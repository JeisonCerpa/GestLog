<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!-- === BRAND (Corporativo) === -->
    <Color x:Key="PrimaryColor">#118938</Color>
    <Color x:Key="PrimaryHoverColor">#149444</Color>
    <Color x:Key="PrimaryPressedColor">#0C6628</Color>
    <Color x:Key="PrimaryLightColor">#1B2A22</Color>
    <Color x:Key="SecondaryBrandColor">#37AB4E</Color>

    <!-- === HEADER === -->
    <Color x:Key="HeaderBackgroundColor">#118938</Color>
    <Color x:Key="HeaderSecondaryButtonColor">#0F7A31</Color>
    <Color x:Key="HeaderSecondaryButtonHoverColor">#27A041</Color>
    <Color x:Key="HeaderSecondaryButtonPressedColor">#0A5724</Color>
    <Color x:Key="HeaderBottomBorderColor">#0A5724</Color>

    <!-- === BACKGROUND (MEJOR ESCALADO DE DEPTH) === -->
    <Color x:Key="BackgroundAppColor">#101412</Color>
    <Color x:Key="BackgroundSurfaceColor">#161C19</Color>
    <Color x:Key="BackgroundElevatedColor">#1E2622</Color>
    <Color x:Key="BackgroundHoverColor">#1F2723</Color>

    <!-- === TEXT (MEJOR JERARQUÍA) === -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextBodyColor">#E5E5E5</Color>
    <Color x:Key="TextSecondaryColor">#B8C2BD</Color>
    <Color x:Key="TextMutedColor">#98A3A0</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>

    <!-- === BORDERS (MÁS VISIBLES EN DARK) === -->
    <Color x:Key="BorderDefaultColor">#303936</Color>
    <Color x:Key="BorderStrongColor">#3A4440</Color>

    <!-- === STATUS === -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="NeutralColor">#9CA3AF</Color>

    <!-- === TABLES (HOVER MÁS CLARO) === -->
    <Color x:Key="TableHeaderColor">#1F2723</Color>
    <Color x:Key="TableRowHoverColor">#26312C</Color>

    <!-- === CORPORATE GRAYS (Original Palette) === -->
    <Color x:Key="CorporateGrayLightColor">#9D9D9C</Color>
    <Color x:Key="CorporateGrayMediumColor">#706F6F</Color>
    <Color x:Key="CorporateGrayDarkColor">#504F4E</Color>
    <Color x:Key="CorporateBlackColor">#1D1D1B</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>

    <!-- Brushes -->
    
    <!-- Brand -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="SecondaryBrandBrush" Color="{StaticResource SecondaryBrandColor}"/>

    <!-- Header -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderSecondaryButtonBrush" Color="{StaticResource HeaderSecondaryButtonColor}"/>
    <SolidColorBrush x:Key="HeaderSecondaryButtonHoverBrush" Color="{StaticResource HeaderSecondaryButtonHoverColor}"/>
    <SolidColorBrush x:Key="HeaderSecondaryButtonPressedBrush" Color="{StaticResource HeaderSecondaryButtonPressedColor}"/>
    <SolidColorBrush x:Key="HeaderBottomBorderBrush" Color="{StaticResource HeaderBottomBorderColor}"/>

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BackgroundAppBrush" Color="{StaticResource BackgroundAppColor}"/>
    <SolidColorBrush x:Key="BackgroundSurfaceBrush" Color="{StaticResource BackgroundSurfaceColor}"/>
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{StaticResource BackgroundElevatedColor}"/>
    <SolidColorBrush x:Key="BackgroundHoverBrush" Color="{StaticResource BackgroundHoverColor}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextBodyBrush" Color="{StaticResource TextBodyColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource NeutralColor}"/>

    <!-- Tables -->
    <SolidColorBrush x:Key="TableHeaderBrush" Color="{StaticResource TableHeaderColor}"/>
    <SolidColorBrush x:Key="TableRowHoverBrush" Color="{StaticResource TableRowHoverColor}"/>

    <!-- === SURFACE LAYERS (CLAVE PARA DEPTH) === -->
    <SolidColorBrush x:Key="SurfaceLayer0Brush" Color="{StaticResource BackgroundAppColor}"/>
    <SolidColorBrush x:Key="SurfaceLayer1Brush" Color="{StaticResource BackgroundSurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLayer2Brush" Color="{StaticResource BackgroundElevatedColor}"/>

    <!-- === EXTRA PRO: OVERLAYS (SIMULAR LUZ EN DARK) === -->
    <!-- Overlay sutil para simular luz -->
    <SolidColorBrush x:Key="OverlayLightBrush" Color="#10FFFFFF"/>
    
    <!-- Overlay hover universal -->
    <SolidColorBrush x:Key="OverlayHoverBrush" Color="#08FFFFFF"/>

</ResourceDictionary>
