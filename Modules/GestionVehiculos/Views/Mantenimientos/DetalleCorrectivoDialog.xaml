<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.DetalleCorrectivoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalles de correctivo"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Style="{StaticResource ModalWindowBase}">

    <Grid x:Name="RootGrid" Background="{DynamicResource ModalOverlayBrush}">
        <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="12" Padding="0"
                Width="920" MaxHeight="860"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="1" BorderBrush="{DynamicResource BorderDefaultBrush}" Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="20,16" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="White" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="40" Height="40">
                                <TextBlock Text="📋" FontSize="20" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TxtTitulo" Text="Detalle del Correctivo" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="White" />
                                <TextBlock x:Name="TxtSubtitulo" Text="Información completa y trazabilidad" FontFamily="Segoe UI" FontSize="11" Foreground="White" Opacity="0.85" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Background="Transparent" Click="BtnClose_Click" ToolTip="Cerrar (Esc)" Cursor="Hand" Padding="8">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundSurfaceBrush}">
                    <StackPanel Margin="20">
                        <!-- Status Badge -->
                        <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📊 Estado del Correctivo" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtEstadoStatus" Text="En Proceso" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Main Metrics Grid - Responsive -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Responsable -->
                            <Border Grid.Column="0" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="👤 Responsable" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtResponsable" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Proveedor -->
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="4,0,4,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🏢 Proveedor" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtProveedor" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Costo Total -->
                            <Border Grid.Column="2" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💰 Costo Total" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtCosto" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Details Row -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Fecha -->
                            <Border Grid.Column="0" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="📅 Fecha de Ejecución" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="TxtFecha" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Factura -->
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="📄 Factura" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBox x:Name="TxtFactura" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button x:Name="BtnAttachFactura" Grid.Column="1" Content="Adjuntar" Margin="8,0,0,0" Padding="10,6" Click="BtnAttachFactura_Click" IsEnabled="False" FontSize="11" Background="{DynamicResource BackgroundSurfaceBrush}" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    
                                    <Button x:Name="BtnOpenFactura" Grid.Column="2" Content="Ver" Margin="8,0,0,0" Padding="10,6" Click="BtnOpenFactura_Click" FontSize="11" Background="{DynamicResource BackgroundSurfaceBrush}" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Desglose de Gastos Section -->
                        <TextBlock Text="💵 Desglose de Gastos" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,12"/>
                        <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,20">
                            <DataGrid x:Name="DgItemsGasto"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      MinHeight="140"
                                      MaxHeight="260"
                                      HeadersVisibility="Column"
                                      Background="{DynamicResource BackgroundSurfaceBrush}"
                                      BorderBrush="{DynamicResource BorderDefaultBrush}"
                                      BorderThickness="0"
                                      RowHeight="36"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      AlternatingRowBackground="{DynamicResource BackgroundElevatedBrush}">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Height" Value="36"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoGastoTexto}" Width="0.4*"/>
                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                    <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="0.5*"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat={}{0:N0}}" Width="0.4*"/>
                                    <DataGridTextColumn Header="Factura" Binding="{Binding NumeroFactura}" Width="0.4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Observaciones Section -->
                        <TextBlock Text="📝 Historial de Observaciones" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                            <TextBox x:Name="TxtTimeline" 
                                     IsReadOnly="True" 
                                     MinHeight="120" 
                                     MaxHeight="180"
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap" 
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextBodyBrush}"
                                     FontSize="12"
                                     Padding="0"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{DynamicResource BackgroundElevatedBrush}" Padding="16" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnEdit" Content="✏️ Editar" Margin="0,0,8,0" Click="BtnEdit_Click" Style="{StaticResource ThemePrimaryButtonStyle}"/>
                        <Button x:Name="BtnCancel" Content="❌ Cancelar" Margin="0,0,8,0" Click="BtnCancel_Click" Style="{StaticResource ThemeSecondaryButtonStyle}" Visibility="Collapsed"/>
                        <Button Content="✖️ Cerrar" Click="BtnClose_Click" Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
