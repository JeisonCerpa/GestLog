<UserControl x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.PlantillasMantenimientoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GestLog.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="{DynamicResource BackgroundSurfaceBrush}">


    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <!-- Plantilla Card para Plantillas -->
        <Style x:Key="PlantillaCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Status Badge Style -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundElevatedBrush}" Padding="28,24" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🧩 Plantillas de Mantenimiento" 
                               FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Crea y administra plantillas reutilizables para todos tus vehículos" 
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Recargar" 
                            Command="{Binding LoadPlantillasCommand}"
                            Style="{StaticResource ThemeSecondaryButtonStyle}" 
                            FocusVisualStyle="{x:Null}"
                            Margin="0,0,12,0"/>
                    <Button Content="➕ Nueva Plantilla" 
                            Click="BtnNuevaPlantilla_Click"
                            Style="{StaticResource ThemePrimaryButtonStyle}" 
                            FocusVisualStyle="{x:Null}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
            <StackPanel Margin="28">
                <!-- SEARCH & FILTER BAR -->
                <Border Background="{DynamicResource BackgroundElevatedBrush}" 
                        BorderBrush="{DynamicResource BorderDefaultBrush}" 
                        BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,24"
                        Effect="{StaticResource WindowShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Input -->
                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ThemeTextBoxStyle}"
                                 Tag="Buscar plantillas..."
                                 Margin="0,0,12,0"/>

                        <!-- Estado Filter -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Estado:" Foreground="{DynamicResource TextBodyBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <ComboBox Style="{StaticResource ThemeComboBoxStyle}" Width="100"
                                      SelectedItem="{Binding FilterEstado}">
                                <sys:String>Todos</sys:String>
                                <sys:String>Activos</sys:String>
                                <sys:String>Inactivos</sys:String>
                            </ComboBox>
                        </StackPanel>

                        <!-- Sort -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Ordenar:" Foreground="{DynamicResource TextBodyBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <ComboBox Style="{StaticResource ThemeComboBoxStyle}" Width="140"
                                      SelectedItem="{Binding SortOption}">
                                <sys:String>Nombre (A-Z)</sys:String>
                                <sys:String>Reciente</sys:String>
                                <sys:String>Frecuencia</sys:String>
                            </ComboBox>
                        </StackPanel>

                        <!-- Clear Button -->
                        <Button Grid.Column="3" Content="Limpiar filtros" 
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ThemeSecondaryButtonStyle}" 
                                FocusVisualStyle="{x:Null}"/>
                    </Grid>
                </Border>

                <!-- MESSAGES -->
                <Border Background="{DynamicResource DangerBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                        Opacity="0.15">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,24"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}"
                        Opacity="0.15">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                </Border>

                <!-- PLANTILLAS GRID (3 COLUMNAS) -->
                <ItemsControl ItemsSource="{Binding FilteredPlantillas}" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3" HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PlantillaCardStyle}" 
                                    Margin="0,0,16,16"
                                    Tag="{Binding}">
                                <StackPanel>
                                    <!-- Card Header -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Nombre}" 
                                                   FontSize="16" FontWeight="Bold" 
                                                   Foreground="{DynamicResource TextBodyBrush}"
                                                   TextWrapping="Wrap"/>

                                        <!-- Status Badge -->
                                        <Border Grid.Column="1" Margin="8,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                    <Setter Property="CornerRadius" Value="6"/>
                                                    <Setter Property="Padding" Value="8,4"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="10" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="🔴 Inactiva"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Activo}" Value="True">
                                                                <Setter Property="Text" Value="🟢 Activa"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Descripcion}" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" 
                                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                               MaxHeight="60"/>

                                    <!-- Intervals -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="KM" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}" 
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding IntervaloKM, StringFormat={}{0:N0}}" 
                                                       Foreground="{DynamicResource TextBodyBrush}" 
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="Días" 
                                                       Foreground="{DynamicResource TextSecondaryBrush}" 
                                                       FontSize="10"/>
                                            <TextBlock Text="{Binding IntervaloDias, StringFormat={}{0}}" 
                                                       Foreground="{DynamicResource TextBodyBrush}" 
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Action Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="✏️ Editar" 
                                                Click="BtnEditarPlantilla_Click"
                                                Style="{StaticResource ThemePrimaryButtonStyle}" 
                                                Padding="8,6" FontSize="11" Margin="0,0,4,0"
                                                FocusVisualStyle="{x:Null}"/>
                                        <Button Grid.Column="1" Content="🗑 Eliminar" 
                                                Click="BtnEliminarPlantilla_Click"
                                                Style="{StaticResource ThemeDangerButtonStyle}" 
                                                Padding="8,6" FontSize="11" Margin="4,0,0,0"
                                                FocusVisualStyle="{x:Null}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- EMPTY STATE -->
                <Border Background="{DynamicResource BackgroundElevatedBrush}" 
                        BorderBrush="{DynamicResource BorderDefaultBrush}" 
                        BorderThickness="1" CornerRadius="12" Padding="40" 
                        TextBlock.TextAlignment="Center"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" Margin="0,0,0,16"/>
                        <TextBlock Text="No hay plantillas que mostrar" 
                                   Foreground="{DynamicResource TextBodyBrush}" 
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Crea una nueva plantilla para comenzar" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
