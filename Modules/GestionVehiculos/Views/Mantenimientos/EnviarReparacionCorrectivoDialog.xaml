<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.EnviarReparacionCorrectivoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enviar a reparación"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Style="{StaticResource ModalWindowBase}">

    <Grid x:Name="RootGrid" Background="{DynamicResource ModalOverlayBrush}">
        <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="12" Padding="0"
                MinWidth="640" MaxWidth="1120" MaxHeight="760"
                HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24"
                BorderThickness="0" Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="18,14" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="36" Height="36" Effect="{StaticResource SectionShadow}">
                                <TextBlock Text="🚚" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Enviar a reparación" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Actualizar a estado En taller" FontFamily="Segoe UI" FontSize="12" Foreground="{DynamicResource TextOnPrimaryBrush}" Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource ThemeCloseButtonStyle}" Click="BtnCancel_Click" ToolTip="Cerrar (Esc)">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,10,16,0" Background="{DynamicResource PrimaryLightBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🚚" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                            <TextBlock Text="Estado destino:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="En taller" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Paso 2 de 3" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" Margin="16,12,16,0" VerticalScrollBarVisibility="Auto">
                    <Border Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Effect="{StaticResource SectionShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="🏭" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                <TextBlock Text="Datos de envío a reparación" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Fecha de envío" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                            <DatePicker x:Name="DpFechaEnvio" SelectedDateFormat="Short" Style="{StaticResource ThemeDatePickerStyle}" Height="40" Margin="0,0,0,12"/>

                            <TextBlock Text="Proveedor (obligatorio)" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbProveedor"
                                      Style="{StaticResource ThemeComboBoxStyle}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="False"
                                      Height="40"
                                      ToolTip="Ej: Taller Los Andes"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Observaciones (opcional)" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtObservaciones" Style="{StaticResource ThemeTextBoxStyle}" Tag="Ej: Ingresa síntoma principal y condición del vehículo" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6" ToolTip="Detalle breve del envío: síntoma principal, condición y notas del taller"/>
                            <TextBlock Text="Sugerencia: describe el síntoma principal y cualquier condición relevante para el taller." FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <TextBlock x:Name="TxtError" Foreground="{DynamicResource DangerBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <Border Grid.Row="3" Background="{DynamicResource BackgroundElevatedBrush}" Padding="14,12" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0,0,8,0" Click="BtnCancel_Click" Padding="12,6"/>
                        <Button Content="Enviar a reparación" Style="{StaticResource ThemePrimaryButtonStyle}" Click="BtnSave_Click" Padding="14,6"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
