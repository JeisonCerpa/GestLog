<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.RegistroCorrectivoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar correctivo"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Style="{StaticResource ModalWindowBase}">

    <Grid x:Name="RootGrid" Background="#80000000">
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="0"
                Width="760" MaxHeight="860"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="0" Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="16,12" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="White" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="36" Height="36" Effect="{StaticResource SectionShadow}">
                                <TextBlock Text="🔧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Registrar mantenimiento correctivo" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="Reporte inicial de falla" FontFamily="Segoe UI" FontSize="12" Foreground="White" Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnCancel_Click" ToolTip="Cerrar (Esc)">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fecha falla" FontWeight="SemiBold"/>
                                <DatePicker SelectedDate="{Binding RegistroFechaEjecucion}" Style="{StaticResource ModernDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Kilometraje" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding RegistroKMAlMomentoInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Descripción de la falla / Observaciones" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding RegistroDescripcionFalla, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,10,0,0" Background="#FAFAFA">
                            <StackPanel>
                                <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🛒" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Carrito de gastos" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                            <TextBlock Text=" · Ítems:" Foreground="#1E3A8A" Margin="10,0,0,0"/>
                                            <TextBlock x:Name="TxtCartItemsCount" Text="0" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="4,0,0,0"/>
                                            <TextBlock Text=" · Total:" Foreground="#1E3A8A" Margin="10,0,0,0"/>
                                            <TextBlock x:Name="TxtCartItemsTotal" Text="$ 0" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="📄 Agregar factura" Style="{StaticResource GhostButton}" Padding="10,4" Click="BtnAddFacturaGroup_Click" ToolTip="Crear un nuevo grupo de factura"/>
                                    </Grid>
                                </Border>

                                <ItemsControl x:Name="IcItemsGasto">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,12" Background="White">
                                                <Expander IsExpanded="False" Background="Transparent" BorderThickness="0">
                                                    <Expander.Header>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="📄 Factura / remisión" FontWeight="SemiBold" Foreground="#1F2937" FontSize="12"/>
                                                                <TextBlock Text="{Binding NumeroFactura, StringFormat='N°: {0}'}" Foreground="#6B7280" FontSize="10" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <TextBlock Text="Ítems:" Foreground="#475569" FontSize="10" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding Items.Count}" Foreground="#475569" FontWeight="SemiBold" FontSize="10" Margin="0,0,10,0"/>
                                                                <TextBlock Text="Total: $" Foreground="#374151" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding TotalGrupo, StringFormat='{}{0:N0}'}" Foreground="#1F2937" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                                                <Button Content="Quitar factura" Margin="12,0,0,0" Style="{StaticResource GhostButton}" Padding="10,4" Click="BtnRemoveFacturaGroup_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Expander.Header>
                                                    <StackPanel Margin="0,10,0,0">

                                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="180"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="220"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="N° factura" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,4"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Proveedor" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,4"/>
                                                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Documento adjunto" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,4"/>

                                                            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NumeroFactura, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding ProveedorFactura, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                            <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding RutaFactura}" Style="{StaticResource ModernTextBoxStyle}" IsReadOnly="True"/>
                                                            <Button Grid.Row="1" Grid.Column="5" Content="Adjuntar" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="10,6" Click="BtnAttachFacturaGroup_Click"/>
                                                            <Button Grid.Row="1" Grid.Column="6" Content="Ver" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="10,6" Click="BtnOpenFacturaGroup_Click"/>
                                                        </Grid>
                                                    </Border>

                                                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                                                        <StackPanel>
                                                            <TextBlock Text="Agregar ítem a esta factura" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                                            <Grid Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="120"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ComboBox Grid.Column="0" Margin="0,0,8,0" SelectedValuePath="Tag" SelectedValue="{Binding DraftTipoGasto}">
                                                                    <ComboBoxItem Content="Repuesto" Tag="1"/>
                                                                    <ComboBoxItem Content="Mano de obra" Tag="2"/>
                                                                    <ComboBoxItem Content="Servicio externo" Tag="3"/>
                                                                    <ComboBoxItem Content="Otro" Tag="4"/>
                                                                </ComboBox>
                                                                <TextBox Grid.Column="1" Margin="0,0,8,0" Text="{Binding DraftDescripcion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                                <TextBox Grid.Column="2" Margin="0,0,8,0" Text="{Binding DraftValorInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                                <Button Grid.Column="3" Content="Agregar" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Click="BtnAddGastoItem_Click"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="8">
                                                        <StackPanel>
                                                            <TextBlock Text="Resumen de ítems" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="140"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="90"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0" Text="{Binding TipoGastoLabel}" FontWeight="SemiBold" Foreground="#1F2937"/>
                                                                                <TextBlock Grid.Column="1" Text="{Binding Descripcion}" Foreground="#1F2937" TextWrapping="Wrap" Margin="8,0,0,0"/>
                                                                                <TextBlock Grid.Column="2" Text="{Binding ValorInput}" Foreground="#0F766E" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="8,0,0,0"/>
                                                                                <Button Grid.Column="3" Content="Editar" Style="{StaticResource GhostButton}" Padding="10,4" Margin="12,0,0,0" Click="BtnEditGastoItem_Click"/>
                                                                                <Button Grid.Column="4" Content="Quitar" Style="{StaticResource GhostButton}" Padding="10,4" Margin="8,0,0,0" Click="BtnRemoveGastoItem_Click" Foreground="#C0392B"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                    </StackPanel>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Aquí puedes registrar repuestos, mano de obra u otros costos desde el primer momento." FontSize="10" Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#F5F5F5" Padding="12" CornerRadius="0,0,12,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                        <Button Content="Guardar" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSave_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
