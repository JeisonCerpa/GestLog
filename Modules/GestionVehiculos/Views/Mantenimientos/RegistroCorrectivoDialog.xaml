<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.RegistroCorrectivoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Registrar correctivo"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Style="{StaticResource ModalWindowBase}">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <converters:IsStringNullOrEmptyConverter x:Key="IsStringNullOrEmptyConverter" />
        <converters:AlternationIndexToColorConverter x:Key="AlternationIndexToColorConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="#80000000">
        <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="12" Padding="0"
                MinWidth="640" MaxWidth="1120" MaxHeight="860"
                HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="24"
                BorderThickness="0" Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="16,12" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="36" Height="36" Effect="{StaticResource SectionShadow}">
                                <TextBlock Text="🔧" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Registrar mantenimiento correctivo" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Reporte inicial de falla" FontFamily="Segoe UI" FontSize="12" Foreground="{DynamicResource TextOnPrimaryBrush}" Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource ThemeCloseButtonStyle}" Click="BtnCancel_Click" ToolTip="Cerrar (Esc)">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,10,16,0" Background="{DynamicResource PrimaryLightBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📝" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                            <TextBlock Text="Fase:" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Registro de falla" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Paso 1 de 3" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" Margin="16,12,16,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="16" Effect="{StaticResource SectionShadow}" Margin="0,0,0,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                    <TextBlock Text="Datos iniciales de la falla" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Fecha falla" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                                        <DatePicker SelectedDate="{Binding RegistroFechaEjecucion}" Style="{StaticResource ThemeDatePickerStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Kilometraje" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                                        <Grid Height="40" VerticalAlignment="Top">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding RegistroKMAlMomentoInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Margin="0" Height="40" VerticalAlignment="Stretch"/>
                                            <Button Grid.Column="2" Content="Tomar actual" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0" Padding="10,6" Height="40" MinWidth="96" Click="BtnTomarKmActual_Click" VerticalAlignment="Stretch" FontSize="10"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Descripción de la falla / Observaciones" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,12,0,6"/>
                                <TextBox Text="{Binding RegistroDescripcionFalla, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="12" Effect="{StaticResource SectionShadow}" Margin="0,0,0,8" Visibility="Collapsed">
                            <StackPanel>
                                <Border CornerRadius="10" Padding="16,12" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource PrimaryLightColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource BackgroundHoverColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="🛒" FontSize="18" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="{DynamicResource BackgroundHoverBrush}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="📦" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                <TextBlock x:Name="TxtCartItemsCount" Text="0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text=" ítems" FontSize="10" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Background="{DynamicResource PrimaryLightBrush}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="💰" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                <TextBlock x:Name="TxtCartItemsTotal" Text="$ 0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="3"/>
                                        <Button Grid.Column="4" Content="+ Agregar factura" Style="{StaticResource ThemeSecondaryButtonStyle}" Padding="12,6" Click="BtnAddFacturaGroup_Click" ToolTip="Crear un nuevo grupo de factura" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource PrimaryBrush}"/>
                                    </Grid>
                                </Border>

                                <ItemsControl x:Name="IcItemsGasto">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="0" Margin="0,0,0,14" Background="{DynamicResource BackgroundSurfaceBrush}" Effect="{StaticResource CardShadow}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0" Margin="0,12,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <ToggleButton Grid.Column="0" Margin="8,0,0,0" Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}" IsChecked="{Binding IsExpanded}">
                                                            <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='▼|▶'}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                        </ToggleButton>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="📄" FontSize="16" VerticalAlignment="Center" Margin="6,0,8,0" Foreground="{DynamicResource TextBodyBrush}"/>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="Factura / Remisión" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" FontSize="12"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{Binding NumeroFactura, StringFormat='N°: {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                                                    <TextBlock Text="{Binding ProveedorFactura, StringFormat=' | {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" Margin="12,0,8,0">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="📌" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                                    <TextBlock Text="{Binding Items.Count}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center"/>
                                                                    <TextBlock Text=" ítems" FontSize="10" Foreground="{DynamicResource TextBodyBrush}" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="6" Padding="8,4" VerticalAlignment="Center" Margin="0,0,0,0">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="💵" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                                    <TextBlock Text="{Binding TotalGrupo, StringFormat='{}{0:N0}'}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>

                                                        <Border Grid.Column="2"/>

                                                        <Button Grid.Column="3" Content="✕ Quitar" Style="{StaticResource ThemeSecondaryButtonStyle}" Padding="8,4" Click="BtnRemoveFacturaGroup_Click" Foreground="{DynamicResource DangerBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0" HorizontalAlignment="Right"/>
                                                    </Grid>

                                                    <StackPanel Grid.Row="1" Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="14,12,14,12">
                                                        <Border Height="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,0,0,12"/>

                                                        <StackPanel Margin="0,0,0,12" Visibility="{Binding NumeroFactura, Converter={StaticResource IsStringNullOrEmptyConverter}}">
                                                            <TextBlock Text="Datos de la factura / remisión" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" FontSize="11" Margin="0,0,0,10"/>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="12"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="12"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock Text="📋 N° factura" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                                                                    <TextBox Text="{Binding NumeroFactura, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="40"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Text="🏢 Proveedor" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                                                                    <ComboBox Style="{StaticResource ThemeComboBoxStyle}"
                                                                              Height="40"
                                                                              IsEditable="True"
                                                                              IsTextSearchEnabled="False"
                                                                              StaysOpenOnEdit="True"
                                                                              Text="{Binding ProveedorFactura, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ProveedorFacturaOptions}"
                                                                              DropDownOpened="ProveedorFacturaCombo_DropDownOpened"
                                                                              KeyUp="ProveedorFacturaCombo_KeyUp"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="4">
                                                                    <TextBlock Text="📎 Documento" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,6"/>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="8"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBox Grid.Column="0" Text="{Binding RutaFactura}" Style="{StaticResource ThemeTextBoxStyle}" IsReadOnly="True" Height="40"/>
                                                                        <Button Grid.Column="2" Content="Adjuntar" Style="{StaticResource ThemeSecondaryButtonStyle}" Padding="10,6" Click="BtnAttachFacturaGroup_Click" VerticalAlignment="Center" FontSize="10"/>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>

                                                        <Border Height="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,0,0,12"/>

                                                        <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                    <TextBlock Text="➕" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                                                    <TextBlock Text="Agregar ítem a esta factura" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontSize="11"/>
                                                                </StackPanel>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="12"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="12"/>
                                                                        <ColumnDefinition Width="140"/>
                                                                        <ColumnDefinition Width="12"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="📦 Tipo de gasto" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,4"/>
                                                                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding DraftTipoGasto}" IsEditable="False" IsReadOnly="True" Height="40" Style="{StaticResource ThemeComboBoxStyle}">
                                                                            <ComboBoxItem Content="Repuesto" Tag="1"/>
                                                                            <ComboBoxItem Content="Mano de obra" Tag="2"/>
                                                                            <ComboBoxItem Content="Servicio externo" Tag="3"/>
                                                                            <ComboBoxItem Content="Otro" Tag="4"/>
                                                                        </ComboBox>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="2">
                                                                        <TextBlock Text="📝 Descripción" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,4"/>
                                                                        <TextBox Text="{Binding DraftDescripcion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" Background="{DynamicResource BackgroundSurfaceBrush}" Tag="Ej: Repuesto o Aceite"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="4">
                                                                        <TextBlock Text="💵 Valor (COP)" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,4"/>
                                                                        <TextBox Text="{Binding DraftValorInput, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" Background="{DynamicResource BackgroundSurfaceBrush}" Tag="Ej: 50000" InputScope="Number"/>
                                                                    </StackPanel>

                                                                    <Button Grid.Column="6" Content="➕ Agregar" Style="{StaticResource ThemePrimaryButtonStyle}" Padding="14,8" Click="BtnAddGastoItem_Click" VerticalAlignment="Bottom" FontSize="10"/>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>

                                                        <Border Height="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,0,0,12"/>

                                                        <StackPanel>
                                                            <TextBlock Text="Ítems en esta factura" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,8" FontSize="11"/>
                                                            <Border Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Effect="{StaticResource CardShadow}">
                                                                <StackPanel>
                                                                    <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1" Padding="12,10,12,10">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="Tipo" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                                                            <TextBlock Grid.Column="1" Text="Descripción" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="8,0,0,0"/>
                                                                            <TextBlock Grid.Column="2" Text="Valor" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center"/>
                                                                            <TextBlock Grid.Column="3" Text="Acciones" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" HorizontalAlignment="Center"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <ItemsControl ItemsSource="{Binding Items}" AlternationCount="2">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1" Padding="12,10,12,10">
                                                                                    <Border.Background>
                                                                                        <SolidColorBrush Color="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource AlternationIndexToColorConverter}}"/>
                                                                                    </Border.Background>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{Binding TipoGastoLabel}" Foreground="{DynamicResource TextBodyBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                                                        <TextBlock Grid.Column="1" Text="{Binding Descripcion}" Foreground="{DynamicResource TextBodyBrush}" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                                                                        <TextBlock Grid.Column="2" Text="{Binding ValorInput, StringFormat='$ {0}'}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0,0,0">
                                                                                            <Border Background="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" CornerRadius="5" Width="32" Height="32" Cursor="Hand" Padding="4">
                                                                                                <Button Content="✎" Style="{StaticResource ThemeTableActionButtonStyle}" Click="BtnEditGastoItem_Click" ToolTip="Editar" FontSize="15"/>
                                                                                            </Border>
                                                                                            <Border Background="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}" CornerRadius="5" Width="32" Height="32" Margin="8,0,0,0" Cursor="Hand" Padding="4">
                                                                                                <Button Content="✕" Style="{StaticResource ThemeTableActionButtonStyle}" Click="BtnRemoveGastoItem_Click" ToolTip="Quitar" FontSize="15"/>
                                                                                            </Border>
                                                                                        </StackPanel>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Aquí puedes registrar repuestos, mano de obra u otros costos desde el primer momento." FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ℹ️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                <TextBlock Text="En este paso solo se registra la falla. Los costos y facturas se agregan al completar el correctivo." FontSize="11" Foreground="{DynamicResource TextBodyBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource DangerBrush}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" Background="{DynamicResource BackgroundElevatedBrush}" Padding="14,12" CornerRadius="0,0,12,12" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0,0,8,0" Click="BtnCancel_Click" Padding="12,6"/>
                        <Button Content="Guardar" Style="{StaticResource ThemePrimaryButtonStyle}" Click="BtnSave_Click" Padding="14,6"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

