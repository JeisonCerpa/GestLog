<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.CrearEditarPlantillaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Plantilla de Mantenimiento"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource ModalOverlayBrush}" MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="12" Padding="0"
                Width="550" Height="650"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="0" Effect="{StaticResource WindowShadow}" MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                Style="{StaticResource ModalCardStyle}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="24,20" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Foreground="White">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource HeaderTextStyle}">
                                        <Setter Property="Text" Value="🧩 Nueva Plantilla"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPlantilla}" Value="{x:Null}">
                                                <Setter Property="Text" Value="🧩 Nueva Plantilla"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Foreground="White" Opacity="0.95" Margin="0,3,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SubHeaderTextStyle}">
                                        <Setter Property="Text" Value="Configura los intervalos de mantenimiento"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPlantilla}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Configura los intervalos de mantenimiento"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="BtnClose" Style="{StaticResource CloseButton}" Click="BtnClose_Click" ToolTip="Cerrar (Esc)" HorizontalAlignment="Right" VerticalAlignment="Center" FocusVisualStyle="{x:Null}">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
                    <StackPanel Margin="24">
                        <!-- Nombre -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Nombre *" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NuevaPlantillaNombre, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ThemeTextBoxStyle}"
                                     Tag="Ej: Cambio de aceite" />
                        </StackPanel>

                        <!-- Descripción -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Descripción" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NuevaPlantillaDescripcion, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ThemeTextBoxStyle}"
                                     Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                     Tag="Describe qué incluye este mantenimiento..."
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>

                        <!-- Intervalos -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Cada cuántos KM *" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NuevoIntervaloKm, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Tag="5000"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Cada cuántos días *" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding NuevoIntervaloDias, UpdateSourceTrigger=PropertyChanged}" 
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Tag="180"/>
                            </StackPanel>
                        </Grid>

                        <!-- Error Message -->
                        <Border Background="{DynamicResource DangerBrush}" CornerRadius="6" Padding="12" 
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                                Opacity="0.15">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontSize="12" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1,1,1,0" Padding="16" CornerRadius="0,0,12,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0,0,8,0" Click="BtnCancel_Click" FocusVisualStyle="{x:Null}" />
                        <Button Content="Guardar Plantilla" Style="{StaticResource ThemePrimaryButtonStyle}" Command="{Binding CrearPlantillaCommand}" FocusVisualStyle="{x:Null}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
