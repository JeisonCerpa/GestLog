<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.EjecucionMantenimientoDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GestLog.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:GestLog.Modules.GestionVehiculos.Models.Enums"
        Title="Detalle de ejecución" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent" ResizeMode="CanResize"
        WindowState="Maximized" Style="{StaticResource ModalWindowBase}">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:PathToFileNameConverter x:Key="PathToFileNameConverter" />
        <!-- items for estado enum -->
        <ObjectDataProvider x:Key="EstadoEjecucionValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:EstadoEjecucion" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource ModalOverlayBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="12" Padding="0"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="1" BorderBrush="{DynamicResource BorderDefaultBrush}" Effect="{StaticResource WindowShadow}"
                MaxWidth="920" MinWidth="500">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- header with icon, title and action buttons -->
                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="20,16" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="White" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="40" Height="40">
                                <TextBlock Text="ℹ️" FontSize="20" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalle de Ejecución" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="Información completa y trazabilidad" FontFamily="Segoe UI" FontSize="11" Foreground="White" Opacity="0.85" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Background="Transparent" Click="BtnClose_Click" ToolTip="Cerrar (Esc)" Cursor="Hand" Padding="8">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundSurfaceBrush}">
                    <StackPanel Margin="20">
                        <!-- Status Badge -->
                        <Border Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,20" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="📊 Estado de la Ejecución" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding EstadoEnum}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Main Metrics Grid - Responsive -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Plan -->
                            <Border Grid.Column="0" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="📋 Plan" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding PlanNombre}" Background="Transparent" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Responsable -->
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="4,0,4,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="👤 Responsable" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding ResponsableEjecucion, Mode=TwoWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Costo Total -->
                            <Border Grid.Column="2" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="💰 Costo" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding Costo, StringFormat={}{0:C2}, Mode=TwoWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Details Row -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Fecha -->
                            <Border Grid.Column="0" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="📅 Fecha de Ejecución" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding FechaEjecucion, StringFormat={}{0:dd/MM/yyyy}, Mode=TwoWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: KM -->
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🛣️ Kilometraje" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding KMAlMomento, Mode=TwoWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Proveedor & Factura Row -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Card: Proveedor -->
                            <Border Grid.Column="0" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🏢 Proveedor" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBox Text="{Binding Proveedor, Mode=TwoWay}" IsReadOnly="True" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: Factura -->
                            <Border Grid.Column="1" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="📄 Factura" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding RutaFactura, Converter={StaticResource PathToFileNameConverter}}" Background="Transparent" Foreground="{DynamicResource TextBodyBrush}" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="Ver" Margin="8,0,0,0" Padding="10,6" Click="BtnOpenFactura_Click" FontSize="11" Background="{DynamicResource BackgroundSurfaceBrush}" Foreground="{DynamicResource TextSecondaryBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Observaciones Section -->
                        <TextBlock Text="📝 Observaciones Técnicas" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,20">
                            <TextBox Text="{Binding ObservacionesTecnico, Mode=TwoWay}" 
                                     IsReadOnly="True"
                                     MinHeight="120" 
                                     MaxHeight="180"
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap" 
                                     VerticalScrollBarVisibility="Auto"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextBodyBrush}"
                                     FontSize="12"
                                     Padding="0"/>
                        </Border>

                        <!-- Desglose de Gastos Section -->
                        <TextBlock Text="💵 Desglose de Gastos" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,12"/>
                        <Border BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="0" Margin="0,0,0,20">
                            <DataGrid ItemsSource="{Binding ItemsGasto}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      MinHeight="140"
                                      MaxHeight="260"
                                      HeadersVisibility="Column"
                                      Background="{DynamicResource BackgroundSurfaceBrush}"
                                      BorderBrush="{DynamicResource BorderDefaultBrush}"
                                      BorderThickness="0"
                                      RowHeight="36"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="None"
                                      AlternatingRowBackground="{DynamicResource BackgroundElevatedBrush}">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="Padding" Value="12,8"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Height" Value="36"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoGastoTexto}" Width="0.4*"/>
                                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                                    <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="0.5*"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat={}{0:N0}}" Width="0.4*"/>
                                    <DataGridTextColumn Header="Factura" Binding="{Binding NumeroFactura}" Width="0.4*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{DynamicResource BackgroundElevatedBrush}" Padding="20,16" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Editar" Click="BtnEdit_Click" Style="{StaticResource ThemePrimaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Cancelar" Click="BtnCancel_Click" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button Content="Eliminar" Click="BtnDelete_Click" Style="{StaticResource ThemeDangerButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>