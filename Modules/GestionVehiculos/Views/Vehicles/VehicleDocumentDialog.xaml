<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Vehicles.VehicleDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GestLog.Modules.GestionVehiculos.ViewModels.Vehicles"
        xmlns:conv="clr-namespace:GestLog.Converters"
        xmlns:controls="clr-namespace:GestLog.Controls"
        Title="Documento de Vehículo"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">

    <!-- CONVERTERS -->
    <Window.Resources>
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <!-- OVERLAY MODAL --><Grid x:Name="RootGrid" Background="#80000000" MouseLeftButtonDown="Overlay_MouseLeftButtonDown" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Border x:Name="Card" Background="{DynamicResource BackgroundElevatedBrush}" CornerRadius="14" Padding="0"
                Width="1200" Height="700"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="0" Effect="{StaticResource WindowShadow}" MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                Style="{StaticResource ModalCardStyle}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="14,14,0,0" Padding="24,20" Effect="{DynamicResource ThemeCardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource TextOnPrimaryBrush}" BorderThickness="0" CornerRadius="8" Padding="8" Margin="0,0,16,0" Width="44" Height="44">
                                <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Nuevo documento" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                <TextBlock Text="Adjunte SOAT, Tecno-Mecánica u otros documentos" FontSize="13" Foreground="{DynamicResource TextOnPrimaryBrush}" Opacity="0.95" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" x:Name="BtnCloseHeader" Style="{StaticResource ThemeCloseButtonStyle}" Click="BtnCancel_Click" ToolTip="Cerrar (Esc)" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>                </Border>                <!-- CONTENIDO - LAYOUT HORIZONTAL (Izquierda: Datos | Derecha: Archivo) -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />                    </Grid.ColumnDefinitions>
                      <!-- COLUMNA IZQUIERDA: DATOS DEL DOCUMENTO Y OBSERVACIONES -->
                    <Grid Grid.Column="0" Margin="24,24,16,24" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>                        <!-- CARD 1: DATOS DEL DOCUMENTO -->
                        <Border Grid.Row="0" Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,10">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="📋 Datos del Documento" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                
                                <!-- Fila 1: Tipo de documento y Número (lado a lado, 50% cada uno) -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Tipo de documento -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,8,0">
                                        <TextBlock Text="Tipo de documento" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                        <ComboBox ItemsSource="{Binding DocumentTypes}" SelectedItem="{Binding DocumentType}" Style="{StaticResource ThemeComboBoxStyle}" Margin="0" Height="36"/>
                                    </StackPanel>
                                    
                                    <!-- Número -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                                        <TextBlock Text="Número" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding DocumentNumber}" Style="{StaticResource ThemeTextBoxStyle}" Margin="0" Height="36"/>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Fila 2: Fecha de emisión y Fecha de vencimiento (lado a lado, 50% cada uno) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Fecha de emisión -->
                                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,8,0">
                                        <TextBlock Text="Fecha de emisión" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                        <DatePicker SelectedDate="{Binding IssuedDate}" Style="{StaticResource ThemeDatePickerStyle}" Margin="0" Height="36"/>
                                    </StackPanel>
                                    
                                    <!-- Fecha de vencimiento -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                                        <TextBlock Text="Fecha de vencimiento" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4" />
                                        <DatePicker SelectedDate="{Binding ExpirationDate}" Style="{StaticResource ThemeDatePickerStyle}" Margin="0" Height="36"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CARD OBSERVACIONES: ocupa todo el espacio restante y se estira -->
                        <Border Grid.Row="1" Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0" VerticalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="📝 Observaciones" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>                                <!-- TextBox estirable: quitar MinHeight fijo, usar Stretch para llenar la fila '*' -->
                                <TextBox Grid.Row="1"
                                         Text="{Binding Notes}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Padding="10,6"
                                         Margin="0"
                                         VerticalAlignment="Stretch"
                                         VerticalContentAlignment="Top"/>
                            </Grid>
                        </Border>
                    </Grid>
                      <!-- COLUMNA DERECHA: ARCHIVO ADJUNTO (PROMINENTE) -->
                    <Border Grid.Column="1" Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2" CornerRadius="8" Padding="16" Margin="0,24,24,24" VerticalAlignment="Stretch">
                        <StackPanel Orientation="Vertical" Margin="0,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="📎 ARCHIVO ADJUNTO" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                              <!-- Botón seleccionar -->
                            <Button x:Name="BtnSelectFile" Content="📁 Seleccionar archivo..." Click="BtnSelectFile_Click" Style="{StaticResource ThemePrimaryButtonStyle}" Margin="0,10,0,16" HorizontalAlignment="Stretch" Padding="12,12" Height="44"/>
                            
                            <!-- Info archivo seleccionado - PROMINENTE -->
                            <TextBlock Text="Archivo seleccionado:" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>                            <TextBlock x:Name="TxtSelectedFile" Text="{Binding SelectedFileName, TargetNullValue='(ninguno seleccionado)'}" 
                                       Foreground="{DynamicResource PrimaryBrush}" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,12"/>
                              <!-- Línea separadora -->
                            <Border Height="1" Background="{DynamicResource BorderDefaultBrush}" Margin="0,0,0,12"/>
                              <!-- Preview y metadata -->
                            <Border Height="100" Width="100" CornerRadius="8" Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Grid x:Name="PreviewContainer">
                                    <!-- Imagen real (cuando exista preview de imagen) -->
                                    <Image x:Name="ImgPreview" Source="{Binding SelectedFilePreview}" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding IsImagePreview, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <!-- Icono para PDF: emoji centrado, ocupa todo el área -->
                                    <Grid x:Name="PdfIconContainer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <Grid.Visibility>
                                            <Binding Path="IsPdfSelected" Converter="{StaticResource BooleanToVisibilityConverter}" />
                                        </Grid.Visibility>
                                        <Viewbox Stretch="Uniform">
                                            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource PrimaryBrush}"/>
                                        </Viewbox>
                                    </Grid>
                                </Grid>
                            </Border>
                              <!-- Metadatos -->
                            <StackPanel Orientation="Vertical">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Tamaño:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Width="70"/>
                                    <TextBlock x:Name="TxtSelectedFileSize" Grid.Column="1" Text="{Binding SelectedFileSize, TargetNullValue='---'}" Foreground="{DynamicResource TextBodyBrush}"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Tipo:" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Width="70"/>
                                    <TextBlock x:Name="TxtSelectedFileMime" Grid.Column="1" Text="{Binding SelectedFileMimeType, TargetNullValue='---'}" Foreground="{DynamicResource TextBodyBrush}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Inline validation message for selected file -->
                            <TextBlock Text="{Binding SelectedFileError}" Foreground="{DynamicResource DangerBrush}" FontSize="12" Margin="6,8,6,0" Visibility="{Binding SelectedFileError, Converter={StaticResource StringToVisibilityConverter}}" />                            <!-- Botones de acciones -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Center">
                                <Button Content="👁️ Ver" Command="{Binding OpenSelectedFileCommand}" Style="{StaticResource ThemeSecondaryButtonStyle}" Width="90" Height="36" Margin="0,0,8,0" 
                                        ToolTip="Abrir archivo seleccionado" />
                                <Button x:Name="BtnRemoveFile" Content="✕ Remover" Command="{Binding RemoveSelectedFileCommand}" Click="BtnRemoveFile_Click" Style="{StaticResource ThemeSecondaryButtonStyle}" Width="90" Height="36"
                                        ToolTip="Remover archivo seleccionado" />
                            </StackPanel>
                              <!-- Progreso carga -->
                            <StackPanel Orientation="Vertical" Margin="0,12,0,0">
                                <controls:SimpleProgressBar Width="Auto" BarHeight="8" ProgressValue="{Binding UploadProgress, Mode=OneWay}" ShowHeader="False" ShowMessage="False" ShowPercentage="True">
                                    <controls:SimpleProgressBar.Visibility>
                                        <MultiBinding Converter="{StaticResource LoadingIndicatorVisibilityConverter}">
                                            <Binding Path="IsUploading" />
                                            <Binding Path="UploadProgress" />
                                        </MultiBinding>
                                    </controls:SimpleProgressBar.Visibility>
                                </controls:SimpleProgressBar>
                            </StackPanel>
                        </StackPanel>
                    </Border>                </Grid>                <!-- FOOTER -->
                <Border Grid.Row="2" Padding="24,12" Background="Transparent" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0">                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Cancelar" Click="BtnCancel_Click" Width="110" Height="40" Style="{StaticResource ThemeSecondaryButtonStyle}" Margin="0,0,8,0"/>
                        <Button x:Name="BtnSave" Content="Guardar" Width="110" Height="40" Command="{Binding SaveCommand}" IsDefault="True" ToolTip="{Binding DisabledReason}" Style="{StaticResource ThemePrimaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>