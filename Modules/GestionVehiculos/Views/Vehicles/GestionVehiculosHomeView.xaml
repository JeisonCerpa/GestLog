<UserControl x:Class="GestLog.Modules.GestionVehiculos.Views.Vehicles.GestionVehiculosHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GestLog.Converters"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignWidth="1200" d:DesignHeight="800"
             Background="{DynamicResource BackgroundSurfaceBrush}"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <!-- Estilo para cards de vehículos -->
        <Style x:Key="VehicleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="4" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION CON ESTADÍSTICAS -->
        <Border Grid.Row="0" Background="{DynamicResource BackgroundElevatedBrush}" Padding="28,24" Effect="{StaticResource HeaderShadow}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🚗 Gestión de Vehículos" 
                               FontSize="28" FontWeight="Bold" 
                               Foreground="{DynamicResource TextBodyBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Administra vehículos, mantenimientos y documentación" 
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AbrirConfiguracionPlantillasCommand}" ToolTip="Configuración de plantillas"
                            Style="{StaticResource ThemePrimaryButtonStyle}" 
                            Content="⚙️ Plantillas" FocusVisualStyle="{x:Null}" Margin="0,0,12,0"/>
                    <Button Command="{Binding AgregarVehiculoAsyncCommand}" ToolTip="Agregar vehículo"
                            Style="{StaticResource ThemePrimaryButtonStyle}" 
                            Content="➕ Agregar Vehículo" Click="BtnAgregar_Click" FocusVisualStyle="{x:Null}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
            <StackPanel Margin="28,28,28,40">
                <!-- SEARCH & FILTER BAR -->
                <Border Background="{DynamicResource BackgroundElevatedBrush}" 
                        BorderBrush="{DynamicResource BorderDefaultBrush}" 
                        BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,24"
                        Effect="{StaticResource WindowShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search Input -->
                        <TextBox Grid.Column="0" 
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ThemeTextBoxStyle}"
                                 Tag="Buscar vehículos..."
                                 Margin="0,0,12,0"/>

                        <!-- Estado Filter -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Estado:" Foreground="{DynamicResource TextBodyBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <ComboBox Style="{StaticResource ThemeComboBoxStyle}" Width="100"
                                      SelectedItem="{Binding FilterEstado}">
                                <sys:String>Todos</sys:String>
                                <sys:String>Activos</sys:String>
                                <sys:String>Con Alertas</sys:String>
                            </ComboBox>
                        </StackPanel>

                        <!-- Sort -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Ordenar:" Foreground="{DynamicResource TextBodyBrush}" 
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                            <ComboBox Style="{StaticResource ThemeComboBoxStyle}" Width="120"
                                      SelectedItem="{Binding SortOption}">
                                <sys:String>Nombre (A-Z)</sys:String>
                                <sys:String>Alertas</sys:String>
                                <sys:String>Reciente</sys:String>
                            </ComboBox>
                        </StackPanel>

                        <!-- Clear Button -->
                        <Button Grid.Column="3" Content="Limpiar filtros" 
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ThemeSecondaryButtonStyle}" 
                                FocusVisualStyle="{x:Null}"/>
                    </Grid>
                </Border>

                <!-- VEHÍCULOS GRID (4 COLUMNAS) -->
                <ItemsControl ItemsSource="{Binding FilteredVehicles}" Margin="0,0,0,24">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" HorizontalAlignment="Stretch"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource VehicleCardStyle}" 
                                    Margin="0,0,16,16">
                                <Grid>
                                    <StackPanel Margin="16">
                                    <!-- Card Header con Status Indicator -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding VehicleName}" 
                                                       FontSize="14" FontWeight="Bold" 
                                                       Foreground="{DynamicResource TextBodyBrush}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Plate}" 
                                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- Status Indicator -->
                                        <TextBlock Grid.Column="1" Text="{Binding StateIndicator}" 
                                                   FontSize="18" Margin="8,0,0,0"
                                                   Foreground="{Binding StateIndicatorBrush}"/>
                                    </Grid>

                                    <!-- Foto del vehículo -->
                                    <Border Height="100" Margin="0,0,0,12" CornerRadius="6"
                                            Background="{DynamicResource BackgroundSurfaceBrush}" ClipToBounds="True">
                                        <Image Source="{Binding PhotoPath}" Stretch="Uniform"/>
                                    </Border>

                                    <!-- Kilometraje -->
                                    <TextBlock Text="{Binding MileageText}" 
                                               Foreground="{DynamicResource TextSecondaryBrush}" 
                                               FontSize="11" Margin="0,0,0,8"/>

                                    <!-- Action Buttons -->
                                    <Button Content="📋 Detalles" 
                                            Command="{Binding VerDetallesCommand}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}" 
                                            Padding="8,6" FontSize="11" Margin="0,8,0,0"
                                            FocusVisualStyle="{x:Null}"/>
                                    </StackPanel>

                                    <Border Background="#88000000"
                                            CornerRadius="12"
                                            Visibility="{Binding IsDiscarded, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- EMPTY STATE -->
                <Border Background="{DynamicResource BackgroundElevatedBrush}" 
                        BorderBrush="{DynamicResource BorderDefaultBrush}" 
                        BorderThickness="1" CornerRadius="12" Padding="60,40" 
                        TextBlock.TextAlignment="Center"
                        Visibility="{Binding HasNoVehicles, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📭" FontSize="48" Margin="0,0,0,16"/>
                        <TextBlock Text="No hay vehículos" 
                                   Foreground="{DynamicResource TextBodyBrush}" 
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Comienza agregando tu primer vehículo" 
                                   Foreground="{DynamicResource TextSecondaryBrush}" 
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
