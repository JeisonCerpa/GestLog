<UserControl x:Class="GestLog.Modules.GestionVehiculos.Views.Vehicles.VehicleDocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:GestLog.Controls"
             xmlns:converters="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="520">

    <UserControl.Resources>
        <converters:LoadingIndicatorVisibilityConverter x:Key="LoadingIndicatorVisibilityConverter" />
        
        <!-- Estilo para centrar TextBlocks dentro de columnas de texto (usado por ElementStyle) -->
        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
        </Style>

        <!-- Estilos para DataGrid con tema -->
        <Style TargetType="DataGrid" x:Key="DocumentsDataGridStyle">
            <Setter Property="RowHeight" Value="48" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource BackgroundElevatedBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="6,0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="8,0" />
        </Style>

        <!-- Estilo para botones de acción (icon-buttons) -->
        <Style x:Key="ActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="6" Width="36" Height="36">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row style para alinear contenido verticalmente y controlar selección -->
        <Style x:Key="DocumentsDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundSurfaceBrush}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: búsqueda y acciones -->
        <Border Grid.Row="0" Style="{StaticResource ThemeElevatedCardStyle}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search box -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔎" VerticalAlignment="Center" Margin="6,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextOnPrimaryBrush}" FontSize="13"
                                 VerticalAlignment="Center" Padding="6,6" HorizontalAlignment="Stretch" />
                        <TextBlock IsHitTestVisible="False" Text="Buscar documentos..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>

                <!-- Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Style="{StaticResource ThemePrimaryButtonStyle}" Content="➕" Click="BtnNewDocument_Click" ToolTip="Nuevo documento" FontSize="18" Margin="0,0,8,0" Padding="10,8" />
                    <Button Style="{StaticResource ThemePrimaryButtonStyle}" Content="🔄" Command="{Binding RefreshCommand}" ToolTip="Actualizar" FontSize="18" Padding="10,8" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenido principal: DataGrid dentro de card -->
        <Border Grid.Row="1" Style="{StaticResource ThemeElevatedCardStyle}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filtros / acciones adicionales (se puede extender) -->
                <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <!-- Placeholder para futuros filtros por tipo/fecha -->
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="DgDocuments" Grid.Row="1" ItemsSource="{Binding Documents}" SelectedItem="{Binding SelectedDocument}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ColumnWidth="*" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          RowStyle="{StaticResource DocumentsDataGridRowStyle}" Style="{StaticResource DocumentsDataGridStyle}" CanUserResizeColumns="True"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          BorderBrush="{DynamicResource BorderDefaultBrush}"
                          BorderThickness="1"
                          RowHeaderWidth="0"
                          FocusVisualStyle="{x:Null}"
                          PreviewMouseDoubleClick="DgDocuments_PreviewMouseDoubleClick">

                    <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo" Binding="{Binding DocumentType}" Width="*" ElementStyle="{StaticResource CenteredTextBlockStyle}" />
                                                <DataGridTextColumn Header="Número" Binding="{Binding DisplayDocumentNumber}" Width="1.2*" ElementStyle="{StaticResource CenteredTextBlockStyle}" />
                                                <DataGridTextColumn Header="Emisión" Binding="{Binding DisplayIssuedDate}" Width="0.9*" ElementStyle="{StaticResource CenteredTextBlockStyle}" />
                                                <DataGridTextColumn Header="Vencimiento" Binding="{Binding DisplayExpirationDate}" Width="0.9*" ElementStyle="{StaticResource CenteredTextBlockStyle}" />

                        <DataGridTemplateColumn Header="Estado" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Border Style="{StaticResource BadgeStyle}" Background="{Binding StatusBackground}">
                                            <TextBlock Style="{StaticResource BadgeTextStyle}" Text="{Binding StatusText}" Foreground="{Binding StatusForeground}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Acciones" Width="1*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Ver -->
                                        <Button Style="{StaticResource ActionIconButtonStyle}"
                                                ToolTip="Ver documento"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=DataContext.PreviewCommand}"
                                                CommandParameter="{Binding}" Margin="0,0,8,0">
                                            <TextBlock Text="🔍" FontSize="14" Foreground="{DynamicResource PrimaryBrush}" />
                                        </Button>

                                        <!-- Eliminar -->
                                        <Button Style="{StaticResource ActionIconButtonStyle}"
                                                ToolTip="Eliminar documento"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=DataContext.DeleteDocumentCommand}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="🗑️" FontSize="14" Foreground="{DynamicResource DangerBrush}" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Mensaje cuando no hay documentos (mostrar sólo cuando NO se está cargando y Count == 0) -->
                <TextBlock Grid.Row="1" Text="No hay documentos registrados" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <!-- Por defecto oculto -->
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <!-- Mostrar sólo cuando IsLoading == false y Documents.Count == 0 -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False" />
                                        <Condition Binding="{Binding Documents.Count}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Indicador de carga: mostrar solo cuando IsLoading == true y LoadingProgress > 0 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Visibility>
                        <MultiBinding Converter="{StaticResource LoadingIndicatorVisibilityConverter}">
                            <Binding Path="IsLoading" />
                            <Binding Path="LoadingProgress" />
                        </MultiBinding>
                    </StackPanel.Visibility>

                    <TextBlock Text="Cargando documentos..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <!-- SimpleProgressBar existe en Controls/ -->
                    <controls:SimpleProgressBar Width="200" BarHeight="10" ProgressValue="{Binding LoadingProgress}" ShowHeader="False" ShowMessage="False" ShowPercentage="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
