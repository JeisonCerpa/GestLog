<Window x:Class="GestLog.Modules.GestionCartera.Views.SmtpConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Name="RootWindow"
        mc:Ignorable="d"
        Title="Configuración SMTP"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">

    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="820"
                MaxHeight="780"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="16,16,0,0"
                        Padding="22,18"
                        Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="48" Height="48" CornerRadius="24" Margin="0,0,14,0">
                                <TextBlock Text="⚙️" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="22"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Configuración del servidor SMTP"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                <TextBlock Text="Ajusta conexión, credenciales y copias para el envío automático"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.92"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Click="Cancel_Click"
                                ToolTip="Cerrar (Esc)">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">

                        <Border Style="{DynamicResource ThemeInfoNoticeStyle}" Padding="16" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="📋 Configuraciones rápidas" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="16" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Content="Gmail" Style="{DynamicResource ThemeSecondaryButtonStyle}" Click="GmailPreset_Click"/>
                                    <Button Grid.Column="2" Content="Zoho" Style="{DynamicResource ThemeSecondaryButtonStyle}" Click="ZohoPreset_Click"/>
                                    <Button Grid.Column="4" Content="Office 365" Style="{DynamicResource ThemeSecondaryButtonStyle}" Click="Office365Preset_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="🌐 Configuración del servidor" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="16" Margin="0,0,0,14"/>

                                <TextBlock Text="Servidor SMTP (HOST)" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="HostTextBox"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Margin="0,0,0,12"
                                         TextChanged="OnFieldChanged"
                                         ToolTip="Ejemplo: smtp.gmail.com, smtppro.zoho.com"/>

                                <TextBlock Text="Puerto" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="PortTextBox"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Margin="0,0,0,12"
                                         TextChanged="OnFieldChanged"
                                         ToolTip="Puerto común: 587 (STARTTLS), 465 (SSL), 25 (sin cifrado)"/>

                                <CheckBox x:Name="SslCheckBox"
                                          Content="Habilitar SSL/TLS (recomendado)"
                                          Foreground="{DynamicResource TextBodyBrush}"
                                          FontWeight="SemiBold"
                                          Checked="OnFieldChanged"
                                          Unchecked="OnFieldChanged"
                                          IsChecked="True"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="🔐 Credenciales de acceso" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="16" Margin="0,0,0,14"/>

                                <TextBlock Text="Correo electrónico" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox x:Name="EmailTextBox"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Margin="0,0,0,12"
                                         TextChanged="OnFieldChanged"
                                         ToolTip="Su dirección de correo electrónico"/>

                                <TextBlock Text="Contraseña" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <PasswordBox x:Name="PasswordBox"
                                             Padding="12,10"
                                             Margin="0,0,0,10"
                                             Background="{DynamicResource BackgroundElevatedBrush}"
                                             Foreground="{DynamicResource TextBodyBrush}"
                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                             BorderThickness="1"
                                             PasswordChanged="OnPasswordChanged"/>

                                <CheckBox x:Name="SaveCredentialsCheckBox"
                                          Content="💾 Guardar credenciales de forma segura"
                                          Foreground="{DynamicResource TextBodyBrush}"
                                          FontWeight="SemiBold"
                                          IsChecked="True"
                                          ToolTip="Las credenciales se almacenarán en Windows Credential Manager"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="📧 Configuración de copias" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="16" Margin="0,0,0,14"/>

                                <TextBlock Text="Copia oculta (BCC)" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox x:Name="BccEmailInputTextBox"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 Padding="12,10"
                                                 TextChanged="OnCopyFieldChanged"
                                                 KeyDown="BccEmailInputTextBox_KeyDown"
                                                 ToolTip="Escriba un correo y presione Enter o Agregar"/>
                                        <TextBlock x:Name="BccPlaceholderTextBlock"
                                                   Text="Ej: cartera@cliente.com; tesoreria@cliente.com"
                                                   Margin="14,0,10,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   IsHitTestVisible="False"/>
                                    </Grid>

                                    <Button Grid.Column="1"
                                            Content="+ Agregar"
                                            Style="{DynamicResource ThemeSecondaryButtonStyle}"
                                            Click="AddBccEmail_Click"
                                            Padding="12,8"/>
                                </Grid>

                                <Border Background="{DynamicResource SurfaceLayer2Brush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="90">
                                        <ItemsControl ItemsSource="{Binding BccEmails, ElementName=RootWindow}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,2,0,2">
                                                        <Button Content="✕"
                                                                DockPanel.Dock="Right"
                                                                Tag="{Binding}"
                                                                Width="24" Height="24"
                                                                Margin="8,0,0,0"
                                                                Style="{DynamicResource ThemeDangerButtonStyle}"
                                                                Padding="0"
                                                                Click="RemoveBccEmail_Click"/>
                                                        <TextBlock Text="{Binding}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextBodyBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <TextBlock x:Name="BccCountTextBlock" Text="0 correos BCC" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                                <TextBlock Text="Copia (CC)" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="0,0,8,0">
                                        <TextBox x:Name="CcEmailInputTextBox"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 Padding="12,10"
                                                 TextChanged="OnCopyFieldChanged"
                                                 KeyDown="CcEmailInputTextBox_KeyDown"
                                                 ToolTip="Escriba un correo y presione Enter o Agregar"/>
                                        <TextBlock x:Name="CcPlaceholderTextBlock"
                                                   Text="Ej: finanzas@empresa.com, compras@empresa.com"
                                                   Margin="14,0,10,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   IsHitTestVisible="False"/>
                                    </Grid>

                                    <Button Grid.Column="1"
                                            Content="+ Agregar"
                                            Style="{DynamicResource ThemeSecondaryButtonStyle}"
                                            Click="AddCcEmail_Click"
                                            Padding="12,8"/>
                                </Grid>

                                <Border Background="{DynamicResource SurfaceLayer2Brush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="90">
                                        <ItemsControl ItemsSource="{Binding CcEmails, ElementName=RootWindow}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin="0,2,0,2">
                                                        <Button Content="✕"
                                                                DockPanel.Dock="Right"
                                                                Tag="{Binding}"
                                                                Width="24" Height="24"
                                                                Margin="8,0,0,0"
                                                                Style="{DynamicResource ThemeDangerButtonStyle}"
                                                                Padding="0"
                                                                Click="RemoveCcEmail_Click"/>
                                                        <TextBlock Text="{Binding}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextBodyBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                                <TextBlock x:Name="CcCountTextBlock" Text="0 correos CC" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                <TextBlock Text="💡 Las copias se aplicarán automáticamente en todos los envíos. También puede pegar listas separadas por coma (,) o punto y coma (;)"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}" Padding="18">
                            <StackPanel>
                                <TextBlock Text="🧪 Validación" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="16" Margin="0,0,0,14"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{DynamicResource DangerBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="StatusTextBlock" Text="No configurado" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}"/>
                                </StackPanel>

                                <Button x:Name="TestButton"
                                        Content="🧪 Probar configuración"
                                        Style="{DynamicResource ThemeSecondaryButtonStyle}"
                                        Click="TestConfiguration_Click"
                                        HorizontalAlignment="Left"
                                        Padding="16,9"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundElevatedBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1,1,1,0"
                        Padding="18"
                        CornerRadius="0,0,16,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Style="{DynamicResource ThemeSecondaryButtonStyle}"
                                Margin="0,0,10,0"
                                Click="Cancel_Click"
                                Padding="18,9"/>
                        <Button x:Name="SaveButton"
                                Content="Guardar configuración"
                                Style="{DynamicResource ThemePrimaryButtonStyle}"
                                Click="Save_Click"
                                IsEnabled="False"
                                Padding="18,9"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

