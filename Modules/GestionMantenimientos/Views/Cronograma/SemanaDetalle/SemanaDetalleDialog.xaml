<Window x:Class="GestLog.Modules.GestionMantenimientos.Views.Cronograma.SemanaDetalle.SemanaDetalleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Detalle de la Semana"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <converters:EstadoSeguimientoToColorConverter x:Key="EstadoSeguimientoToColorConverter" />
        <converters:TipoMantenimientoToColorConverter x:Key="TipoMantenimientoToColorConverter" />

        <Style x:Key="SedeTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder"
                                Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SedeTabListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="KeyboardNavigation.TabNavigation" Value="Once" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border Style="{StaticResource ThemeElevatedCardStyle}"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                MinWidth="900"
                MaxWidth="1500"
                Margin="24"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="14,14,0,0"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,14,0">
                                <TextBlock Text="🗓️"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="22" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Titulo}"
                                           Style="{StaticResource ThemeCardTitleStyle}"
                                           FontSize="22"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Resumen de los mantenimientos programados para la semana seleccionada"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="13" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding RangoFechas, StringFormat=Rango: {0}}"
                                       Style="{StaticResource ThemeBodyTextStyle}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,2" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Body -->
                <Grid Grid.Row="1" Margin="18,18,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource ThemeInfoNoticeStyle}"
                            Padding="16"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Estados de mantenimiento"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Los registros se muestran con la paleta del tema y las acciones disponibles por fila."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Filtrar por sede"
                                           Style="{StaticResource LabelTextStyle}"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,0,6" />

                                <ListBox ItemsSource="{Binding SedeFiltros}"
                                         SelectedItem="{Binding SelectedSedeFiltro, Mode=TwoWay}"
                                         Style="{StaticResource SedeTabListStyle}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <StaticResource ResourceKey="SedeTabItemStyle" />
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Display}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="8,3"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Count}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource ThemeElevatedCardStyle}"
                            Background="{DynamicResource BackgroundSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            Padding="0"
                            Margin="0,0,0,14"
                            CornerRadius="14"
                            ClipToBounds="True">
                        <DataGrid x:Name="MantenimientosDataGrid"
                                  ItemsSource="{Binding EstadosMantenimientosView}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Style="{StaticResource ThemeDataGridStyle}"
                                  RowStyle="{StaticResource ThemeDataGridRowStyle}"
                                  CellStyle="{StaticResource ThemeDataGridCellStyle}"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MinWidth="820"
                                  RowHeight="40"
                                  ColumnWidth="*"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.VirtualizationMode="Standard"
                                  ScrollViewer.CanContentScroll="True"
                                  Background="Transparent"
                                  Margin="1"
                                  SnapsToDevicePixels="True"
                                  UseLayoutRounding="True">
                            <DataGrid.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                                <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Equipo"
                                                    Binding="{Binding NombreEquipo}"
                                                    MinWidth="180"
                                                    Width="2*"
                                                    IsReadOnly="True" />

                                <DataGridTextColumn Header="Código"
                                                    Binding="{Binding CodigoEquipo}"
                                                    MinWidth="110"
                                                    Width="*"
                                                    IsReadOnly="True" />

                                <DataGridTextColumn Header="Sede"
                                                    Binding="{Binding Sede, Converter={StaticResource EnumToDescriptionConverter}}"
                                                    MinWidth="120"
                                                    Width="*"
                                                    IsReadOnly="True" />

                                <DataGridTemplateColumn Header="Tipo"
                                                        MinWidth="150"
                                                        Width="*"
                                                        IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                                    BorderBrush="{Binding Seguimiento.TipoMtno, Converter={StaticResource TipoMantenimientoToColorConverter}}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Padding="5,1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    MinHeight="0">
                                                <TextBlock Text="{Binding Seguimiento.TipoMtno, Converter={StaticResource EnumToDescriptionConverter}, TargetNullValue=Sin tipo}"
                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                       FontSize="9"
                                                       LineHeight="10"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Seguimiento.TipoMtno, Converter={StaticResource TipoMantenimientoToColorConverter}}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Estado"
                                                        MinWidth="180"
                                                        Width="1.2*"
                                                        IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="10"
                                                         Height="10"
                                                         Fill="{Binding Estado, Converter={StaticResource EstadoSeguimientoToColorConverter}}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Estado, Converter={StaticResource EnumToDescriptionConverter}}"
                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Acciones"
                                                        MinWidth="240"
                                                        Width="Auto"
                                                        IsReadOnly="True">
                                    <DataGridTemplateColumn.CellStyle>
                                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemeDataGridCellStyle}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                            <Setter Property="Padding" Value="10,0,0,0" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundHoverBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTemplateColumn.CellStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center">
                                                <Button Content="Registrar"
                                                        Command="{Binding DataContext.RegistrarMantenimientoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ThemePrimaryButtonStyle}"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        MinHeight="30"
                                                        Margin="0,0,8,0"
                                                        Visibility="{Binding PuedeRegistrar, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Button Content="Ver seguimiento"
                                                        Click="VerDetalles_Click"
                                                        Tag="{Binding}"
                                                    Style="{StaticResource ThemeTableActionButtonStyle}"
                                                    Foreground="{DynamicResource PrimaryBrush}"
                                                        FontSize="11"
                                                        Padding="10,5"
                                                        MinHeight="30"
                                                        Visibility="{Binding PuedeVerDetalles, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="No hay estados de mantenimiento para esta semana."
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,8"
                                   Visibility="{Binding EstadosMantenimientos.Count, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=False}" />

                        <TextBlock Text="{Binding MensajeUsuario}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding MensajeUsuario, Converter={StaticResource StringToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="18,14">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cerrar"
                                Width="110"
                                IsCancel="True"
                                Click="OnCerrar_Click"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                FontSize="13"
                                FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
