<UserControl x:Class="GestLog.Modules.GestionMantenimientos.Views.Cronograma.CronogramaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Background="{DynamicResource BackgroundAppBrush}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThemeScrollBarStyle}" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                Margin="16,16,16,0"
                CornerRadius="14,14,0,0"
            Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                            Width="44"
                            Height="44"
                            Margin="0,0,12,0">
                        <TextBlock Text="📅"
                                   FontFamily="Segoe UI Emoji"
                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                   FontSize="22" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cronograma de Mantenimientos"
                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                   FontSize="20"
                                   Margin="0,0,0,2" />
                        <TextBlock Text="Vista general de mantenimientos programados"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   FontSize="12"
                                   Margin="0,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                        Margin="0,0,10,0">
                        <TextBlock Text="Año"
                                   Style="{StaticResource ThemeBodyTextStyle}"
                                   Foreground="{DynamicResource TextOnPrimaryBrush}"
                                   FontWeight="SemiBold"
                           FontSize="12"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                        <ComboBox Width="110"
                          Height="34"
                                  ItemsSource="{Binding AniosDisponibles}"
                                  SelectedItem="{Binding AnioSeleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ThemeComboBoxStyle}" />
                    </StackPanel>

                    <Button Content="↻ Actualizar"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                        FontSize="12"
                        Padding="10,6"
                        MinHeight="34"
                            Margin="0,0,10,0"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />

                    <Button Content="⇩ Exportar"
                            Command="{Binding ExportarCronogramasCommand}"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                        FontSize="12"
                        Padding="10,6"
                        MinHeight="34"
                            IsEnabled="{Binding CanExportCronograma}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource BackgroundAppBrush}"
                      Margin="16,16,16,0">
            <Grid Background="{DynamicResource BackgroundAppBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <ItemsControl ItemsSource="{Binding PlaceholderSemanas}"
                                  Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="12"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="2" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ThemeElevatedCardStyle}"
                                    Padding="4"
                                    Margin="0"
                                        MinHeight="126"
                                    Opacity="0.45" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Semanas}"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="12"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="2" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Border Margin="0"
                                        Padding="4"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        MinHeight="126">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ThemeElevatedCardStyle}">
                                                <Setter Property="Padding" Value="4" />
                                                <Setter Property="Margin" Value="1" />
                                                <Setter Property="BorderBrush" Value="{Binding ColorSemana}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                                <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSemanaActual}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="BorderThickness" Value="3" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EsSemanaVacia}" Value="True">
                                                        <Setter Property="Opacity" Value="0.78" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Rectangle x:Name="EmptyWeekIndicator"
                                                       Stroke="{DynamicResource BorderDefaultBrush}"
                                                       StrokeThickness="2"
                                                       RadiusX="8"
                                                       RadiusY="8"
                                                       Fill="Transparent"
                                                       StrokeDashArray="4 2"
                                                       Margin="4"
                                                       HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Stretch"
                                                       Panel.ZIndex="10"
                                                       IsHitTestVisible="False">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EsSemanaVacia}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSemanaActualYVacia}" Value="True">
                                                                <Setter Property="Stroke" Value="{DynamicResource PrimaryBrush}" />
                                                                <Setter Property="StrokeThickness" Value="3" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>

                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        ToolTipService.ShowDuration="15000">
                                                <StackPanel.ToolTip>
                                                    <ToolTip Background="{DynamicResource BackgroundElevatedBrush}"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                             BorderThickness="1"
                                                             Padding="0"
                                                             Placement="MousePoint"
                                                             HasDropShadow="True"
                                                             SnapsToDevicePixels="True">
                                                        <Border Padding="12"
                                                                Background="{DynamicResource BackgroundElevatedBrush}"
                                                                CornerRadius="10"
                                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TituloSemana}"
                                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Margin="0,0,0,3" />
                                                                <ItemsControl ItemsSource="{Binding Mantenimientos}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Style="{StaticResource ThemeBodyTextStyle}"
                                                                                       Foreground="{DynamicResource TextBodyBrush}"
                                                                                       FontSize="10">
                                                                                <Run Text="• " />
                                                                                <Run Text="{Binding Codigo}" />
                                                                                <Run Text=" - " />
                                                                                <Run Text="{Binding Nombre}" />
                                                                            </TextBlock>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="Sin mantenimientos programados"
                                                                           Foreground="{DynamicResource DangerBrush}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="11"
                                                                           Margin="0,6,0,0">
                                                                    <TextBlock.Visibility>
                                                                        <Binding Path="Mantenimientos.Count"
                                                                                 Converter="{StaticResource CountToVisibilityConverter}" />
                                                                    </TextBlock.Visibility>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </ToolTip>
                                                </StackPanel.ToolTip>

                                                <TextBlock Text="{Binding NumeroSemana, StringFormat=Semana {0}}"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="NoWrap"
                                                           Margin="0,0,0,0" />
                                                <TextBlock Text="{Binding RangoFechas}"
                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="NoWrap" />
                                                <TextBlock Text="{Binding Mantenimientos.Count, StringFormat={}{0} Mtto}"
                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                           FontWeight="SemiBold"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           TextWrapping="NoWrap"
                                                           Margin="0,0,0,0" />

                                                <Border HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Margin="0,2,0,0"
                                                        Padding="6,1"
                                                        CornerRadius="999"
                                                        Background="{DynamicResource PrimaryBrush}"
                                                        Visibility="{Binding IsSemanaActual, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="ACTUAL"
                                                            FontSize="8"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                                </Border>

                                                <Button Content="Ver detalles"
                                                        Command="{Binding VerSemanaCommand}"
                                                        CommandParameter="{Binding}"
                                                        Margin="0,3,0,0"
                                                        Visibility="{Binding TieneMantenimientos, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Style="{StaticResource ThemePrimaryButtonStyle}"
                                                        FontSize="9"
                                                        Padding="6,2"
                                                        MinHeight="24"
                                                        HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource ThemeInfoNoticeStyle}"
                            Padding="16,12"
                            Visibility="{Binding Semanas.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <TextBlock Text="No hay mantenimientos programados para mostrar."
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Border Width="14" Height="14" CornerRadius="2" Background="#B3E5FC" BorderBrush="#B3E5FC" BorderThickness="1" />
                            <TextBlock Text="Pendiente" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Border Width="14" Height="14" CornerRadius="2" Background="{DynamicResource SuccessBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" />
                            <TextBlock Text="Ejecutado" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Border Width="14" Height="14" CornerRadius="2" Background="{DynamicResource WarningBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" />
                            <TextBlock Text="Retrasado" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <Border Width="14" Height="14" CornerRadius="2" Background="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}" BorderThickness="1" />
                            <TextBlock Text="No Realizado" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="14" Height="14" CornerRadius="2" Background="Transparent" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1">
                                <Rectangle Stroke="{DynamicResource BorderDefaultBrush}"
                                           StrokeThickness="0.5"
                                           StrokeDashArray="1.5 1.5"
                                           RadiusX="1"
                                           RadiusY="1" />
                            </Border>
                            <TextBlock Text="Sin Mtto" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="3,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              Grid.RowSpan="3"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
              Background="{DynamicResource ModalOverlayBrush}"
              Panel.ZIndex="999"
              IsHitTestVisible="True"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Border Width="420"
                    Height="140"
                    CornerRadius="10"
                    Background="{DynamicResource BackgroundSurfaceBrush}"
                    Opacity="0.98"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource ThemeElevatedCardStyle}">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Height="18"
                                 Margin="0,0,18,0" />

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cargando..."
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Por favor espere"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
