<Window x:Class="GestLog.Modules.GestionMantenimientos.Views.Equipos.EquipoDetalleModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:enums="clr-namespace:GestLog.Modules.GestionMantenimientos.Models.Enums"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Detalle del equipo"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <converters:EstadoToColorConverter x:Key="EstadoToColorConverter" />
        <converters:EstadoSeguimientoToColorConverter x:Key="EstadoSeguimientoToColorConverter" />
        <converters:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter" />
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />

        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThemeScrollBarStyle}" />

        <Style x:Key="HistorialEstadoBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
            <Setter Property="Background" Value="{DynamicResource NeutralBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.RealizadoEnTiempo}">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.RealizadoFueraDeTiempo}">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.Atrasado}">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.NoRealizado}">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.Pendiente}">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="{x:Static enums:EstadoSeguimientoMantenimiento.Correctivo}">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <x:Array x:Key="registrosPorPaginaItems" Type="sys:Int32">
            <sys:Int32>5</sys:Int32>
            <sys:Int32>10</sys:Int32>
            <sys:Int32>15</sys:Int32>
            <sys:Int32>20</sys:Int32>
        </x:Array>
    </Window.Resources>

    <Grid Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border Width="1200"
                MaxWidth="1320"
                MaxHeight="980"
                Margin="24"
                Background="{DynamicResource BackgroundAppBrush}"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="26,22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="56"
                                    Height="56"
                                    CornerRadius="28"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,16,0">
                                <TextBlock Text="🧰"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="24"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalle del equipo"
                                           Style="{StaticResource HeaderTextStyle}"/>
                                <TextBlock Text="Consulta integral del activo, su historial y acciones rápidas"
                                           Style="{StaticResource SubHeaderTextStyle}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="📥 Exportar hoja de vida"
                                    Command="{Binding ExportarHojaVidaEquipoCommand}"
                                    Style="{StaticResource ThemeHeaderActionButtonStyle}"
                                    Margin="0,0,10,0"
                                    MinHeight="40"/>

                            <Button Content="✕"
                                    x:Name="CloseButton"
                                    Click="CloseButton_Click"
                                    Style="{StaticResource CloseButton}"
                                    ToolTip="Cerrar (Esc)"
                                    Width="38"
                                    Height="38"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardSectionStyle}">
                                <StackPanel>
                                    <TextBlock Text="Información general" Style="{StaticResource SectionHeaderStyle}"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Código" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEquipo.Codigo}" Style="{StaticResource ThemeBodyTextStyle}" FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Nombre" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEquipo.Nombre}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap" FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Marca" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEquipo.Marca}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Clasificación" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEquipo.Clasificacion}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Comprado a" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedEquipo.CompradoA}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Sede" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedEquipo.Sede}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Frec. Mtto" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedEquipo.FrecuenciaMtto}" Style="{StaticResource ThemeBodyTextStyle}" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Precio" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedEquipo.Precio, Converter={StaticResource DecimalToCopCurrencyConverter}}" Style="{StaticResource ThemeBodyTextStyle}" FontWeight="SemiBold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource CardSectionStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Estado actual" Style="{StaticResource SectionHeaderStyle}"/>

                                        <Border Padding="14"
                                                CornerRadius="14"
                                                Background="{Binding SelectedEquipo.Estado, Converter={StaticResource EstadoToColorConverter}}"
                                                HorizontalAlignment="Stretch">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedEquipo.Estado}"
                                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="16"/>
                                                <TextBlock Text="Estado del activo"
                                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                           Opacity="0.9"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,16,0,0"
                                                Padding="14"
                                                CornerRadius="14"
                                                Background="{DynamicResource BackgroundSurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Fechas" Style="{StaticResource ThemeSectionSubtitleStyle}" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                                <TextBlock Style="{StaticResource ThemeBodyTextStyle}" Margin="0,0,0,6">
                                                    <Run Text="Compra: "/>
                                                    <Run Text="{Binding SelectedEquipo.FechaCompra, StringFormat=dd/MM/yyyy}"/>
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource ThemeBodyTextStyle}">
                                                    <Run Text="Baja: "/>
                                                    <Run Text="{Binding SelectedEquipo.FechaBaja, StringFormat=dd/MM/yyyy}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource CardSectionStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Observaciones" Style="{StaticResource SectionHeaderStyle}"/>
                                <TextBlock Text="{Binding SelectedEquipo.Observaciones}"
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardSectionStyle}" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Historial de mantenimientos"
                                               Style="{StaticResource SectionHeaderStyle}"/>

                                    <Button Grid.Column="1"
                                            Content="📥 Exportar a Excel"
                                            Command="{Binding ExportarHojaVidaEquipoCommand}"
                                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                                            MinHeight="40"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding HistorialMantenimientosVisibles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="16"
                                                CornerRadius="14"
                                                Background="{DynamicResource BackgroundSurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <TextBlock Text="{Binding TipoMtno}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Margin="0,0,10,0"/>
                                                        <Border Style="{StaticResource HistorialEstadoBadgeStyle}">
                                                            <TextBlock Text="{Binding Estado, Converter={StaticResource EnumToDescriptionConverter}}"
                                                                       Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Text="{Binding Descripcion}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,10"/>

                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="👤"
                                                                       Margin="0,0,6,0"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            <TextBlock Text="{Binding Responsable}" Style="{StaticResource ThemeBodyTextStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Costo, Converter={StaticResource DecimalToCopCurrencyConverter}}"
                                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel>
                                                            <TextBlock Text="Programado" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,2"/>
                                                            <TextBlock Text="{Binding SemanaTexto}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                            <TextBlock Text="Realizado" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,2"/>
                                                            <TextBlock Text="{Binding FechaRegistro, StringFormat=dd/MM/yyyy}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="{Binding Observaciones}"
                                                               Margin="0,10,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Visibility>
                                                            <Binding Path="Observaciones" Converter="{StaticResource NullToVisibilityConverter}"/>
                                                        </TextBlock.Visibility>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="No hay mantenimientos realizados aún."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontStyle="Italic"
                                       Margin="0,12,0,0">
                                    <TextBlock.Visibility>
                                        <Binding Path="HistorialMantenimientosVisibles.Count" Converter="{StaticResource CountToVisibilityConverter}"/>
                                    </TextBlock.Visibility>
                                </TextBlock>

                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                    CornerRadius="14"
                                    Padding="14"
                                    Margin="0,16,0,0"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Content="◄ Anterior"
                                            Command="{Binding HistorialPaginaAnteriorCommand}"
                                            MinHeight="36"
                                            Padding="12,6">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ThemeSecondaryButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HistorialPaginaActual}" Value="1">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="12,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Página {0} de {1}">
                                                <Binding Path="HistorialPaginaActual"/>
                                                <Binding Path="HistorialTotalPaginas"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="Mostrar" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ComboBox ItemsSource="{StaticResource registrosPorPaginaItems}"
                                                  SelectedItem="{Binding HistorialRegistrosPorPagina}"
                                                  Width="72"
                                                  Height="34"
                                                  Style="{StaticResource ThemeComboBoxStyle}"/>
                                    </StackPanel>

                                    <Button Grid.Column="4"
                                            Content="Siguiente ►"
                                            Command="{Binding HistorialPaginaSiguienteCommand}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            MinHeight="36"
                                            Padding="12,6"
                                            IsEnabled="{Binding HistorialPuedeIrSiguiente}"/>
                                </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundAppBrush}"
                        CornerRadius="0,0,18,18"
                        Padding="22"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="EditActionButton"
                                Content="✎ Editar"
                                Click="EditButton_Click"
                                MinWidth="120"
                                MinHeight="40"
                                Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ThemePrimaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedEquipo.Estado}" Value="DadoDeBaja">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="RegistrarMantenimientoActionButton"
                                Content="🔧 Registrar mantenimiento"
                                Command="{Binding RegistrarMantenimientoCommand}"
                                CommandParameter="{Binding SelectedEquipo}"
                                MinWidth="180"
                                MinHeight="40"
                                Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ThemeSecondaryButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedEquipo.Estado}" Value="DadoDeBaja">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedEquipo.Estado}" Value="Inactivo">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="DeleteActionButton"
                                Content="🗑 Dar de baja"
                                Click="DeleteButton_Click"
                                MinWidth="140"
                                MinHeight="40">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ThemeDangerButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedEquipo.Estado}" Value="DadoDeBaja">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>