<Window x:Class="GestLog.Modules.GestionMantenimientos.Views.Equipos.ObservacionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Observación al dar de baja"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">
    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="720"
                MaxWidth="760"
                Padding="0"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="14"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        CornerRadius="14,14,0,0"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Observación obligatoria"
                                       Style="{DynamicResource ThemeSectionTitleStyle}"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                            <TextBlock Text="Ingrese el motivo para dar de baja el equipo"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                IsCancel="True"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="22">
                    <TextBlock Text="La observación se registrará como parte del proceso de baja."
                               Style="{DynamicResource ThemeBodyTextStyle}"
                               Margin="0,0,0,10"/>
                    <TextBox x:Name="ObservacionTextBox"
                             AcceptsReturn="True"
                             Height="220"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             Tag="Escriba aquí la observación..."/>
                </StackPanel>

                <Border Grid.Row="2"
                        Padding="22"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                IsCancel="True"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="Confirmar baja"
                                IsDefault="True"
                                Click="OnConfirmar_Click"
                                Style="{StaticResource ThemeDangerButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
