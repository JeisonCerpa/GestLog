<UserControl x:Class="GestLog.Modules.GestionMantenimientos.Views.Seguimiento.SeguimientoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.openxmlformats.org/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:GestLog.Controls"
             xmlns:converters="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        <converters:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter"/>
        <converters:SeguimientoEstadoToColorConverter x:Key="SeguimientoEstadoToColorConverter"/>
        <converters:SeguimientoEstadoToTextConverter x:Key="SeguimientoEstadoToTextConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,12"
                Padding="24,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="52"
                            Height="52"
                            CornerRadius="26"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,14,0">
                        <TextBlock Text="🧭"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="24"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Seguimientos"
                                   Style="{StaticResource ThemeSectionTitleStyle}"/>
                        <TextBlock Text="Historial, estados y mantenimiento de activos"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,16,0">
                    <TextBlock Text="Año"
                           Style="{StaticResource ThemeBodyTextStyle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                        <ComboBox Width="110"
                          Height="36"
                                  ItemsSource="{Binding AniosDisponibles}"
                                  SelectedItem="{Binding AnioSeleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Style="{StaticResource ThemeComboBoxStyle}"/>
                    </StackPanel>

                    <Button Content="⭱ Exportar"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Command="{Binding ExportarCommand}"
                            IsEnabled="{Binding CanExportSeguimiento}"
                            Opacity="{Binding CanExportSeguimiento, Converter={StaticResource BooleanToOpacityConverter}}"
                            Margin="0,0,8,0"
                            MinHeight="40"/>

                    <Button Content="↻ Refrescar"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Command="{Binding LoadSeguimientosCommand}"
                            Margin="0,0,8,0"
                            MinHeight="40"/>

                    <Button Content="⭲ Importar"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Command="{Binding ImportarSeguimientosAntiguosCommand}"
                            IsEnabled="{Binding CanImportSeguimiento}"
                            Opacity="{Binding CanImportSeguimiento, Converter={StaticResource BooleanToOpacityConverter}}"
                            Margin="0,0,8,0"
                            MinHeight="40"
                            Visibility="{Binding CanImportSeguimiento, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Button Content="📥 Plantilla"
                            Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                            Command="{Binding DescargarPlantillaCommand}"
                            IsEnabled="{Binding CanImportSeguimiento}"
                            Opacity="{Binding CanImportSeguimiento, Converter={StaticResource BooleanToOpacityConverter}}"
                            MinHeight="40"
                            MinWidth="150"
                            Visibility="{Binding CanImportSeguimiento, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,12"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Buscar"
                               Style="{StaticResource ThemeBodyTextStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <TextBox Width="520"
                             Tag="Buscar por código, nombre, tipo, responsable, estado o descripción"
                             Text="{Binding FiltroSeguimiento, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             VerticalAlignment="Center"/>

                    <DatePicker Width="140"
                                Margin="12,0,0,0"
                                SelectedDate="{Binding FechaDesde, UpdateSourceTrigger=LostFocus}"
                                Style="{StaticResource ThemeDatePickerStyle}"
                                ToolTip="Desde (fecha registro)"/>

                    <DatePicker Width="140"
                                Margin="12,0,0,0"
                                SelectedDate="{Binding FechaHasta, UpdateSourceTrigger=LostFocus}"
                                Style="{StaticResource ThemeDatePickerStyle}"
                                ToolTip="Hasta (fecha registro)"/>

                    <Button Content="Filtrar"
                            Command="{Binding FiltrarCommand}"
                            Style="{StaticResource ThemePrimaryButtonStyle}"
                            MinWidth="100"
                            Margin="12,0,0,0"
                            MinHeight="40"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Limpiar filtros"
                        Command="{Binding LimpiarFiltrosCommand}"
                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                        MinWidth="130"
                        MinHeight="40"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,10"
                Padding="22">
            <DataGrid ItemsSource="{Binding SeguimientosView}"
                      SelectedItem="{Binding SelectedSeguimiento, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource BorderDefaultBrush}"
                      Background="{DynamicResource BackgroundElevatedBrush}"
                      RowBackground="{DynamicResource BackgroundElevatedBrush}"
                      AlternatingRowBackground="{DynamicResource BackgroundElevatedBrush}"
                      FontSize="13"
                      RowHeight="40"
                      ColumnWidth="SizeToCells"
                      MinColumnWidth="80"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.VirtualizationMode="Standard"
                      ScrollViewer.CanContentScroll="True"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      BorderThickness="0"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">

                <DataGrid.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}"/>
                    <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}"/>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,10"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                        <Setter Property="Padding" Value="8,0"/>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}"
                                        Width="SizeToCells"
                                        MinWidth="110"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}"
                                        Width="*"
                                        MinWidth="180"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Fecha realizada"
                                        Binding="{Binding FechaRealizacion, StringFormat=dd/MM/yyyy}"
                                        Width="SizeToCells"
                                        MinWidth="130"
                                        IsReadOnly="True"/>

                    <DataGridTextColumn Header="Responsable"
                                        Binding="{Binding Responsable}"
                                        Width="140"
                                        MinWidth="130"
                                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Estado"
                                            Width="140"
                                            MinWidth="130"
                                            IsReadOnly="True"
                                            SortMemberPath="EstadoOrden">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding Estado, TargetNullValue='Estado desconocido', FallbackValue='Estado desconocido'}">
                                    <Ellipse Width="12"
                                             Height="12"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ., Converter={StaticResource SeguimientoEstadoToColorConverter}, TargetNullValue=#D1D5DB, FallbackValue=#D1D5DB}"
                                             Stroke="{DynamicResource BorderDefaultBrush}"
                                             StrokeThickness="0.5"/>
                                    <TextBlock Text="{Binding ., Converter={StaticResource SeguimientoEstadoToTextConverter}, TargetNullValue=Desconocido, FallbackValue=Desconocido}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextBodyBrush}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header=""
                                            Width="SizeToCells"
                                            MinWidth="92"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Detalles"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        Click="VerDetalles_Click"
                                        Tag="{Binding}"
                                        MinWidth="88"
                                        Height="34"
                                        Padding="12,6"
                                        HorizontalAlignment="Center"
                                        Focusable="False"
                                        ToolTip="Ver detalles del seguimiento"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>