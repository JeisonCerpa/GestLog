<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GestLog.Modules.GestionMantenimientos.Views.Seguimiento.SeguimientoDetalleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Detalle del Seguimiento"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
            <converters:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="OverlayGrid"
          Background="{DynamicResource ModalOverlayBrush}"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border x:Name="ModalPanel"
                Width="1020"
                MinWidth="880"
                MaxWidth="1180"
                MaxHeight="860"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="36"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="5" Opacity="0.25" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="16,16,0,0"
                        Padding="24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="50"
                                    Height="50"
                                    CornerRadius="25"
                                    Margin="0,0,14,0">
                                <TextBlock Text="🧾"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="22" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalle del seguimiento"
                                           Style="{StaticResource ThemeCardTitleStyle}"
                                           FontSize="22"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Consulta el contexto del mantenimiento y administra el registro sin perder la jerarquía visual del tema."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,8">
                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,5"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Seguimiento.Codigo, StringFormat=Código: {0}}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>

                                <Border Background="{DynamicResource PrimaryLightBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,5"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding EstadoDisplayName}"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>

                            <Button Content="✕"
                                    Style="{StaticResource CloseButton}"
                                    Click="Cerrar_Click"
                                    HorizontalAlignment="Right"
                                    ToolTip="Cerrar (Esc)" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BackgroundElevatedBrush}">
                    <Grid Margin="22,18,22,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource ThemeInfoNoticeStyle}"
                                Padding="16,14"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Resumen del seguimiento"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,2" />
                                    <TextBlock Text="La información se presenta por bloques para facilitar lectura, edición y validación del estado del mantenimiento."
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="11" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center">
                                    <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,5"
                                            Margin="0,0,8,8">
                                        <TextBlock Text="{Binding SedeDisplayName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,5"
                                            Margin="0,0,8,8">
                                        <TextBlock Text="{Binding TipoMantenimientoDisplayName}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,5"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Seguimiento.SemanaTexto}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.12*" />
                                <ColumnDefinition Width="0.88*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="18"
                                    Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Información del equipo"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,12" />

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Código" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding Seguimiento.Codigo}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Nombre" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding Seguimiento.Nombre}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Sede" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding SedeDisplayName}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Tipo de mantenimiento" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding TipoMantenimientoDisplayName}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="18"
                                    Margin="10,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Información del seguimiento"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,12" />

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Estado" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding EstadoDisplayName}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" FontWeight="SemiBold" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Responsable" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding Seguimiento.Responsable}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Fecha de registro" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding Seguimiento.FechaRegistro, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Fecha de realización" Style="{StaticResource LabelTextStyle}" />
                                            <TextBlock Text="{Binding Seguimiento.FechaRealizacion, StringFormat='{}{0:dd/MM/yyyy}'}" Style="{StaticResource ThemeBodyTextStyle}" FontSize="13" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="18"
                                    Margin="0,0,10,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Descripción y costo"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,12" />

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource BackgroundElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding EnModoEdicion, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Seguimiento.Descripcion}"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   MinHeight="84" />
                                    </Border>

                                    <StackPanel Grid.Row="1"
                                                Visibility="{Binding EnModoEdicion, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Descripción" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox Text="{Binding DescripcionEditable}"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 Height="96"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalContentAlignment="Top"
                                                 Margin="0,0,0,12" />
                                    </StackPanel>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Costo" Style="{StaticResource LabelTextStyle}" />
                                            <Border Background="{DynamicResource PrimaryLightBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12,8"
                                                    Visibility="{Binding EnModoEdicion, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding Seguimiento.Costo, Converter={StaticResource DecimalToCopCurrencyConverter}}"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                            </Border>

                                            <TextBox Text="{Binding CostoEditable}"
                                                     Style="{StaticResource ThemeTextBoxStyle}"
                                                     Height="40"
                                                     HorizontalContentAlignment="Right"
                                                     Visibility="{Binding EnModoEdicion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Estado visual" Style="{StaticResource LabelTextStyle}" />
                                            <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12,8">
                                                <TextBlock Text="{Binding EstadoDisplayName}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="18"
                                    Margin="10,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Observaciones y edición"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,12" />

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource BackgroundElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding EnModoEdicion, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Seguimiento.Observaciones}"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   MinHeight="76" />
                                    </Border>

                                    <StackPanel Grid.Row="1"
                                                Visibility="{Binding EnModoEdicion, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Observaciones" Style="{StaticResource LabelTextStyle}" />
                                        <TextBox Text="{Binding ObservacionesEditable}"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 Height="84"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalContentAlignment="Top"
                                                 Margin="0,0,0,12" />
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource BackgroundElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Edición" Style="{StaticResource LabelTextStyle}" />
                                                <TextBlock Text="Los cambios se guardan en el mismo registro y actualizan la vista semanal."
                                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                           FontSize="11" />
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource PrimaryLightBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10,6"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Seguimiento.SemanaTexto}"
                                                           Foreground="{DynamicResource PrimaryBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="18,14"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Background="{DynamicResource BackgroundSurfaceBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding MensajeDeshabilitacion}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding MensajeDeshabilitacion, Converter={StaticResource StringToVisibilityConverter}}"
                                   IsHitTestVisible="False" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal" Visibility="{Binding EnModoEdicion, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <Button Content="Editar"
                                        Width="Auto"
                                        MinWidth="92"
                                        Height="36"
                                        Margin="0,0,8,0"
                                        Click="Editar_Click"
                                        Style="{StaticResource ThemePrimaryButtonStyle}"
                                        IsEnabled="{Binding PuedeEditarOEliminar}"
                                        ToolTip="Editar este seguimiento" />

                                <Button Content="Eliminar"
                                        Width="Auto"
                                        MinWidth="92"
                                        Height="36"
                                        Margin="0,0,8,0"
                                        Click="Eliminar_Click"
                                        Style="{StaticResource ThemeDangerButtonStyle}"
                                        IsEnabled="{Binding PuedeEditarOEliminar}"
                                        ToolTip="Eliminar este seguimiento" />

                                <Button Content="Cerrar"
                                        Width="Auto"
                                        MinWidth="92"
                                        Height="36"
                                        Click="Cerrar_Click"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding EnModoEdicion, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Button Content="Guardar"
                                        Width="Auto"
                                        MinWidth="100"
                                        Height="36"
                                        Margin="0,0,8,0"
                                        Click="Guardar_Click"
                                        Style="{StaticResource ThemePrimaryButtonStyle}" />

                                <Button Content="Cancelar"
                                        Width="Auto"
                                        MinWidth="100"
                                        Height="36"
                                        Click="Cancelar_Click"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
