<Window x:Class="GestLog.Modules.GestionMantenimientos.Views.Seguimiento.SeguimientoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:GestLog.Models.Enums"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Registrar Mantenimiento" WindowStartupLocation="Manual"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="False" UseLayoutRounding="True" SnapsToDevicePixels="True"
        Loaded="SeguimientoDialog_OnLoaded" KeyDown="SeguimientoDialog_KeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:TipoMantenimientoFilterConverter x:Key="TipoMantenimientoFilterConverter" />
            <converters:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter" />
            <!-- UppercaseConverter no usado directamente: conservar archivo en Converters si es reutilizable -->
        </ResourceDictionary>
    </Window.Resources>    <!-- Grid overlay con fondo semi-transparente -->
    <Grid x:Name="RootGrid" MouseLeftButtonDown="Overlay_MouseLeftButtonDown" Background="{DynamicResource ModalOverlayBrush}">        <!-- Border con la ventana modal centrada -->
        <Border Width="980" MaxWidth="1120" MinWidth="860" MaxHeight="780" Background="{DynamicResource BackgroundSurfaceBrush}" CornerRadius="14" Padding="0" 
                HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40" BorderThickness="1"
                BorderBrush="{DynamicResource BorderDefaultBrush}" Effect="{StaticResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header premium -->
                <Border Grid.Row="0"
                    Style="{StaticResource ThemeHeaderContainerStyle}"
                    CornerRadius="14,14,0,0"
                        Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="44"
                                    Height="44"
                                    CornerRadius="22"
                                    Margin="0,0,10,0">
                                <TextBlock Text="🔧"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Registrar mantenimiento"
                                           Style="{StaticResource ThemeCardTitleStyle}"
                                           FontSize="19"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Completa los datos del seguimiento y guarda el registro con la paleta visual del tema."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                    <Button Style="{StaticResource CloseButton}"
                                    Click="Cancelar_Click"
                                    ToolTip="Cerrar (Esc)"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,0,6" />

                                     <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                     CornerRadius="8"
                                     Padding="10,5"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="Modo registro"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                         FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Contenido principal -->
                <Grid Grid.Row="1" Margin="18,10,18,10" Background="{DynamicResource BackgroundElevatedBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource ThemeInfoNoticeStyle}"
                            Padding="14,12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Resumen del registro"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="14"
                                               Margin="0,0,0,1" />
                                    <TextBlock Text="Revisa el contexto antes de guardar el mantenimiento. Los campos editables están organizados para una lectura rápida."
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="10" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,5"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Codigo, StringFormat=Código: {0}}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*" />
                                <ColumnDefinition Width="0.85*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Datos base"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="14"
                                               Margin="0,0,0,8" />

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Código" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding Codigo}" Style="{StaticResource InputStyle}" IsReadOnly="True" IsEnabled="False" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Nombre" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding Nombre}" Style="{StaticResource InputStyle}" IsReadOnly="True" IsEnabled="False" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Fecha realización" Style="{StaticResource LabelTextStyle}" />
                                            <DatePicker SelectedDate="{Binding FechaRealizacion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                Style="{StaticResource ModernDatePickerStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Tipo mantenimiento" Style="{StaticResource LabelTextStyle}" />
                                            <ComboBox x:Name="TipoMantenimientoComboBox"
                                                      SelectedItem="{Binding TipoMtno, UpdateSourceTrigger=PropertyChanged}"
                                                                                                            Style="{StaticResource ModernComboBoxStyle}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Row="3" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="0.8*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Responsable" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding Responsable, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource InputStyle}"
                                                     CharacterCasing="Upper" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Costo (COP)" Style="{StaticResource LabelTextStyle}" />
                                            <TextBox Text="{Binding Costo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToCopCurrencyConverter}}"
                                                     Style="{StaticResource InputStyle}"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="16"
                                    Margin="16,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Checklist"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="14"
                                               Margin="0,0,0,6" />

                                    <TextBlock Grid.Row="1"
                                               Text="Selecciona los puntos verificados durante el mantenimiento."
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="10"
                                               Margin="0,0,0,10" />

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource PrimaryLightBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            Margin="0,0,0,10">
                                        <TextBlock Text="Marca rápidamente los procedimientos realizados."
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <WrapPanel Grid.Row="3" HorizontalAlignment="Left">
                                        <CheckBox x:Name="cbRevision"
                                                  Content="Revisión general"
                                                  Style="{StaticResource ThemeCheckBoxStyle}"
                                                  Margin="0,0,10,10"
                                                  Checked="ChecklistItem_Checked"
                                                  Unchecked="ChecklistItem_Checked" />
                                        <CheckBox x:Name="cbLimpieza"
                                                  Content="Limpieza"
                                                  Style="{StaticResource ThemeCheckBoxStyle}"
                                                  Margin="0,0,10,10"
                                                  Checked="ChecklistItem_Checked"
                                                  Unchecked="ChecklistItem_Checked" />
                                        <CheckBox x:Name="cbAjustes"
                                                  Content="Ajustes"
                                                  Style="{StaticResource ThemeCheckBoxStyle}"
                                                  Margin="0,0,10,10"
                                                  Checked="ChecklistItem_Checked"
                                                  Unchecked="ChecklistItem_Checked" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="14"
                                    Margin="0,0,8,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Descripción"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="14"
                                               Margin="0,0,0,8" />
                                    <TextBox Grid.Row="1"
                                             x:Name="DescripcionTextBox"
                                             Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             MinHeight="80"
                                             VerticalAlignment="Stretch"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MaxLength="1000" />
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    Padding="14"
                                    Margin="8,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Observaciones y frecuencia"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="14"
                                               Margin="0,0,0,8" />

                                    <TextBox Grid.Row="1"
                                             Text="{Binding Observaciones, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"
                                             MinHeight="58"
                                             VerticalAlignment="Top"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MaxLength="1000" />

                                    <StackPanel Grid.Row="2" Margin="0,6,0,0"
                                                Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ModoRestringido, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="Frecuencia"
                                                   Style="{StaticResource LabelTextStyle}" />
                                        <ComboBox x:Name="FrecuenciaComboBox"
                                                  SelectedItem="{Binding Frecuencia, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource InputStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                </Grid>

                <!-- Footer con botones -->
                <Border Grid.Row="2"
                        Padding="16,12"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Background="{DynamicResource BackgroundSurfaceBrush}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Style="{StaticResource GhostButton}"
                                Click="Cancelar_Click"
                                MinWidth="110"
                                Margin="0,0,10,0" />
                        <Button Content="Guardar cambios"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="Aceptar_Click"
                                IsDefault="True"
                                MinWidth="150" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>



