<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Personas.PersonaManagementView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestLog.Converters"
        mc:Ignorable="d"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <local:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter" TrueText="Activo" FalseText="Inactivo"/>
        <local:BooleanToColorConverter x:Key="BooleanToColorConverter" TrueColor="#C8E6C9" FalseColor="#FFCDD2"/>
        <local:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />

        <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OverflowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeTableActionButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="OverflowMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeSecondaryButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
        </Style>

        <Style x:Key="ActionIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </UserControl.Resources>
    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="24,20,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{DynamicResource ThemeCardIconCircleStyle}" Width="72" Height="72" CornerRadius="36" Margin="0" VerticalAlignment="Center">
                    <TextBlock Text="🧑" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="30"/>
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de Personas" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="24"/>
                    <TextBlock Text="Busca, filtra y administra personas con sus datos de acceso" Style="{DynamicResource ThemeSectionSubtitleStyle}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="24,0,24,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="280" Height="40" VerticalAlignment="Center"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Buscar por nombre, documento o correo"/>
                    <ComboBox Width="200" Height="40" Margin="12,0,0,0" VerticalAlignment="Center"
                              Style="{StaticResource ThemeComboBoxStyle}"
                              ItemsSource="{Binding Sedes}"
                              SelectedItem="{Binding SelectedSedeOption, Mode=TwoWay}"
                              SelectedValue="{Binding FiltroSede, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              ToolTip="Filtrar por sede">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <Button Grid.Column="1" Width="44" Height="44" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding RegistrarPersonaCommand}"
                        ToolTip="Registrar nueva persona"
                        Style="{StaticResource ThemePrimaryButtonStyle}">
                    <TextBlock Text="+" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource ThemeElevatedCardStyle}" Margin="24,0,24,24" Padding="12">
            <DataGrid ItemsSource="{Binding Personas}" AutoGenerateColumns="False" IsReadOnly="True"
                      RowHeight="40" HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single" Background="{DynamicResource BackgroundSurfaceBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0">
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding NombreCompleto}" Width="2*"/>
                    <DataGridTextColumn Header="Tipo Documento" Binding="{Binding TipoDocumento.Nombre}" Width="1.5*"/>
                    <DataGridTextColumn Header="Documento" Binding="{Binding NumeroDocumento}" Width="1.5*"/>
                    <DataGridTextColumn Header="Correo" Binding="{Binding Correo}" Width="2*"/>
                    <DataGridTextColumn Header="Cargo" Binding="{Binding Cargo.Nombre}" Width="1.5*"/>
                    <DataGridTextColumn Header="Sede" Width="1*" Binding="{Binding Sede, Converter={StaticResource EnumToDescriptionConverter}}" />
                    <DataGridTemplateColumn Header="Estado" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Activo}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,8,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource NeutralBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Activo}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Activo}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Text="{Binding Activo, Converter={StaticResource BooleanToStatusTextConverter}, ConverterParameter='Activo;Inactivo'}"
                                                   Style="{DynamicResource ThemeBodyTextStyle}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Usuario" Width="1*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border ToolTip="{Binding TieneUsuario, Converter={StaticResource BooleanToStatusTextConverter}, ConverterParameter='Tiene usuario;No tiene usuario'}">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TieneUsuario}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TieneUsuario}" Value="False">
                                                    <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border Width="8" Height="8" CornerRadius="2" Margin="0,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource NeutralBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TieneUsuario}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding TieneUsuario}" Value="False">
                                                            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Text="👤"
                                                   Margin="6,0,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Acciones" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Button x:Name="OverflowButton"
                                            Style="{StaticResource OverflowActionButtonStyle}"
                                            ToolTip="Más acciones"
                                            Click="OverflowActions_Click"
                                            Tag="{Binding ElementName=OverflowPopup}">
                                        <TextBlock Text="⋯" FontSize="18" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Popup x:Name="OverflowPopup"
                                           PlacementTarget="{Binding ElementName=OverflowButton}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="8"
                                                MinWidth="180"
                                                Effect="{DynamicResource ThemeCardShadow}">
                                            <StackPanel>
                                                <Button Content="Editar"
                                                        Style="{StaticResource OverflowMenuButtonStyle}"
                                                        Tag="{Binding ElementName=OverflowPopup}"
                                                        Click="OverflowEditar_Click"/>
                                                <Button Content="Crear usuario"
                                                        Tag="{Binding ElementName=OverflowPopup}"
                                                        Click="OverflowCrearUsuario_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource OverflowMenuButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TieneUsuario}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Content="Desactivar"
                                                        Tag="{Binding ElementName=OverflowPopup}"
                                                        Click="OverflowDesactivar_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource OverflowMenuButtonStyle}">
                                                            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Activo}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

