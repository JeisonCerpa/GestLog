<Window x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Personas.PersonaRegistroWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:validation="clr-namespace:GestLog.Controls.Validation"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Persona"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
    </Window.Resources>
    <Grid Background="#A0000000">
        <Border Style="{DynamicResource ThemeWelcomeCardStyle}"
                Padding="0"
                Margin="24"
                Width="820"
                MaxWidth="920"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.28" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24,22,18,18"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding FormTitle}"
                                       Style="{DynamicResource ThemeSectionTitleStyle}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding FormSubtitle}"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       TextWrapping="Wrap"
                                       MaxWidth="600"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="620">
                    <StackPanel Margin="24,20,24,24">
                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Datos personales"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                                        <TextBlock Text="Nombres" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingTextBox Text="{Binding Persona.Nombres, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                      Height="40"
                                                                      Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                        <TextBlock Text="Apellidos" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingTextBox Text="{Binding Persona.Apellidos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                      Height="40"
                                                                      Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Tipo de documento" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingComboBox ItemsSource="{Binding TiposDocumento}"
                                                                       SelectedItem="{Binding Persona.TipoDocumento, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                       DisplayMemberPath="Nombre"
                                                                       Height="40"
                                                                       Style="{StaticResource ThemeComboBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="Número de documento" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingTextBox Text="{Binding Persona.NumeroDocumento, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                      Height="40"
                                                                      Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Contacto y ubicación"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,14"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                                        <TextBlock Text="Correo electrónico" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingTextBox Text="{Binding Persona.Correo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                      Height="40"
                                                                      Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                        <TextBlock Text="Teléfono" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <validation:ValidatingTextBox Text="{Binding Persona.Telefono, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                                      Height="40"
                                                                      Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Cargo" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ComboBox Height="40"
                                                  IsEditable="True"
                                                  ItemsSource="{Binding Cargos}"
                                                  SelectedItem="{Binding Persona.Cargo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Nombre"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  ToolTip="Buscar y seleccionar cargo"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1"
                                                Visibility="{Binding MostrarEstado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="Estado" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12,10">
                                            <CheckBox Content="Activo"
                                                      IsChecked="{Binding Persona.Activo, Mode=TwoWay}"
                                                      Foreground="{DynamicResource TextBodyBrush}"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="24"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Command="{Binding CancelarCommand}"
                                Width="122"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                        <Button Content="{Binding GuardarText}"
                                Command="{Binding GuardarCommand}"
                                Width="160"
                                Height="40"
                                Style="{StaticResource ThemePrimaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>