<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.IdentidadCatalogosHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,30">
            <StackPanel>

                <StackPanel Margin="0,0,0,22">
                    <TextBlock Text="Gestión de Identidad y Catálogos"
                               Style="{DynamicResource ThemeSectionTitleStyle}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Left"/>
                    <TextBlock Text="Personas, usuarios, cargos, tipos de documento, roles y permisos"
                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <UniformGrid Columns="3" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Border Style="{DynamicResource ThemeInteractiveCardStyle}" Margin="12">
                        <StackPanel>
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                <TextBlock Text="🧑" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                            </Border>
                            <TextBlock Text="Personas" Style="{DynamicResource ThemeCardTitleStyle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Registrar, editar y consultar personas." Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Gestionar Personas" Command="{Binding AbrirPersonasCommand}" Style="{DynamicResource ThemePrimaryButtonStyle}" Width="200" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ThemeInteractiveCardStyle}" Margin="12">
                        <StackPanel>
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                <TextBlock Text="👤" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                            </Border>
                            <TextBlock Text="Usuarios" Style="{DynamicResource ThemeCardTitleStyle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Gestión de cuentas de usuario y autenticación." Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Gestionar Usuarios" Command="{Binding AbrirUsuariosCommand}" Style="{DynamicResource ThemePrimaryButtonStyle}" Width="200" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ThemeInteractiveCardStyle}" Margin="12">
                        <StackPanel>
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                <TextBlock Text="🗂️" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                            </Border>
                            <TextBlock Text="Cargos" Style="{DynamicResource ThemeCardTitleStyle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Gestiona los cargos disponibles en la empresa." Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Gestionar Cargos" Command="{Binding AbrirCargosCommand}" Style="{DynamicResource ThemePrimaryButtonStyle}" Width="200" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ThemeInteractiveCardStyle}" Margin="12">
                        <StackPanel>
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                <TextBlock Text="📄" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                            </Border>
                            <TextBlock Text="Tipos de Documento" Style="{DynamicResource ThemeCardTitleStyle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Gestiona los tipos de documento registrados." Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Gestionar Tipos de Documento" Command="{Binding AbrirTiposDocumentoCommand}" Style="{DynamicResource ThemePrimaryButtonStyle}" Width="200" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ThemeInteractiveCardStyle}" Margin="12">
                        <StackPanel>
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                <TextBlock Text="🛡️" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                            </Border>
                            <TextBlock Text="Roles" Style="{DynamicResource ThemeCardTitleStyle}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Gestiona los roles y sus permisos." Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="Gestionar Roles" Command="{Binding AbrirRolesCommand}" Style="{DynamicResource ThemePrimaryButtonStyle}" Width="200" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

