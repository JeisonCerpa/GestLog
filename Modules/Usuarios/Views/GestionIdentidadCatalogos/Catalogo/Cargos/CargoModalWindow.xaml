<Window x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.CargoModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GestLog.Converters"
        Title="Cargo"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">
    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Style="{DynamicResource ThemeWelcomeCardStyle}"
                Padding="0"
                Margin="24"
                Width="680"
                MaxWidth="820"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.30" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24,22,18,18"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CG"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CargoEnEdicion.Nombre, TargetNullValue='Cargo'}"
                                       Style="{DynamicResource ThemeSectionTitleStyle}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Define un nombre claro y una descripción útil para mantener el catálogo ordenado"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       TextWrapping="Wrap"
                                       MaxWidth="560"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,20,24,24">
                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Información del cargo"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,14"/>

                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Nombre" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding CargoEnEdicion.Nombre, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ThemeTextBoxStyle}"
                                             Tag="Ej. Analista de sistemas"/>
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Text="Descripción" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding CargoEnEdicion.Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                             Height="110"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             Style="{StaticResource ThemeTextBoxStyle}"
                                             Tag="Describe brevemente la función del cargo"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding MensajeErrorCargo}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold"
                                   Margin="2,0,2,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="24"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Command="{Binding CerrarModalCargoCommand}"
                                Width="122"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                        <Button Content="Guardar"
                                Command="{Binding GuardarCargoCommand}"
                                Width="150"
                                Height="40"
                                Style="{StaticResource ThemePrimaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

