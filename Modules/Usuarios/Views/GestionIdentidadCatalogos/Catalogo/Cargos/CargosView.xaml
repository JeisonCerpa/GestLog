<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Catalogo.Cargos.CargosView"
    x:Name="CargosRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:GestLog.Converters"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="CargoActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeTableActionButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="24,20,24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="68"
                        Height="68"
                        CornerRadius="34"
                        Background="{DynamicResource BackgroundElevatedBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="CG"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de cargos"
                               Style="{DynamicResource ThemeSectionTitleStyle}"
                               FontSize="24"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Crea y edita cargos con una experiencia clara, moderna y consistente con el tema"
                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Command="{Binding AbrirModalNuevoCargoCommand}"
                        ToolTip="Agregar nuevo cargo"
                        Style="{StaticResource ThemePrimaryButtonStyle}"
                        Foreground="{DynamicResource TextOnPrimaryBrush}"
                        Width="46"
                        Height="46"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock Text="+"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource ThemeElevatedCardStyle}" Margin="24,0,24,24" Padding="12">
            <Grid>
                <DataGrid ItemsSource="{Binding Cargos}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="40"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="{DynamicResource BackgroundSurfaceBrush}"
                          BorderBrush="{DynamicResource BorderDefaultBrush}"
                          BorderThickness="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="3*"/>
                        <DataGridTemplateColumn Header="Acciones" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource CargoActionButtonStyle}"
                                                Margin="0,0,6,0"
                                                Command="{Binding DataContext.AbrirModalEditarCargoCommand, ElementName=CargosRoot}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                ToolTip="Editar cargo">
                                            <TextBlock Text="✏" FontSize="15" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource CargoActionButtonStyle}"
                                                Command="{Binding DataContext.EliminarCargoCommand, ElementName=CargosRoot}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource DangerBrush}"
                                                ToolTip="Eliminar cargo">
                                            <TextBlock Text="🗑" FontSize="15" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

