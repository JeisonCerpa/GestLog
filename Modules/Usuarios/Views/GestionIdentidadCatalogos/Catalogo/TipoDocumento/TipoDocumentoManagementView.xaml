<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Catalogo.TipoDocumento.TipoDocumentoManagementView"
             x:Name="TipoDocumentoRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="TypeDocActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeTableActionButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource TableHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="24,20,24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="68"
                        Height="68"
                        CornerRadius="34"
                        Background="{DynamicResource BackgroundElevatedBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="TD"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de tipos de documento"
                               Style="{DynamicResource ThemeSectionTitleStyle}"
                               FontSize="24"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Crea, edita y elimina tipos de documento con una experiencia limpia y consistente"
                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="3"
                        Command="{Binding AbrirModalNuevoTipoDocumentoCommand}"
                        ToolTip="Agregar nuevo tipo de documento"
                        Style="{StaticResource ThemePrimaryButtonStyle}"
                        Foreground="{DynamicResource TextOnPrimaryBrush}"
                        Width="46"
                        Height="46"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                    <TextBlock Text="+"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="24,0,24,14" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="320"
                             Height="40"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             Text="{Binding FiltroTipoDocumentoTexto, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Buscar por nombre, código o descripción"/>
                    <Button Width="118"
                            Height="40"
                            Margin="12,0,0,0"
                            Content="Limpiar"
                            Command="{Binding LimpiarFiltrosTipoDocumentoCommand}"
                            Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="{DynamicResource BackgroundElevatedBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Registros: " Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TiposDocumento.Count}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{DynamicResource ThemeElevatedCardStyle}" Margin="24,0,24,24" Padding="12">
            <Grid>
                <DataGrid ItemsSource="{Binding TiposDocumentoView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="40"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          Background="{DynamicResource BackgroundSurfaceBrush}"
                          BorderBrush="{DynamicResource BorderDefaultBrush}"
                          BorderThickness="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TableRowHoverBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="2*"/>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="1.2*"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="3*"/>
                        <DataGridTemplateColumn Header="Acciones" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource TypeDocActionButtonStyle}"
                                                Margin="0,0,6,0"
                                                Command="{Binding DataContext.AbrirModalEditarTipoDocumentoCommand, ElementName=TipoDocumentoRoot}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                ToolTip="Editar tipo de documento">
                                            <TextBlock Text="✏" FontSize="15" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource TypeDocActionButtonStyle}"
                                                Command="{Binding DataContext.EliminarTipoDocumentoCommand, ElementName=TipoDocumentoRoot}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource DangerBrush}"
                                                ToolTip="Eliminar tipo de documento">
                                            <TextBlock Text="🗑" FontSize="15" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                        Opacity="0.96"
                        Visibility="{Binding IsLoadingTiposDocumento, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Cargando tipos de documento..."
                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                   FontSize="16"
                                   Margin="0,0,0,8"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Preparando catálogo y validando registros"
                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="Transparent"
                        Visibility="{Binding NoTiposDocumentoMessageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="36" Background="{DynamicResource BackgroundElevatedBrush}" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <TextBlock Text="TD" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No hay tipos de documento para mostrar"
                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Prueba con otro filtro o crea un nuevo tipo de documento"
                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="360"
                                   Margin="0,0,0,14"/>
                        <Button Content="Limpiar filtros"
                                Command="{Binding LimpiarFiltrosTipoDocumentoCommand}"
                                Width="150"
                                Height="38"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
