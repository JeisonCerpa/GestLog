<Window x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.TipoDocumentoModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GestLog.Converters"
        Title="Tipo de documento"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}">
    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Style="{DynamicResource ThemeWelcomeCardStyle}"
                Padding="0"
                Margin="24"
                Width="640"
                MaxWidth="760"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.30" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="24,22,18,18"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="TD"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding TipoDocumentoEnEdicion.Nombre, TargetNullValue='Tipo de documento'}"
                                       Style="{DynamicResource ThemeSectionTitleStyle}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="Define un nombre, código y descripción claros para el catálogo"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       TextWrapping="Wrap"
                                       MaxWidth="520"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,20,24,24">
                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Identificación"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,14"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="Nombre" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding TipoDocumentoEnEdicion.Nombre, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="40"
                                                 Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Código" Style="{DynamicResource ThemeBodyTextStyle}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding TipoDocumentoEnEdicion.Codigo, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="40"
                                                 Style="{StaticResource ThemeTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Descripción"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,14"/>

                                <TextBox Text="{Binding TipoDocumentoEnEdicion.Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                         Height="110"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource ThemeTextBoxStyle}"/>

                                <TextBlock Text="Evita nombres o códigos duplicados para mantener consistencia en reportes y formularios"
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding MensajeErrorTipoDocumento}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold"
                                   Margin="2,14,2,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="24"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Command="{Binding CerrarModalTipoDocumentoCommand}"
                                Width="122"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"/>
                        <Button Content="Guardar"
                                Command="{Binding GuardarTipoDocumentoCommand}"
                                Width="150"
                                Height="40"
                                Style="{StaticResource ThemePrimaryButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>