<Window x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Catalogo.Roles.RolFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Titulo}"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown">

        <Border Width="680"
                MaxHeight="720"
                Background="{DynamicResource BackgroundAppBrush}"
                CornerRadius="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="20,20,0,0"
                        Padding="24,18">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="12"
                                Background="{DynamicResource PrimaryLightBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                Margin="0,0,14,0">
                            <TextBlock Text="🛡"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="20"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Titulo}"
                                       FontFamily="Segoe UI"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                            <TextBlock Text="{Binding Subtitulo}"
                                       FontFamily="Segoe UI"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}"
                                       Opacity="0.85"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Formulario -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18,24,0">
                    <StackPanel>
                        <!-- Información del rol -->
                        <Border Style="{StaticResource ThemeCompactSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Información del Rol"
                                           FontFamily="Segoe UI"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,12"/>

                                <TextBlock Text="Nombre *"
                                           Style="{StaticResource ThemeDetailLabelStyle}"/>
                                <TextBox Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Tag="Nombre del rol"
                                         Margin="0,0,0,12"/>

                                <TextBlock Text="Descripción"
                                           Style="{StaticResource ThemeDetailLabelStyle}"/>
                                <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Tag="Descripción del rol"
                                         Height="70"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Border>

                        <!-- Permisos -->
                        <Border Style="{StaticResource ThemeCompactSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Permisos del Rol"
                                           FontFamily="Segoe UI"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,12"/>

                                <TextBox Text="{Binding FiltroPermisos, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         Tag="Filtrar permisos por nombre, descripción o módulo..."
                                         Margin="0,0,0,12"/>

                                <ItemsControl ItemsSource="{Binding PermisosPorModulo}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Modulo}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Margin="0,0,0,6"/>
                                                <ItemsControl ItemsSource="{Binding Permisos}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Nombre}"
                                                                      IsChecked="{Binding EstaSeleccionado}"
                                                                      Style="{StaticResource ThemeCheckBoxStyle}"
                                                                      ToolTip="{Binding Descripcion}"
                                                                      Margin="8,0,0,6"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,20,20"
                        Padding="24,14">
                    <Grid>
                        <TextBlock Text="{Binding MensajeValidacion}"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="360"
                                   HorizontalAlignment="Left"
                                   Visibility="{Binding MensajeValidacion, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar"
                                    Click="BtnCancelar_Click"
                                    IsCancel="True"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    MinWidth="110"
                                    MinHeight="38"
                                    Margin="0,0,10,0"/>
                            <Button Content="{Binding TextoGuardar}"
                                    Click="BtnGuardar_Click"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    MinWidth="140"
                                    MinHeight="38"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
