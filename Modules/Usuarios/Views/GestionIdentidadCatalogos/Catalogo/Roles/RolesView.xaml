<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Catalogo.Roles.RolesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="{DynamicResource BackgroundAppBrush}">

    <Grid Background="{DynamicResource BackgroundAppBrush}"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,8"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="22"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,12,0">
                        <TextBlock Text="🛡"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="20"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Roles"
                                   Style="{StaticResource ThemeSectionTitleStyle}"/>
                        <TextBlock Text="Administra los roles del sistema y sus permisos"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="↻ Refrescar"
                            Command="{Binding BuscarRolesCommand}"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Margin="0,0,8,0"
                            MinHeight="38"
                            ToolTip="Actualizar lista de roles"/>
                    <Button Content="＋ Nuevo Rol"
                            Click="BtnNuevoRol_Click"
                            Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                            IsEnabled="{Binding CanCreateRole}"
                            MinHeight="38"
                            MinWidth="140"
                            ToolTip="Crear un nuevo rol"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenido maestro-detalle -->
        <Grid Grid.Row="1" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de roles -->
            <Border Grid.Column="0"
                    Style="{StaticResource ThemeElevatedCardStyle}"
                    Padding="14"
                    Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Text="{Binding FiltroRoles, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             Tag="Buscar rol..."
                             Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding RolesFiltrados}"
                             SelectedItem="{Binding RolSeleccionado, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12,10">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource BackgroundHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Nombre}"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Descripcion}"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Panel de detalle -->
            <Border Grid.Column="1"
                    Style="{StaticResource ThemeElevatedCardStyle}"
                    Padding="24,20">
                <Grid>
                    <!-- Estado vacío -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding RolSeleccionado, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}">
                        <Border Style="{StaticResource ThemeCardIconCircleStyle}">
                            <TextBlock Text="🛡" Style="{StaticResource ThemeCardIconTextStyle}" FontFamily="Segoe UI Emoji"/>
                        </Border>
                        <TextBlock Text="Selecciona un rol para ver su detalle"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Detalle del rol seleccionado -->
                    <Grid Visibility="{Binding RolSeleccionado, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Encabezado del detalle -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding RolSeleccionado.Nombre}"
                                           Style="{StaticResource ThemeCardTitleStyle}"/>
                                <TextBlock Text="{Binding RolSeleccionado.Descripcion}"
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                <Button Content="✏ Editar"
                                        Click="BtnEditarRol_Click"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        IsEnabled="{Binding CanEditRole}"
                                        Margin="0,0,8,0"
                                        MinHeight="36"/>
                                <Button Content="🗑 Eliminar"
                                        Command="{Binding EliminarRolCommand}"
                                        CommandParameter="{Binding RolSeleccionado}"
                                        Style="{StaticResource ThemeDangerButtonStyle}"
                                        MinHeight="36"/>
                            </StackPanel>
                        </Grid>

                        <!-- Separador -->
                        <Border Grid.Row="1" Height="1"
                                Background="{DynamicResource BorderDefaultBrush}"
                                Margin="0,16,0,16"/>

                        <!-- Título de permisos -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="Permisos"
                                       FontFamily="Segoe UI"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Style="{StaticResource ThemePillBadgeStyle}"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}"
                                    Padding="10,3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding TotalPermisosSeleccionado}"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryBrush}"/>
                            </Border>
                        </StackPanel>

                        <!-- Chips de permisos por módulo -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding PermisosPorModuloVer}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,10,0,4">
                                            <TextBlock Text="{Binding Modulo}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <ItemsControl ItemsSource="{Binding Permisos}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource ThemeDetailChipStyle}"
                                                                Margin="0,6,6,0"
                                                                ToolTip="{Binding Descripcion}">
                                                            <TextBlock Text="{Binding Nombre}"
                                                                       FontFamily="Segoe UI"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource TextBodyBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Mensaje de estado -->
        <TextBlock Grid.Row="2"
                   Text="{Binding MensajeEstado}"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="12,6,12,10"
                   Visibility="{Binding MensajeEstado, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
