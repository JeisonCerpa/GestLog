<UserControl x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Usuario.UsuarioManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

        <Style x:Key="UserCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DangerOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeSecondaryButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{DynamicResource ThemeWelcomeCardStyle}"
                Margin="24,20,24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Gestión de usuarios"
                               Style="{DynamicResource ThemeSectionTitleStyle}"
                               FontSize="24"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Consulta usuarios, revisa su estado y administra accesos desde una sola vista."
                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding StatusMessage, TargetNullValue='Listo para gestionar usuarios'}"
                               Style="{DynamicResource ThemeBodyTextStyle}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="{DynamicResource BackgroundElevatedBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,8"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Usuarios: " Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding Usuarios.Count}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Button Content="Nuevo usuario"
                            Command="{Binding AbrirRegistroUsuarioWindowCommand}"
                            Margin="0,0,12,0"
                            Height="44"
                            MinWidth="140"
                            Style="{StaticResource ThemePrimaryButtonStyle}" />

                    <Button Content="Refrescar"
                            Command="{Binding BuscarUsuariosCommand}"
                            Height="44"
                            MinWidth="120"
                            Style="{StaticResource ThemeSecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <!-- Panel izquierdo -->
            <Border Grid.Column="0"
                    Style="{DynamicResource ThemeElevatedCardStyle}"
                    Padding="16"
                    Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BackgroundSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Height="40"
                                     Style="{StaticResource ThemeTextBoxStyle}"
                                     Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="Buscar por usuario, persona o correo" />

                            <Button Grid.Column="1"
                                    Content="Limpiar"
                                    Command="{Binding LimpiarFiltroTextoCommand}"
                                    Margin="12,0,0,0"
                                    Height="40"
                                    MinWidth="110"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <ListBox ItemsSource="{Binding Usuarios}"
                                 SelectedItem="{Binding UsuarioSeleccionado, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource UserCardStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource BackgroundElevatedBrush}" />
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.12" Color="Black" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Background="{Binding Activo, Converter={StaticResource BooleanToColorConverter}}"
                                                    CornerRadius="2" />

                                            <StackPanel Grid.Column="1" Margin="14,0,12,0">
                                                <TextBlock Text="{Binding NombreUsuario}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding NombrePersona, TargetNullValue='Sin persona asociada'}"
                                                           Margin="0,4,0,0"
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                                <TextBlock Text="{Binding Correo, TargetNullValue='Sin correo registrado'}"
                                                           Margin="0,2,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Top"
                                                        Orientation="Horizontal"
                                                        Margin="8,2,0,0">
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Fill="{Binding Activo, Converter={StaticResource BooleanToColorConverter}}"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="Activo"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Visibility="{Binding Activo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <TextBlock Text="Inactivo"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Visibility="{Binding Activo, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24"
                                Visibility="{Binding NoUsuariosMessageVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border Width="72"
                                        Height="72"
                                        CornerRadius="36"
                                        Background="{DynamicResource BackgroundElevatedBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,14">
                                    <TextBlock Text="U"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="No hay usuarios para mostrar"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="Prueba con otro texto de búsqueda o limpia el filtro actual."
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           TextWrapping="Wrap"
                                           MaxWidth="320"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Margin="0,0,0,14" />
                                <Button Content="Limpiar búsqueda"
                                        Command="{Binding LimpiarFiltroTextoCommand}"
                                        Width="160"
                                        Height="40"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                Opacity="0.94"
                                CornerRadius="12"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Cargando usuarios..."
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Preparando datos y sincronizando información asociada"
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           MaxWidth="280" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Panel derecho -->
            <Border Grid.Column="1"
                    Style="{DynamicResource ThemeElevatedCardStyle}"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BackgroundSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Detalle del usuario"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding UsuarioSeleccionado.DisplayText, TargetNullValue='Selecciona un usuario para ver su información'}"
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Orientation="Horizontal"
                                        Margin="8,2,0,0"
                                        Visibility="{Binding TieneUsuarioSeleccionado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource BooleanToColorConverter}}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Activo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Visibility="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="Inactivo"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Visibility="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,14,0,14"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid Visibility="{Binding TieneUsuarioSeleccionado, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Información básica"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,14" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,16">
                                                <TextBlock Text="Nombre de usuario" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.NombreUsuario, TargetNullValue='-'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                                <TextBlock Text="Persona asignada" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.NombrePersona, TargetNullValue='Sin persona asignada'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="Correo electrónico" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.Correo, TargetNullValue='Sin correo registrado'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1">
                                                <TextBlock Text="Teléfono" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.TelefonoPersona, TargetNullValue='Sin teléfono registrado'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1"
                                        Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Acceso y actividad"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,14" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="Estado" Style="{StaticResource FieldLabelStyle}" />
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="10"
                                                             Height="10"
                                                             Fill="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource BooleanToColorConverter}}"
                                                             Margin="0,0,8,0"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="Activo"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Visibility="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <TextBlock Text="Inactivo"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Visibility="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Fecha de creación" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.FechaCreacion, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,18,16,0">
                                                <TextBlock Text="Último acceso" Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding UsuarioSeleccionado.FechaUltimoAcceso, StringFormat='{}{0:yyyy-MM-dd HH:mm}', TargetNullValue='Sin registros'}" Style="{StaticResource FieldValueStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Roles asignados"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,14" />

                                        <TextBlock Text="Sin roles asignados"
                                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                                   FontSize="13"
                                                   Visibility="{Binding RolesDeUsuario.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                                        <ItemsControl ItemsSource="{Binding RolesDeUsuario}"
                                                      Visibility="{Binding RolesDeUsuario.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=invert}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="999"
                                                            Padding="10,6"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding Nombre}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="12" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="24"
                                    Visibility="{Binding TieneUsuarioSeleccionado, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="76"
                                            Height="76"
                                            CornerRadius="38"
                                            Background="{DynamicResource BackgroundElevatedBrush}"
                                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,16">
                                        <TextBlock Text="U"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Selecciona un usuario"
                                               Style="{DynamicResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="El detalle completo aparecerá aquí para revisar su estado, roles y datos de contacto."
                                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                               TextWrapping="Wrap"
                                               MaxWidth="320"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="Transparent"
                            Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Acciones disponibles para el usuario seleccionado"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="320" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Editar"
                                        Command="{Binding EditarUsuarioCommand}"
                                        Width="112"
                                        Height="40"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource ThemePrimaryButtonStyle}"
                                        IsEnabled="{Binding TieneUsuarioSeleccionado}" />
                                <Button Content="Restablecer contraseña"
                                        Command="{Binding RestablecerContrasenaCommand}"
                                        Width="174"
                                        Height="40"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        IsEnabled="{Binding TieneUsuarioSeleccionado}" />
                                <Button Content="Eliminar"
                                        Command="{Binding EliminarUsuarioCommand}"
                                        Width="122"
                                        Height="40"
                                        Style="{StaticResource DangerOutlineButtonStyle}"
                                        IsEnabled="{Binding TieneUsuarioSeleccionado}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                            Opacity="0.94"
                            CornerRadius="12"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Grid.RowSpan="3">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Cargando información de usuarios..."
                                       Style="{DynamicResource ThemeSectionTitleStyle}"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Preparando listas, relaciones y accesos"
                                       Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       MaxWidth="280" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
