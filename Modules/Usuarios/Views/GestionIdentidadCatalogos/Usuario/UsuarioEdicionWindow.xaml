<Window x:Class="GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Usuario.UsuarioEdicionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GestLog.Modules.Usuarios.Views.GestionIdentidadCatalogos.Usuario"
        Title="Editar Usuario"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Style="{StaticResource ModalWindowBase}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Style="{DynamicResource ThemeWelcomeCardStyle}"
                Width="1080"
                MaxWidth="1160"
                Margin="24"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.30" Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="24,24,0,0"
                        Padding="24,22,20,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="46"
                                    Height="46"
                                    CornerRadius="23"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,14,0">
                                <TextBlock Text="🧩"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="20"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </Border>

                            <StackPanel>
                                <TextBlock Text="Editar usuario"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" />
                                <TextBlock Text="Actualice los datos básicos y los roles del usuario desde un modal unificado."
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.92"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Click="CancelarButton_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24">
                        <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="18"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="56"
                                        Height="56"
                                        CornerRadius="28"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        Margin="0,0,16,0">
                                    <TextBlock Text="👤"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="24"
                                               Foreground="{DynamicResource PrimaryBrush}" />
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Cuenta y persona asociada"
                                               Style="{DynamicResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,6" />
                                    <TextBlock Text="{Binding UsuarioSeleccionado.NombrePersona, TargetNullValue='Persona no disponible'}"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding UsuarioSeleccionado.Correo, TargetNullValue='Correo no disponible'}"
                                               Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.0*" />
                                <ColumnDefinition Width="1.0*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Datos básicos"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="Actualice únicamente el nombre de inicio de sesión y el estado de la cuenta."
                                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />

                                        <TextBlock Text="Nombre de usuario"
                                                   Style="{DynamicResource ThemeBodyTextStyle}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6" />
                                        <TextBox Text="{Binding UsuarioSeleccionado.NombreUsuario, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 Height="42"
                                                 Margin="0,0,0,16"
                                                 ToolTip="Nombre de usuario" />

                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Width="14"
                                                         Height="14"
                                                         Margin="0,4,12,0"
                                                         Fill="{Binding UsuarioSeleccionado.Activo, Converter={StaticResource BooleanToColorConverter}}" />

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Estado de la cuenta"
                                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,8" />
                                                    <CheckBox IsChecked="{Binding UsuarioSeleccionado.Activo, Mode=TwoWay}"
                                                              Content="Activo"
                                                              Foreground="{DynamicResource TextPrimaryBrush}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Resumen de edición"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,10" />
                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="• El nombre de usuario debe ser único"
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           Margin="0,0,0,6"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="• El cambio de estado puede deshabilitar el acceso"
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           Margin="0,0,0,6"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="• Los roles se sincronizan al guardar los cambios"
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Roles del usuario"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="Seleccione los roles que permanecerán asignados a esta cuenta."
                                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />

                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="12"
                                                MaxHeight="340">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding RolesDisponibles}" Name="RolesItemsControl">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,10,10"
                                                                    Padding="10,8"
                                                                    CornerRadius="12"
                                                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                                    BorderThickness="1">
                                                                <CheckBox Content="{Binding Nombre}"
                                                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                                                          FontWeight="SemiBold"
                                                                          Checked="CheckBox_Checked_Edit"
                                                                          Unchecked="CheckBox_Unchecked_Edit">
                                                                    <CheckBox.IsChecked>
                                                                        <MultiBinding Converter="{StaticResource RoleCheckedConverter}" Mode="OneWay">
                                                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                            <Binding Path="." />
                                                                        </MultiBinding>
                                                                    </CheckBox.IsChecked>
                                                                </CheckBox>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>

                                        <TextBlock Text="Debe seleccionar al menos un rol."
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   FontSize="12"
                                                   Margin="2,10,0,0"
                                                   Visibility="{Binding RolesSeleccionadosCount, Converter={StaticResource CountToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Acción final"
                                                   Style="{DynamicResource ThemeSectionTitleStyle}"
                                                   FontSize="16"
                                                   Margin="0,0,0,10" />
                                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="La edición actualizará nombre, estado y roles en una sola operación."
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,6" />
                                                <TextBlock Text="Verifique la información antes de guardar para evitar cambios innecesarios."
                                                           Style="{DynamicResource ThemeBodyTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="24"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Los cambios se aplicarán al usuario seleccionado al confirmar."
                                   Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,18,0" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar"
                                    Margin="0,0,12,0"
                                    Width="122"
                                    Height="40"
                                    Click="CancelarButton_Click"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}" />
                            <Button Content="Guardar cambios"
                                    Width="160"
                                    Height="40"
                                    Click="GuardarButton_Click"
                                    Style="{StaticResource ThemePrimaryButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

