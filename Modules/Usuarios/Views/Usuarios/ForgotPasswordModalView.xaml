<Window x:Class="GestLog.Modules.Usuarios.Views.Usuarios.ForgotPasswordModalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:GestLog.Converters"
        mc:Ignorable="d"
        Title="Recuperar Contraseña"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Width="500"
        Height="500">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <!-- Animación de rotación continua para spinner -->
        <Storyboard x:Key="SpinnerRotation" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="LoadingSpinner"
                Storyboard.TargetProperty="Angle"
                From="0" To="360"
                Duration="0:0:1"
                AccelerationRatio="0.1"
                DecelerationRatio="0.1" />
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource BackgroundAppBrush}" MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border Background="{DynamicResource BackgroundAppBrush}" Opacity="0.92" />

        <Border x:Name="Card"
                Width="500"
                MaxHeight="540"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{DynamicResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="24,24,0,0"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="40"
                                    Height="40"
                                    Margin="0,0,12,0"
                                    CornerRadius="10"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="🔑" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Recuperar Contraseña"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Reciba una contraseña temporal por correo"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.85"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="BtnCerrar"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar (Esc)"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical" Margin="24">
                        <TextBlock Text="ℹ️ Recuperación Segura"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="0,0,0,8" />

                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,20">
                            <TextBlock Text="Ingrese su nombre de usuario o correo electrónico asociado a su cuenta. Enviaremos una contraseña temporal a su correo para que pueda acceder nuevamente."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBodyBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <TextBlock Text="Nombre de Usuario o Correo"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBodyBrush}"
                                   Margin="0,0,0,6" />

                        <TextBox x:Name="UsernameOrEmailBox"
                                 Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemeTextBoxStyle}"
                                 Tag="Ingrese su usuario o correo"
                                 Margin="0,0,0,20"
                                 IsEnabled="{Binding IsNotLoading}" />

                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                BorderBrush="{DynamicResource DangerBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12"
                                Visibility="{Binding ShowError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❌ " FontSize="12" Foreground="{DynamicResource DangerBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding ErrorMessage}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextBodyBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                BorderBrush="{DynamicResource SuccessBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,12"
                                Visibility="{Binding ShowSuccess, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Vertical">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="✅" FontSize="20" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />
                                    <TextBlock Text="¡Correo enviado exitosamente!"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextBodyBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{Binding SuccessMessage}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextBodyBrush}"
                                           TextWrapping="Wrap"
                                           Margin="32,0,0,0"
                                           LineHeight="20" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <Grid Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1" CenterX="25" CenterY="25" />
                                        <RotateTransform x:Name="LoadingSpinner" Angle="0" CenterX="25" CenterY="25" />
                                    </TransformGroup>
                                </Grid.RenderTransform>

                                <Ellipse Stroke="{DynamicResource BorderDefaultBrush}" StrokeThickness="4" Fill="Transparent"
                                         Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Ellipse Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="4" Fill="Transparent"
                                         StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                         StrokeDashArray="15,40" Margin="0"
                                         Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>

                            <TextBlock Text="Enviando correo..."
                                       FontSize="12"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="20,12"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderDefaultBrush}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                Click="BtnCerrar_Click"
                                IsEnabled="{Binding IsNotLoading}"
                                Margin="0,0,10,0" />

                        <Button Content="Enviar Correo"
                                Style="{StaticResource ThemePrimaryButtonStyle}"
                                Command="{Binding SendResetEmailCommand}"
                                IsEnabled="{Binding IsNotLoading}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
