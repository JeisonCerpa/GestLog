<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.CompletarMantenimientoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:GestLog.Converters"
        mc:Ignorable="d"
        Title="Completar Mantenimiento"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        d:DesignHeight="680"
        d:DesignWidth="1020">

    <Window.Resources>
        <ResourceDictionary>
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="980"
                MaxHeight="840"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                Effect="{DynamicResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,14,0">
                                <TextBlock Text="✅"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Completar mantenimiento"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Cierra el registro con costo final, garantía y observaciones"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                Padding="0"
                                ToolTip="Cerrar"
                                Click="CancelarButton_Click" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BackgroundAppBrush}"
                              Padding="20">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </ScrollViewer.Resources>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.10*" />
                            <ColumnDefinition Width="0.90*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Cierre del registro"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Mantenimiento"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding Mantenimiento.Codigo}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Proveedor asignado"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding Mantenimiento.ProveedorAsignado}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource ThemeDetailItemCardStyle}"
                                            Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Costo de reparación"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0,0,0,6" />
                                            <TextBox x:Name="CostoTextBox"
                                                     Text="{Binding CostoReparacion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToCopCurrencyConverter}}"
                                                     Style="{StaticResource ThemeTextBoxStyle}"
                                                     ToolTip="Ingrese el costo total"
                                                     PreviewTextInput="CostoTextBox_PreviewTextInput" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource ThemeDetailItemCardStyle}"
                                            Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Garantía en días"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0,0,0,6" />
                                            <TextBox x:Name="GarantiaTextBox"
                                                     Text="{Binding PeriodoGarantia, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemeTextBoxStyle}"
                                                     ToolTip="Ej: 90, 180, 365 días"
                                                     PreviewTextInput="GarantiaTextBox_PreviewTextInput" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Historial de observaciones"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="{Binding Mantenimiento.Observaciones}"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   MaxHeight="160" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Agregar observación"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="ObservacionesTextBox"
                                                 Text="{Binding Observaciones, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 AcceptsReturn="True"
                                                 Height="110"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="Wrap"
                                                 ToolTip="Nueva observación a agregar al historial" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                                <Border Style="{StaticResource ThemeInfoNoticeStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox x:Name="DarDeBajaCheckBox"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IncluirDarDeBaja, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ThemeCheckBoxStyle}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="El equipo o periférico no es reparable. Activa esta opción para completar el registro con baja en lugar de finalizar la reparación."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="12,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Guía rápida"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeInfoNoticeStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="La columna izquierda ya concentra el formulario principal."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Este panel sirve como referencia visual antes de confirmar el cierre."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Registro actual"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Mantenimiento.Codigo}"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   FontSize="18"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Mantenimiento.ProveedorAsignado}"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Acción seleccionada"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="Completar mantenimiento"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   FontSize="18"
                                                   Margin="0,0,0,4" />
                                        <TextBlock Text="Dar de baja"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   FontSize="18"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Text="Se utilizará la operación normal de cierre"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Text="Se utilizará la operación de baja directa"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Antes de guardar"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="• Verifica el costo final"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Confirma la garantía en días"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Añade una observación clara de cierre"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Estado"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="Listo para completar"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Text="Procesando solicitud y guardando cambios"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,18,18"
                        Padding="20,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Procesando..."
                                       Style="{StaticResource ThemeBodyTextStyle}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="CancelarButton"
                                    Content="Cancelar"
                                    Click="CancelarButton_Click"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    Width="118"
                                    Height="38"
                                    Margin="0,0,10,0" />

                            <Button x:Name="DarDeBajaButton"
                                    Content="Dar de baja"
                                    Command="{Binding CompletarYDarDeBajaCommand}"
                                    Style="{StaticResource ThemeDangerButtonStyle}"
                                    Width="132"
                                    Height="38"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />

                            <Button x:Name="CompletarButton"
                                    Content="Completar"
                                    Command="{Binding CompletarMantenimientoCommand}"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    Width="128"
                                    Height="38"
                                    Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource InverseBooleanConverter}}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
