<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.HistorialEjecucionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.EdgeMode="Aliased">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />

        <Storyboard x:Key="ShowDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="DetailPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="400"
                             To="0"
                             Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.25" />
        </Storyboard>

        <Storyboard x:Key="HideDetailPanelStoryboard">
            <DoubleAnimation Storyboard.TargetName="DetailPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0"
                             To="400"
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DetailPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.2" />
        </Storyboard>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,8"
            Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,12,0">
                        <TextBlock Text=""
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Historial de Ejecuciones"
                                   Style="{StaticResource ThemeSectionTitleStyle}" />
                        <TextBlock Text="Registro completo de mantenimientos ejecutados"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="⭱ Exportar"
                            Command="{Binding ExportarItemsCommand}"
                            ToolTip="Exportar historial"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Margin="0,0,8,0"
                            MinHeight="38" />
                    <Button Content="↻ Refrescar"
                            Command="{Binding CargarItemsCommand}"
                            ToolTip="Actualizar historial"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            MinHeight="38" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,8"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0"
                           VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                        <TextBlock Text="Código"
                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Width="160"
                                 Text="{Binding FiltroCodigo, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filtrar por código"
                                 Style="{StaticResource ThemeTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                        <TextBlock Text="Nombre de equipo"
                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Width="220"
                                 Text="{Binding FiltroNombre, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filtrar por nombre de equipo"
                                 Style="{StaticResource ThemeTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                        <TextBlock Text="Usuario / Asignación"
                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Width="200"
                                 Text="{Binding FiltroUsuario, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filtrar por usuario/asignación"
                                 Style="{StaticResource ThemeTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                        <TextBlock Text="Semana"
                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBox Width="100"
                                 Text="{Binding FiltroSemana, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filtrar por semana"
                                 Style="{StaticResource ThemeTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Año"
                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox Width="120"
                                  Height="40"
                                  ItemsSource="{Binding Years}"
                                  SelectedItem="{Binding SelectedYear}"
                                  Style="{StaticResource ThemeComboBoxStyle}"
                                  ToolTip="Seleccionar año" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

          <Grid Grid.Row="2"
              Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource ThemeElevatedCardStyle}"
                    Padding="16">
                <DataGrid ItemsSource="{Binding FilteredItems}"
                          SelectedItem="{Binding SelectedEjecucion}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          RowHeight="40"
                          ColumnWidth="*"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Standard"
                          ScrollViewer.CanContentScroll="True"
                          Style="{StaticResource ThemeDataGridStyle}"
                          BorderThickness="0"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemeDataGridRowStyle}" />
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemeDataGridCellStyle}" />
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding CodigoEquipo}" Width="SizeToCells" MinWidth="110" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Nombre de Equipo" Binding="{Binding NombreEquipo}" Width="*" MinWidth="260" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Año" Binding="{Binding AnioISO}" Width="SizeToCells" MinWidth="80" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Semana" Binding="{Binding SemanaISO}" Width="SizeToCells" MinWidth="90" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Fecha Objetivo" Binding="{Binding FechaObjetivo, StringFormat=dd/MM/yyyy}" Width="SizeToCells" MinWidth="140" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Fecha Ejecución" Binding="{Binding FechaEjecucion, StringFormat=dd/MM/yyyy HH:mm}" Width="SizeToCells" MinWidth="160" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTemplateColumn Header="Estado" Width="SizeToCells" MinWidth="160" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EstadoDescripcion}" Value="Ejecutado">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EstadoDescripcion}" Value="No Realizado">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EstadoDescripcion}" Value="Atrasado">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EstadoDescripcion}" Value="Pendiente">
                                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EstadoDescripcion}" Value="En Proceso">
                                                        <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding EstadoDescripcion}"
                                                   Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Usuario/Asignación" Binding="{Binding UsuarioAsignadoEquipo}" Width="*" MinWidth="240" IsReadOnly="True" ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTemplateColumn Header="" Width="SizeToCells" MinWidth="120" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Detalles"
                                            Style="{StaticResource ThemeSecondaryButtonStyle}"
                                            Command="{Binding DataContext.VerDetallePlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            MinWidth="88"
                                            Height="32"
                                            Padding="12,6"
                                            HorizontalAlignment="Center"
                                            Focusable="False"
                                            IsHitTestVisible="True"
                                            ClickMode="Release" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border x:Name="DetailPanel"
                    Grid.Column="1"
                    Background="{DynamicResource BackgroundSurfaceBrush}"
                    BorderBrush="{DynamicResource BorderLightBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0"
                    Width="400"
                    Opacity="0"
                    Visibility="Collapsed"
                    CacheMode="BitmapCache">
                <Border.RenderTransform>
                    <TranslateTransform X="400" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding MostrarDetalle}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource ShowDetailPanelStoryboard}" />
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource HideDetailPanelStoryboard}" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource ThemeElevatedCardStyle}"
                            Margin="10,0,10,10"
                            Padding="16">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Margin="0,0,12,0">
                                    <TextBlock Text=""
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" />
                                </Border>
                                <TextBlock Text="Detalle de Ejecución"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Content="✕"
                                    Command="{Binding CerrarDetalleCommand}"
                                    Style="{StaticResource ThemeCloseButtonStyle}"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    ToolTip="Cerrar panel de detalle" />
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20"
                                  ScrollViewer.CanContentScroll="True">
                        <StackPanel>
                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                    Padding="16"
                                    Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Equipo:" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,0,12,8" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEjecucion.CodigoEquipo}" Style="{StaticResource ThemeDetailValueStyle}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Nombre:" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,0,12,8" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEjecucion.NombreEquipo}" Style="{StaticResource ThemeDetailValueStyle}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Año / Semana:" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,0,12,8" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource ThemeDetailValueStyle}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} / {1}">
                                                <Binding Path="SelectedEjecucion.AnioISO" />
                                                <Binding Path="SelectedEjecucion.SemanaISO" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Objetivo:" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,0,12,8" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEjecucion.FechaObjetivo, StringFormat=dd/MM/yyyy}" Style="{StaticResource ThemeDetailValueStyle}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ejecución:" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,0,12,0" />
                                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedEjecucion.FechaEjecucion, StringFormat=dd/MM/yyyy HH:mm}" Style="{StaticResource ThemeDetailValueStyle}" />
                                        <Border Style="{StaticResource ThemeDetailChipStyle}"
                                                Margin="12,0,0,0"
                                                Background="{DynamicResource PrimaryBrush}">
                                            <TextBlock Text="{Binding SelectedEjecucion.EstadoDescripcion}"
                                                       Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Checklist"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding SelectedEjecucion.Checklist}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                                    <CheckBox IsChecked="{Binding Completado}"
                                                              IsEnabled="False"
                                                              VerticalAlignment="Center"
                                                              Style="{StaticResource ThemeCheckBoxStyle}" />
                                                    <TextBlock Text="{Binding Descripcion}"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource ThemeDetailValueStyle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
