<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.MantenimientosCorrectivosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:GestLog.Converters"
             x:Name="MantenimientosCorrectivosViewControl"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             Background="{DynamicResource BackgroundAppBrush}">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
        <conv:EstadoToColorConverter x:Key="EstadoToColorConverter" />
        <conv:EstadoToActionButtonTextConverter x:Key="EstadoToActionButtonTextConverter" />
        <conv:EstadoToActionButtonColorConverter x:Key="EstadoToActionButtonColorConverter" />
        <conv:EstadoMantenimientoCountConverter x:Key="EstadoMantenimientoCountConverter" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <conv:DecimalToCopCurrencyConverter x:Key="DecimalToCopCurrencyConverter" />
        <conv:GarantiaStatusConverter x:Key="GarantiaStatusConverter" />
        <conv:GarantiaStatusToColorConverter x:Key="GarantiaStatusToColorConverter" />
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,8"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                            Width="44"
                            Height="44"
                            Margin="0,0,12,0">
                        <TextBlock Text="🔧"
                                   FontFamily="Segoe UI Emoji"
                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                   FontSize="18" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Mantenimientos Correctivos"
                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                   Foreground="{DynamicResource TextOnPrimaryBrush}" />
                        <TextBlock Text="Gestión de reparaciones y mantenimientos reactivos"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextOnPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="↻ Refrescar"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Margin="0,0,8,0"
                            MinHeight="38" />

                    <Button Content="＋ Agregar"
                            Command="{Binding AgregarMantenimientoCommand}"
                            Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                            MinHeight="38"
                            MinWidth="140" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,8"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filtrar"
                               Style="{StaticResource ThemeBodyTextStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBox Width="460"
                             Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             VerticalAlignment="Center"
                             Tag="Filtrar por equipo, proveedor o texto libre" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <CheckBox Content="Pendientes"
                              IsChecked="{Binding FiltrarPendientes, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ThemeCheckBoxStyle}"
                              Margin="8,0" />
                    <CheckBox Content="Completados"
                              IsChecked="{Binding FiltrarCompletados, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ThemeCheckBoxStyle}"
                              Margin="8,0" />
                    <CheckBox Content="Cancelados"
                              IsChecked="{Binding FiltrarCancelados, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ThemeCheckBoxStyle}"
                              Margin="8,0" />
                    <CheckBox Content="En Reparación"
                              IsChecked="{Binding FiltrarEnReparacion, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ThemeCheckBoxStyle}"
                              Margin="8,0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,10"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Lista de mantenimiento"
                           Style="{StaticResource ThemeSectionTitleStyle}"
                           FontSize="18"
                           Margin="0,0,0,12" />

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Mantenimientos}"
                          SelectedItem="{Binding SelectedMantenimiento}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderDefaultBrush}"
                          AlternatingRowBackground="{DynamicResource BackgroundHoverBrush}"
                          RowHeight="40"
                          ColumnWidth="*"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Standard"
                          ScrollViewer.CanContentScroll="True"
                          Style="{StaticResource ThemeDataGridStyle}"
                          RowStyle="{StaticResource ThemeDataGridRowStyle}"
                          BorderThickness="0"
                          SnapsToDevicePixels="True"
                          UseLayoutRounding="True"
                          Margin="0,0,0,16">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemeDataGridCellStyle}" />
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </DataGrid.Resources>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemeDataGridCellStyle}" />
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Codigo}"
                                            Width="SizeToCells"
                                            MinWidth="140"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Falla"
                                            Binding="{Binding DescripcionFalla}"
                                            Width="*"
                                            MinWidth="220"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Observaciones"
                                            Binding="{Binding Observaciones}"
                                            Width="*"
                                            MinWidth="180"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Proveedor"
                                            Binding="{Binding ProveedorAsignado}"
                                            Width="SizeToCells"
                                            MinWidth="150"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Fecha"
                                            Binding="{Binding FechaFalla, StringFormat=dd/MM/yyyy}"
                                            Width="SizeToCells"
                                            MinWidth="110"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Costo"
                                            Binding="{Binding CostoReparacion, Converter={StaticResource DecimalToCopCurrencyConverter}}"
                                            Width="SizeToCells"
                                            MinWidth="110"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTextColumn Header="Garantía"
                                            Binding="{Binding PeriodoGarantia, StringFormat='0d'}"
                                            Width="SizeToCells"
                                            MinWidth="85"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                        <DataGridTemplateColumn Header="Est. Garantía"
                                                Width="SizeToCells"
                                                MinWidth="130"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                ToolTip="Estado de garantía">
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"
                                                 Stroke="{DynamicResource BorderDefaultBrush}"
                                                 StrokeThickness="0.5">
                                            <Ellipse.Fill>
                                                <MultiBinding Converter="{StaticResource GarantiaStatusToColorConverter}">
                                                    <Binding Path="FechaCompletado" />
                                                    <Binding Path="PeriodoGarantia" />
                                                </MultiBinding>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock VerticalAlignment="Center"
                                                   Style="{StaticResource ThemeDataGridTextStyle}"
                                                   FontWeight="Medium"
                                                   FontSize="11">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource GarantiaStatusConverter}">
                                                    <Binding Path="FechaCompletado" />
                                                    <Binding Path="PeriodoGarantia" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Estado"
                                                Width="SizeToCells"
                                                MinWidth="100"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Center"
                                            Width="112"
                                            Height="28"
                                            Padding="8,4"
                                            CornerRadius="6"
                                            Margin="0,0,6,0"
                                            BorderThickness="1"
                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                        <Border.BorderBrush>
                                            <Binding Path="Estado" Converter="{StaticResource EstadoToColorConverter}" />
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <Ellipse Width="7"
                                                 Height="7"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0">
                                                <Ellipse.Fill>
                                                    <Binding Path="Estado" Converter="{StaticResource EstadoToColorConverter}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Estado, Converter={StaticResource EnumToDescriptionConverter}}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Acción"
                                                Width="SizeToCells"
                                                MinWidth="110"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Estado, Converter={StaticResource EstadoToActionButtonTextConverter}}"
                                            Background="{Binding Estado, Converter={StaticResource EstadoToActionButtonColorConverter}}"
                                            Foreground="{DynamicResource TextOnPrimaryBrush}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Command="{Binding DataContext.EjecutarAccionDinamicaCommand, ElementName=MantenimientosCorrectivosViewControl}"
                                            CommandParameter="{Binding}"
                                            Width="112"
                                            Height="30"
                                            Margin="6,0,0,0"
                                            HorizontalAlignment="Center"
                                            Focusable="False"
                                            ClickMode="Release"
                                            FontSize="11"
                                            Padding="8,2"
                                            BorderThickness="0"
                                            Cursor="Hand" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        Padding="8"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderDefaultBrush}">
                    <TextBlock Text="{Binding Mantenimientos.Count, StringFormat='Total: {0} mantenimientos'}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
