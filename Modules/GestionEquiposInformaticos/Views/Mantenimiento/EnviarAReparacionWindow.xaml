<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.EnviarAReparacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:GestLog.Converters"
        mc:Ignorable="d"
        Title="Enviar a Reparación"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        d:DesignHeight="640"
        d:DesignWidth="980">

    <Window.Resources>
        <ResourceDictionary>
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:BooleanToStatusTextConverter x:Key="ActionStatusTextConverter" TrueText="Se dará de baja" FalseText="Se enviará a reparación" />
            <conv:BooleanToColorConverter x:Key="ActionStatusColorConverter" TrueColor="#DC3545" FalseColor="#2563EB" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="960"
                MaxHeight="820"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                Effect="{DynamicResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,14,0">
                                <TextBlock Text="🔧"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Enviar a reparación"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Define proveedor, fecha y observaciones antes de confirmar"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                Padding="0"
                                ToolTip="Cerrar"
                                Click="CancelarButton_Click" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BackgroundAppBrush}"
                              Padding="20">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </ScrollViewer.Resources>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.12*" />
                            <ColumnDefinition Width="0.88*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Datos del envío"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Proveedor"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <ComboBox x:Name="CmbProveedor"
                                                  Text="{Binding ProveedorAsignado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding ProveedoresFiltrados}"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  ToolTip="Seleccione un proveedor existente o escriba uno nuevo" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Fecha de inicio"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <DatePicker SelectedDate="{Binding FechaInicio, UpdateSourceTrigger=PropertyChanged}"
                                                    Style="{StaticResource ThemeDatePickerStyle}"
                                                    ToolTip="Fecha en que inicia el mantenimiento" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Observaciones"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBox x:Name="ObservacionesTextBox"
                                                 Text="{Binding Observaciones, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ThemeTextBoxStyle}"
                                                 AcceptsReturn="True"
                                                 Height="120"
                                                 VerticalScrollBarVisibility="Auto"
                                                 TextWrapping="Wrap"
                                                 ToolTip="Observaciones adicionales sobre el envío o la reparación" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12"
                                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}" />

                                <Border Style="{StaticResource ThemeInfoNoticeStyle}"
                                        Margin="0,0,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox x:Name="DarDeBajaCheckBox"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IncluirDarDeBaja, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ThemeCheckBoxStyle}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="El activo no es reparable y debe darse de baja en lugar de enviarse a reparación."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="12,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Guía rápida"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeInfoNoticeStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="La vista izquierda ya concentra el formulario principal."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Este panel ayuda a tomar la decisión correcta antes de guardar."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Acción seleccionada"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10"
                                                     Height="10"
                                                     Margin="0,0,8,0"
                                                     Fill="{Binding IncluirDarDeBaja, Converter={StaticResource ActionStatusColorConverter}}" />
                                            <TextBlock Text="{Binding IncluirDarDeBaja, Converter={StaticResource ActionStatusTextConverter}}"
                                                       Style="{StaticResource ThemeSectionTitleStyle}"
                                                       FontSize="18" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Recomendación"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="Completa proveedor, fecha y observaciones antes de confirmar."
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="Si activas la baja, el botón de envío se reemplaza por una acción de baja directa."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Estado del registro"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="Listo para confirmar"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                                        <TextBlock Text="Procesando solicitud y guardando cambios"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,18,18"
                        Padding="20,16">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Procesando..."
                                       Style="{StaticResource ThemeBodyTextStyle}"
                                       Margin="0,0,12,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="CancelarButton"
                                    Content="Cancelar"
                                    Click="CancelarButton_Click"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    Width="118"
                                    Height="38"
                                    Margin="0,0,10,0" />

                            <Button x:Name="DarDeBajaButton"
                                    Content="Dar de baja"
                                    Command="{Binding DarDeBajaCommand}"
                                    Style="{StaticResource ThemeDangerButtonStyle}"
                                    Width="132"
                                    Height="38"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />

                            <Button x:Name="EnviarButton"
                                    Content="Enviar a reparación"
                                    Command="{Binding EnviarAReparacionCommand}"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    Width="164"
                                    Height="38"
                                    Visibility="{Binding IncluirDarDeBaja, Converter={StaticResource InverseBooleanConverter}}"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
