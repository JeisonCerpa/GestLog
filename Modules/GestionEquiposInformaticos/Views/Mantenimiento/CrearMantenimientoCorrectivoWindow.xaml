<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.CrearMantenimientoCorrectivoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Crear Mantenimiento Correctivo"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        d:DesignHeight="680"
        d:DesignWidth="1020">

    <Grid x:Name="RootGrid"
          Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="1000"
                MaxHeight="820"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                Effect="{DynamicResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="22,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,14,0">
                                <TextBlock Text="🔧"
                                           FontFamily="Segoe UI Emoji"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Crear mantenimiento correctivo"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Registrar una nueva reparación o incidencia"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                Padding="0"
                                ToolTip="Cerrar"
                                Click="CancelarButton_Click" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BackgroundAppBrush}"
                              Padding="20">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </ScrollViewer.Resources>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.15*" />
                            <ColumnDefinition Width="0.85*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Datos del activo"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Entidad"
                                                   Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding EntidadTipos}"
                                                  SelectedItem="{Binding TipoEntidad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  ToolTip="Seleccionar si el mantenimiento corresponde a un equipo o periférico" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Código Equipo / Periférico"
                                                   Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding CodigoSugerencias}"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  SelectedItem="{Binding SelectedCodigoSuggestion, Mode=TwoWay}"
                                                  Text="{Binding CodigoEntidad, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  ToolTip="Escribe el código y selecciona una sugerencia">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} - {1}">
                                                                <Binding Path="Code" />
                                                                <Binding Path="Name" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Incidencia"
                                                   Style="{StaticResource ThemeDetailLabelStyle}" />

                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="Fecha de falla"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0,0,0,6" />
                                            <DatePicker SelectedDate="{Binding FechaFalla}"
                                                        Style="{StaticResource ThemeDatePickerStyle}"
                                                        ToolTip="Fecha en la que ocurrió la falla" />
                                        </StackPanel>

                                        <StackPanel>
                                            <TextBlock Text="Descripción de la falla"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0,0,0,6" />
                                            <TextBox Text="{Binding DescripcionFalla, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemeTextBoxStyle}"
                                                     AcceptsReturn="True"
                                                     Height="160"
                                                     VerticalScrollBarVisibility="Auto"
                                                     TextWrapping="Wrap"
                                                     ToolTip="Describe el motivo del mantenimiento correctivo" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="12,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Ayuda del formulario"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border Style="{StaticResource ThemeInfoNoticeStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="El panel izquierdo ya muestra los datos capturados en tiempo real."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Este espacio queda para indicar qué completar y cómo dejar listo el registro."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Qué debes completar"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Text="• Selecciona si corresponde a un equipo o periférico"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Busca o escribe el código exacto del activo"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Registra una fecha real de la falla"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="• Describe el problema con suficiente contexto"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                        Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Flujo rápido"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,8" />

                                        <TextBlock Text="1. Completa el código"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="2. Revisa la sugerencia autocompletada"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="3. Escribe la descripción y crea el registro"
                                                   Style="{StaticResource ThemeDetailValueStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Nota"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,0,6" />
                                        <TextBlock Text="El botón Crear se habilita cuando existan código y descripción."
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,18,18"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cancelar"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                Width="120"
                                Height="38"
                                Click="CancelarButton_Click"
                                Margin="0,0,10,0" />

                        <Button Content="Crear"
                                Style="{StaticResource ThemePrimaryButtonStyle}"
                                Width="130"
                                Height="38"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding CanSave}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
