<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento.RegistroEjecucionPlanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:GestLog.Converters"
        Title="Registrar Ejecución de Plan"
        Width="1180"
        MinWidth="1080"
        MinHeight="780"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        WindowState="Maximized"
        KeyDown="RegistroEjecucionPlanDialog_KeyDown">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <Style x:Key="ExecutionHeaderChipStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailChipStyle}">
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style x:Key="CompactExecutionCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource ThemeCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="#B3000000"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="1120"
                MaxHeight="880"
                Background="{DynamicResource BackgroundAppBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        CornerRadius="24,24,0,0"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="52"
                                    Height="52"
                                    Margin="0,0,16,0"
                                    CornerRadius="16"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="⚙"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Registro de ejecución"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           FontSize="21" />
                                <TextBlock Text="Registro semanal del plan con checklist, progreso y observaciones"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="CloseButton"
                                Click="Cerrar_Click"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                ToolTip="Cerrar (Esc)"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <TextBlock Text="✕"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="24"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <!-- Checklist -->
                    <Border Grid.Column="0"
                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                            Padding="18"
                            Margin="0,0,12,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Checklist de ejecución"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               Margin="0,0,0,4" />
                                    <TextBlock Text="Marca cada actividad completada durante la ejecución del plan."
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource ExecutionHeaderChipStyle}"
                                        VerticalAlignment="Center">
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="FechaObjetivo" StringFormat="Fecha objetivo: {0:dd/MM/yyyy}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <Separator Grid.Row="1" Margin="0,0,0,10" Opacity="0.6" />

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="No hay actividades en el checklist"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,8"
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Visibility="{Binding Checklist.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                                <ScrollViewer Grid.Row="1"
                                              PreviewMouseWheel="ChecklistScrollViewer_PreviewMouseWheel"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0"
                                              Margin="0"
                                              UseLayoutRounding="True"
                                              SnapsToDevicePixels="True">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                                    </ScrollViewer.Resources>

                                    <ListView ItemsSource="{Binding Checklist}"
                                              HorizontalContentAlignment="Stretch"
                                              BorderThickness="0"
                                              Background="Transparent"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListViewItem">
                                                            <Border Background="Transparent" Padding="0">
                                                                <ContentPresenter />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                                        Background="{DynamicResource BackgroundSurfaceBrush}"
                                                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                        Padding="10,8"
                                                        Margin="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox IsChecked="{Binding Completado, Mode=TwoWay}"
                                                                  Style="{StaticResource CompactExecutionCheckBoxStyle}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,12,0" />

                                                        <StackPanel Grid.Column="1"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Descripcion, TargetNullValue=(sin descripción)}"
                                                                       Style="{StaticResource ThemeBodyTextStyle}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Row="3" Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="0,0,10,0">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Items completados"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0}/{1}">
                                                <Binding Path="CompletedItems" />
                                                <Binding Path="TotalItems" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource ThemeDetailChipStyle}">
                                    <TextBlock Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="PercentComplete" StringFormat="{}{0}% progreso" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Panel lateral -->
                    <Border Grid.Column="1"
                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                            Padding="18"
                            Margin="12,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Información del plan"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,10" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Semana" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <Border Style="{StaticResource ExecutionHeaderChipStyle}">
                                            <TextBlock Text="{Binding SemanaISO, StringFormat=Semana {0}}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Código equipo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <Border Style="{StaticResource ExecutionHeaderChipStyle}">
                                            <TextBlock Text="{Binding CodigoEquipo}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="Responsable del plan" Style="{StaticResource ThemeDetailLabelStyle}" />
                                    <TextBox Text="{Binding ResponsablePlan, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ThemeTextBoxStyle}"
                                             MinHeight="40" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    Margin="0,16,0,0"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Resumen en vivo"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,10" />

                                    <ProgressBar Height="10"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding PercentComplete}"
                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                 Background="{DynamicResource BackgroundElevatedBrush}" />

                                    <TextBlock Text="{Binding PercentComplete, StringFormat={}{0}% completado}"
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Right"
                                               Margin="0,8,0,0" />

                                    <TextBlock Text="{Binding ResumenEnVivo}"
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               Foreground="{DynamicResource TextBodyBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Style="{StaticResource ThemeElevatedCardStyle}"
                                    Background="{DynamicResource BackgroundSurfaceBrush}"
                                    Margin="0,16,0,0"
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Observaciones"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="16"
                                               Margin="0,0,0,10" />
                                    <TextBox Text="{Binding ObservacionCentral, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="170"
                                             Style="{StaticResource ThemeTextBoxStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="3"
                                    Background="Transparent"
                                    Margin="0,16,0,0">
                                <StackPanel VerticalAlignment="Bottom">
                                    <TextBlock Text="Recomendación"
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Padding="24,16"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Marca cada ítem y guarda la ejecución para dejar el plan actualizado en el sistema."
                                   Style="{StaticResource ThemeBodyTextStyle}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="Cancelar"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    Click="Cerrar_Click"
                                    Margin="0,0,10,0"
                                    MinWidth="120"
                                    MinHeight="40" />

                            <Button Content="Guardar ejecución"
                                    Command="{Binding GuardarCommand}"
                                    IsDefault="True"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    MinWidth="170"
                                    MinHeight="40" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
