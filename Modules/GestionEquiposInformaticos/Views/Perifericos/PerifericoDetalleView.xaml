<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Perifericos.PerifericoDetalleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Perifericos"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Detalle de periférico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.Resources>
        <ResourceDictionary>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:EstadoToColorConverter x:Key="EstadoToColorConverter" />

            <Style x:Key="PerifericoDetalleBadgeStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailChipStyle}">
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style x:Key="PerifericoDetalleBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ThemeDetailValueStyle}">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
            </Style>

            <Style x:Key="PerifericoKeyValueCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailItemCardStyle}">
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="#80000000"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown">

        <Border x:Name="Card"
            Width="960"
                MaxHeight="760"
                Background="{DynamicResource BackgroundAppBrush}"
                CornerRadius="22"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        CornerRadius="22,22,0,0"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="54"
                                    Height="54"
                                    Margin="0,0,16,0"
                                    CornerRadius="16"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="⌨"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalle del periférico"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="20"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Vista premium y elegante para revisar información, estado e historial del activo"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="BtnCerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Click="BtnCerrar_Click"
                                ToolTip="Cerrar (Esc)"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <TextBlock Text="✕"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                            <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                        </ScrollViewer.Resources>

                        <StackPanel>
                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Información principal"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               Margin="0,0,0,18" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.15*" />
                                            <ColumnDefinition Width="0.85*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource PerifericoKeyValueCardStyle}" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Código" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding Codigo}"
                                                           Style="{StaticResource ThemeDetailValueStyle}"
                                                           Margin="0,2,0,0" />

                                                <TextBlock Text="Dispositivo"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           Margin="0,14,0,0" />
                                                <TextBlock Text="{Binding Nombre}"
                                                           Style="{StaticResource ThemeDetailValueStyle}"
                                                           Margin="0,2,0,0"
                                                           TextWrapping="Wrap" />

                                                <TextBlock Text="Asignación"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           Margin="0,14,0,0" />
                                                <TextBlock Text="{Binding Asignacion}"
                                                           Style="{StaticResource ThemeDetailValueStyle}"
                                                           Margin="0,2,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource PerifericoKeyValueCardStyle}" Margin="10,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Estado" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <Border Style="{StaticResource PerifericoDetalleBadgeStyle}"
                                                        Background="{Binding Estado, Converter={StaticResource EstadoToColorConverter}}"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Estado}" Style="{StaticResource PerifericoDetalleBadgeTextStyle}" />
                                                </Border>

                                                <TextBlock Text="Sede"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           Margin="0,14,0,0" />
                                                <TextBlock Text="{Binding Sede}"
                                                           Style="{StaticResource ThemeDetailValueStyle}"
                                                           Margin="0,2,0,0" />

                                                <TextBlock Text="Fecha adquisición"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           Margin="0,14,0,0" />
                                                <TextBlock Text="{Binding FechaAdquisicion, StringFormat=d}"
                                                           Style="{StaticResource ThemeDetailValueStyle}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Datos técnicos"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               Margin="0,0,0,18" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBlock Text="{Binding Marca}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,2,0,0" />

                                            <TextBlock Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="{Binding Modelo}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Número de serie" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,2,0,0" />

                                            <TextBlock Text="Usuario anterior" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="{Binding UsuarioAsignadoAnterior, TargetNullValue='(vacío)'}"
                                                       Style="{StaticResource ThemeDetailValueStyle}"
                                                       Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />

                                            <TextBlock Text="Equipo anterior" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,14,0,0" />
                                            <TextBlock Text="{Binding CodigoEquipoAsignadoAnterior, TargetNullValue='(vacío)'}"
                                                       Style="{StaticResource ThemeDetailValueStyle}"
                                                       Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Observaciones"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               Margin="0,0,0,14" />

                                    <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                        <TextBlock Text="{Binding Observaciones, TargetNullValue='Sin observaciones'}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Detalles adicionales"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               FontSize="18"
                                               Margin="0,0,0,14" />

                                    <ItemsControl ItemsSource="{Binding DetallesAdicionales}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                                    <TextBlock Text="{Binding}"
                                                               Style="{StaticResource ThemeDetailValueStyle}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Row="2"
                        Padding="20,16"
                        Background="Transparent"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Text="Una vista de solo lectura pensada para revisar el periférico con claridad y sin ruido visual." />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="Cerrar"
                                    Click="BtnCerrar_Click"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    Margin="0,0,10,0" />
                            <Button Content="Editar"
                                    Click="BtnEditar_Click"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    Visibility="{Binding CanEditar, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    MinWidth="130" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
