<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Perifericos.PerifericosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1200"
             Background="{DynamicResource BackgroundAppBrush}">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <conv:EstadoToColorConverter x:Key="EstadoToColorConverter" />
        <conv:EstadoToBoolConverter x:Key="EstadoToDadoDeBajaConverter" TargetEstado="DadoDeBaja" />
        <conv:EstadoToOpacityConverter x:Key="EstadoToOpacityConverter" />
    </UserControl.Resources>

        <Grid Background="{DynamicResource BackgroundAppBrush}"
            UseLayoutRounding="True"
          SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,8"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,12,0">
                        <TextBlock Text="🖱"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="20"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de periféricos"
                                   Style="{StaticResource ThemeSectionTitleStyle}" />
                        <TextBlock Text="Administración, seguimiento y consulta de periféricos informáticos"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="⭱ Exportar"
                        Command="{Binding ExportarPerifericosCommand}"
                        Style="{StaticResource ThemeHeaderActionButtonStyle}"
                        IsEnabled="{Binding CanExportarDatos}"
                        Opacity="{Binding CanExportarDatos, Converter={StaticResource BooleanToOpacityConverter}}"
                        Margin="0,0,8,0"
                        MinHeight="38"
                        ToolTip="Exportar periféricos a Excel" />
                    <Button Content="↻ Refrescar"
                        Command="{Binding CargarPerifericosCommand}"
                        Style="{StaticResource ThemeHeaderActionButtonStyle}"
                        Margin="0,0,8,0"
                        MinHeight="38"
                        ToolTip="Actualizar lista de periféricos" />
                    <Button Content="＋ Nuevo periférico"
                        Command="{Binding AgregarPerifericoCommand}"
                        Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                        MinHeight="38"
                        MinWidth="150"
                        ToolTip="Agregar nuevo periférico" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
            Style="{StaticResource ThemeElevatedCardStyle}"
            Margin="10,0,10,8"
            Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Filtrar"
                               Style="{StaticResource ThemeBodyTextStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />

                    <TextBox Width="420"
                             Text="{Binding Filtro, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             Tag="Escribe código, nombre, marca o asignación"
                             VerticalAlignment="Center" />
                </StackPanel>

                <CheckBox Grid.Column="1"
                          Content="Mostrar dados de baja"
                          IsChecked="{Binding ShowDadoDeBaja, Mode=TwoWay}"
                          Style="{StaticResource ThemeCheckBoxStyle}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          Margin="16,0,0,0" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
            Style="{StaticResource ThemeElevatedCardStyle}"
            Margin="10,0,10,10"
            Padding="16">
            <Grid>
                <DataGrid ItemsSource="{Binding PerifericosView}"
                          SelectedItem="{Binding PerifericoSeleccionado}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderDefaultBrush}"
                          FontSize="13"
                          RowHeight="40"
                          ColumnWidth="*"
                          EnableColumnVirtualization="False"
                          VirtualizingPanel.VirtualizationMode="Standard"
                          ScrollViewer.CanContentScroll="True"
                          Style="{StaticResource ThemeDataGridStyle}"
                          CellStyle="{StaticResource ThemeDataGridCellStyle}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ThemeDataGridTextStyle}" />
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código"
                                           Binding="{Binding Codigo}"
                                           Width="SizeToCells"
                                           MinWidth="110"
                                           IsReadOnly="True"
                                           ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Dispositivo"
                                           Binding="{Binding Dispositivo}"
                                           Width="*"
                                           MinWidth="240"
                                           IsReadOnly="True"
                                           ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Marca"
                                           Binding="{Binding Marca}"
                                           Width="SizeToCells"
                                           MinWidth="140"
                                           IsReadOnly="True"
                                           ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Asignación"
                                           Binding="{Binding TextoAsignacion}"
                                           Width="*"
                                           MinWidth="220"
                                           IsReadOnly="True"
                                           ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTextColumn Header="Sede"
                                           Binding="{Binding Sede, Converter={StaticResource EnumToDescriptionConverter}}"
                                           Width="SizeToCells"
                                           MinWidth="165"
                                           IsReadOnly="True"
                                           ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                        <DataGridTemplateColumn Header="Estado"
                                                Width="SizeToCells"
                                               MinWidth="170"
                                                IsReadOnly="True"
                                                SortMemberPath="EstadoOrden">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding Estado}">
                                        <Ellipse Width="12"
                                                 Height="12"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Estado, Converter={StaticResource EstadoToColorConverter}}"
                                                 Stroke="#BFBFBF"
                                                 StrokeThickness="0.5" />
                                        <TextBlock Text="{Binding Estado, Converter={StaticResource EnumToDescriptionConverter}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Medium" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header=""
                                                Width="SizeToCells"
                                                MinWidth="130"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Detalles"
                                            Style="{StaticResource ThemeSecondaryButtonStyle}"
                                            Command="{Binding DataContext.VerDetallesPerifericoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            MinWidth="104"
                                            Width="Auto"
                                            Height="34"
                                            Padding="14,6"
                                            HorizontalAlignment="Center"
                                            Margin="4,0"
                                            Focusable="False"
                                            IsHitTestVisible="True"
                                            ClickMode="Release" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                Background="{DynamicResource ModalOverlayBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="220"
                             Height="5"
                             Margin="0,0,0,16" />
                <TextBlock Text="Cargando..."
                           Style="{StaticResource ThemeSectionTitleStyle}"
                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
