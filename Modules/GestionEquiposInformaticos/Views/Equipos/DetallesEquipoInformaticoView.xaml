<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Equipos.DetallesEquipoInformaticoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:GestLog.Converters"
        mc:Ignorable="d"
        Title="Detalles Equipo"
        Height="820"
        Width="1120"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    <Window.Resources>
        <ResourceDictionary>
            <conv:BooleanToEmojiConverter x:Key="BooleanToEmojiConverter" />
            <conv:EstadoToColorConverter x:Key="EstadoToColorConverter" />

            <DataTemplate x:Key="RamItemTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding TipoMemoria, Mode=OneWay}"
                                   Style="{StaticResource ThemeCardTitleStyle}"
                                   FontSize="16" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Slot" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NumeroSlot, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Capacidad" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CapacidadGB, Mode=OneWay, StringFormat={}{0} GB}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Marca, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Frecuencia" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Frecuencia, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />
                        </Grid>

                        <TextBlock Text="{Binding Observaciones, Mode=OneWay}"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource ThemeBodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="DiscoItemTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{Binding NumeroDisco, Mode=OneWay, StringFormat=Disco {0}}"
                                   Style="{StaticResource ThemeCardTitleStyle}"
                                   FontSize="16" />

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Tipo, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Capacidad" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CapacidadGB, Mode=OneWay, StringFormat={}{0} GB}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Marca, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Modelo, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="ConexionItemTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Adaptador, Mode=OneWay}"
                                       Style="{StaticResource ThemeCardTitleStyle}"
                                       FontSize="16" />
                            <Border Margin="12,0,0,0"
                                    Padding="10,6"
                                    CornerRadius="10"
                                    Background="{Binding EstadoDescripcion, Mode=OneWay, Converter={StaticResource EstadoToColorConverter}}">
                                <TextBlock Text="Activo"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DireccionIPv4, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="MAC" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding DireccionMAC, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Máscara" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MascaraSubred, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Gateway" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PuertoEnlace, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="PerifericoItemTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Dispositivo, Mode=OneWay}"
                                       Style="{StaticResource ThemeCardTitleStyle}"
                                       FontSize="16" />
                            <Border Margin="12,0,0,0"
                                    Padding="12,7"
                                    CornerRadius="10"
                                    Background="{Binding EstadoDescripcion, Mode=OneWay, Converter={StaticResource EstadoToColorConverter}}">
                                <TextBlock Text="{Binding EstadoDescripcion, Mode=OneWay}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Código" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Codigo, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding Marca, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Modelo, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Serial" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,10,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SerialNumber, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,10,0,0" />
                        </Grid>

                        <TextBlock Text="{Binding Observaciones, Mode=OneWay}"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource ThemeBodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True"
          Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="1120"
                MaxHeight="820"
                Background="{DynamicResource BackgroundAppBrush}"
                CornerRadius="18"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                Effect="{StaticResource WindowShadow}">
            <Border.MouseLeftButtonDown>Panel_MouseLeftButtonDown</Border.MouseLeftButtonDown>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="18,14"
                        Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="46"
                                    Height="46"
                                    Margin="0,0,12,0">
                                <TextBlock Text=""
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center" MaxWidth="650">
                                <TextBlock Text="Detalle del equipo informático"
                                           Style="{StaticResource ThemeCardTitleStyle}"
                                           FontSize="20"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Resumen técnico, componentes y periféricos asociados"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxWidth="620" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button x:Name="BtnEditar"
                                    Style="{StaticResource ThemeHeaderActionButtonStyle}"
                                    Click="BtnEditar_Click"
                                    ToolTip="Editar"
                                    Margin="0,0,10,0"
                                    MinHeight="38">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" />
                                    <TextBlock Text="Editar" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource CloseButton}"
                                    Click="BtnCerrar_Click"
                                    ToolTip="Cerrar (Esc)"
                                    Width="38"
                                    Height="38"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <Grid Width="14" Height="14">
                                    <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource BackgroundAppBrush}"
                              Padding="24">
                    <StackPanel>
                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="320" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NombreEquipo, Mode=OneWay}"
                                                   Style="{StaticResource ThemeCardTitleStyle}"
                                                   FontSize="24" />
                                        <Border Margin="14,0,0,0"
                                                Padding="12,7"
                                                CornerRadius="10"
                                                Background="{Binding Estado, Mode=OneWay, Converter={StaticResource EstadoToColorConverter}}">
                                            <TextBlock Text="{Binding Estado, Mode=OneWay}"
                                                       Foreground="White"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Codigo, Mode=OneWay, StringFormat=Código {0}}"
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               Margin="0,6,0,0" />

                                    <TextBlock Text="Resumen técnico del activo y su trazabilidad principal."
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               Margin="0,10,0,0" />

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                            <StackPanel>
                                                <TextBlock Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding Marca, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding Modelo, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                                            <StackPanel>
                                                <TextBlock Text="Procesador" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding Procesador, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Sistema operativo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding SO, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="0" Margin="0,0,12,12">
                                            <StackPanel>
                                                <TextBlock Text="Serial" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding SerialNumber, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="AnyDesk" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding CodigoAnydesk, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="3" Grid.ColumnSpan="2"
                                                Padding="0,14,0,0"
                                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                BorderThickness="0,1,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Observaciones" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                <TextBlock Text="{Binding Observaciones, Mode=OneWay}"
                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource ThemeDetailSectionCardStyle}"
                                        Padding="18"
                                        Margin="0"
                                        Background="{DynamicResource BackgroundSurfaceBrush}">
                                    <StackPanel>
                                        <TextBlock Text="Asignación y compra"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   FontSize="16" />

                                        <TextBlock Text="Responsable del activo y datos de adquisición"
                                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="260" />

                                        <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                                Margin="0,14,0,10"
                                                Background="{DynamicResource BackgroundElevatedBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Asignación"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="15" />

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="108" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Asignado a" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UsuarioAsignado, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" />

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Anterior" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding UsuarioAsignadoAnterior, Mode=OneWay}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,12,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource ThemeDetailItemCardStyle}"
                                                Margin="0"
                                                Background="{DynamicResource BackgroundElevatedBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Compra"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="15" />

                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="108" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Costo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Costo, Mode=OneWay, StringFormat={}{0:C}}" Style="{StaticResource ThemeDetailValueStyle}" />

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FechaCompra, Mode=OneWay, StringFormat={}{0:dd/MM/yyyy}}" Style="{StaticResource ThemeDetailValueStyle}" Margin="0,12,0,0" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Componentes y periféricos"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="17" />
                                <TextBlock Text="Detalles técnicos agrupados para una lectura rápida y consistente."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Margin="0,4,0,0" />

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0"
                                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                                            Padding="18"
                                            Margin="0,0,8,8"
                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="Memoria RAM"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="16"
                                                           DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding SlotsRam.Count, Mode=OneWay, StringFormat={}{0} slots}"
                                                           DockPanel.Dock="Right"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding SlotsRam}"
                                                          ItemTemplate="{StaticResource RamItemTemplate}"
                                                          Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                                            Padding="18"
                                            Margin="8,0,0,8"
                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="Almacenamiento"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="16"
                                                           DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding Discos.Count, Mode=OneWay, StringFormat={}{0} discos}"
                                                           DockPanel.Dock="Right"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Discos}"
                                                          ItemTemplate="{StaticResource DiscoItemTemplate}"
                                                          Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0"
                                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                                            Padding="18"
                                            Margin="0,8,8,0"
                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="Conexiones de red"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="16"
                                                           DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding Conexiones.Count, Mode=OneWay, StringFormat={}{0} conexiones}"
                                                           DockPanel.Dock="Right"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Conexiones}"
                                                          ItemTemplate="{StaticResource ConexionItemTemplate}"
                                                          Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1"
                                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                                            Padding="18"
                                            Margin="8,8,0,0"
                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="Periféricos"
                                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                                           FontSize="16"
                                                           DockPanel.Dock="Left" />
                                                <TextBlock Text="{Binding Perifericos.Count, Mode=OneWay, StringFormat={}{0} periféricos}"
                                                           DockPanel.Dock="Right"
                                                           Style="{StaticResource ThemeDetailLabelStyle}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Perifericos}"
                                                          ItemTemplate="{StaticResource PerifericoItemTemplate}"
                                                          Margin="0,14,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
