<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Equipos.EquiposInformaticosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
        <conv:EstadoToColorConverter x:Key="EstadoToColorConverter" />
        <conv:EstadoToBoolConverter x:Key="EstadoToDadoDeBajaConverter" TargetEstado="DadoDeBaja" />
        <conv:EstadoToOpacityConverter x:Key="EstadoToOpacityConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource ThemeHeaderContainerStyle}"
                CornerRadius="14"
                Margin="10,10,10,8"
                Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="44"
                            Height="44"
                            CornerRadius="22"
                            Background="{DynamicResource PrimaryLightBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            Margin="0,0,12,0">
                        <TextBlock Text="🧰"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="20"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestión de Equipos"
                                   Style="{StaticResource ThemeSectionTitleStyle}" />
                        <TextBlock Text="Inventario, estados y mantenimiento de activos"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="⭱ Exportar"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Command="{Binding ExportarEquiposCommand}"
                            IsEnabled="{Binding CanExportarDatos}"
                            Opacity="{Binding CanExportarDatos, Converter={StaticResource BooleanToOpacityConverter}}"
                            Margin="0,0,8,0"
                            MinHeight="38" />

                    <Button Content="↻ Refrescar"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            Command="{Binding LoadEquiposCommand}"
                            Margin="0,0,8,0"
                            MinHeight="38" />

                    <Button Content="＋ Nuevo equipo"
                            Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                            Command="{Binding AgregarEquipoCommand}"
                            IsEnabled="{Binding CanCrearEquipo}"
                            Opacity="{Binding CanCrearEquipo, Converter={StaticResource BooleanToOpacityConverter}}"
                            MinHeight="38"
                            MinWidth="150" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,8"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Buscar"
                               Style="{StaticResource ThemeBodyTextStyle}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />

                    <TextBox Width="500"
                             Tag="Buscar por código, nombre, marca, sede o estado"
                             Text="{Binding FiltroEquipo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ThemeTextBoxStyle}"
                             VerticalAlignment="Center" />
                </StackPanel>

                <CheckBox Grid.Column="1"
                          Content="Mostrar bajas"
                          IsChecked="{Binding MostrarDadosDeBaja, Mode=TwoWay}"
                          Style="{StaticResource ThemeCheckBoxStyle}"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          Margin="16,0,0,0" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource ThemeElevatedCardStyle}"
                Margin="10,0,10,10"
                Padding="16">
            <DataGrid ItemsSource="{Binding EquiposView}"
                      SelectedItem="{Binding SelectedEquipo, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      Style="{StaticResource ThemeDataGridStyle}"
                      RowStyle="{StaticResource ThemeDataGridRowStyle}"
                      CellStyle="{StaticResource ThemeDataGridCellStyle}"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      RowHeight="40"
                      ColumnWidth="*"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.VirtualizationMode="Standard"
                      ScrollViewer.CanContentScroll="True"
                      BorderThickness="0"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True">

                <DataGrid.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                    <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código"
                                        Binding="{Binding Codigo}"
                                        Width="SizeToCells"
                                        MinWidth="110"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}"
                                        Width="*"
                                        MinWidth="220"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTextColumn Header="Marca"
                                        Binding="{Binding Marca}"
                                        Width="SizeToCells"
                                        MinWidth="130"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTextColumn Header="Clasificación"
                                        Binding="{Binding Clasificacion}"
                                        Width="SizeToCells"
                                        MinWidth="150"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTextColumn Header="Sede"
                                        Binding="{Binding Sede}"
                                        Width="SizeToCells"
                                        MinWidth="130"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTextColumn Header="Frecuencia Mtto"
                                        Binding="{Binding FrecuenciaMtto}"
                                        Width="SizeToCells"
                                        MinWidth="140"
                                        IsReadOnly="True"
                                        ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                    <DataGridTemplateColumn Header="Estado"
                                            Width="SizeToCells"
                                            MinWidth="160"
                                            IsReadOnly="True"
                                            SortMemberPath="EstadoOrden">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding Estado, TargetNullValue='Estado desconocido', FallbackValue='Estado desconocido'}">
                                    <Ellipse Width="12"
                                             Height="12"
                                             VerticalAlignment="Center"
                                             Fill="{Binding Estado, Converter={StaticResource EstadoToColorConverter}, TargetNullValue={StaticResource BorderDefaultBrush}, FallbackValue={StaticResource BorderDefaultBrush}}"
                                             Stroke="{DynamicResource BorderDefaultBrush}"
                                             StrokeThickness="0.5" />
                                    <TextBlock Text="{Binding Estado, TargetNullValue='Desconocido', FallbackValue='Desconocido'}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource ThemeDataGridTextStyle}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header=""
                                            Width="SizeToCells"
                                            MinWidth="100"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Detalles"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        Command="{Binding DataContext.VerDetallesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        MinWidth="88"
                                        Height="34"
                                        Padding="12,6"
                                        HorizontalAlignment="Center"
                                        Focusable="False"
                                        ToolTip="Ver detalles del equipo" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
