<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Equipos.GestionEquiposHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Equipos"
             xmlns:cronogramaViews="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Cronograma"
             xmlns:historialViews="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento"
             xmlns:mantenimientoViews="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Mantenimiento"
             xmlns:perifericosViews="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Views.Perifericos"
             xmlns:converters="clr-namespace:GestLog.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">
    
    <UserControl.Resources>
        <converters:PlanesStatsConverter x:Key="PlanesStatsConverter" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}" Margin="16">
        <Border Style="{StaticResource ThemeElevatedCardStyle}" Padding="14" CornerRadius="14">
        <TabControl x:Name="tabEquipos" Style="{StaticResource ThemeTabControlStyle}" SelectedIndex="0">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource ThemeTabItemStyle}" />
            </TabControl.Resources>
            <TabItem Header="Cronograma">
                <Border Background="{DynamicResource BackgroundSurfaceBrush}" Padding="0" CornerRadius="0 0 8 8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>                        <cronogramaViews:CronogramaDiarioView x:Name="cronogramaView" DataContext="{Binding CronogramaVm}" /><!-- Indicador de estadísticas de planes -->
                        <DockPanel Grid.Row="1" Margin="8">
                            <!-- Contador de planes (izquierda) -->
                            <TextBlock Text="{Binding DataContext.StatusMessage, ElementName=cronogramaView}" 
                                       FontWeight="Medium" 
                                       VerticalAlignment="Center" 
                                       Foreground="{DynamicResource TextBodyBrush}"
                                       FontSize="12" 
                                       DockPanel.Dock="Left" />
                            
                            <!-- Leyenda (derecha) -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <TextBlock Text="Leyenda:" FontWeight="SemiBold" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource TextBodyBrush}" FontSize="11" />
                                <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="2" Padding="3,1" Margin="0,0,6,0">
                                    <TextBlock Text="Pendiente" FontSize="9" Foreground="{DynamicResource TextBodyBrush}" />
                                </Border>
                                <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" CornerRadius="2" Padding="3,1" Margin="0,0,6,0">
                                    <TextBlock Text="Atrasado" FontSize="9" Foreground="{DynamicResource TextBodyBrush}" />
                                </Border>
                                <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1" CornerRadius="2" Padding="3,1">
                                    <TextBlock Text="Ejecutado" FontSize="9" Foreground="{DynamicResource TextBodyBrush}" />
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Equipos">
                <Border Background="{DynamicResource BackgroundSurfaceBrush}" Padding="0" CornerRadius="0 0 8 8">
                    <views:EquiposInformaticosView />
                </Border>
            </TabItem>

            <TabItem Header="Historial">
                <Border Background="{DynamicResource BackgroundSurfaceBrush}" Padding="0" CornerRadius="0 0 8 8">
                    <historialViews:HistorialEjecucionesView DataContext="{Binding HistorialVm}" />
                </Border>
            </TabItem>

            <TabItem Header="Periféricos">
                <Border Background="{DynamicResource BackgroundSurfaceBrush}" Padding="0" CornerRadius="0 0 8 8">
                    <perifericosViews:PerifericosView DataContext="{Binding PerifericosVm}" />
                </Border>
            </TabItem>

            <!-- ✅ NUEVO: Tab para Mantenimientos Correctivos -->
            <TabItem Header="Mantenimientos Correctivos">
                <Border Background="{DynamicResource BackgroundSurfaceBrush}" Padding="0" CornerRadius="0 0 8 8">
                    <mantenimientoViews:MantenimientosCorrectivosView DataContext="{Binding MantenimientosCorrectivosVm}" />
                </Border>
            </TabItem>
        </TabControl>
        </Border>
    </Grid>
</UserControl>
