<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Equipos.AgregarEquipoInformaticoView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:GestLog.Converters"
        xmlns:local="clr-namespace:GestLog.Behaviors"
        xmlns:modelsEntities="clr-namespace:GestLog.Modules.GestionEquiposInformaticos.Models.Entities"
        mc:Ignorable="d"
        Title="Agregar Equipo Informático"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        WindowStartupLocation="Manual"
        Height="820"
        Width="1360"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.Resources>
        <ResourceDictionary>
            <conv:TipoMemoriaTooltipConverter x:Key="TipoMemoriaTooltipConverter" />
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
            <conv:EstadoToButtonEnabledConverter x:Key="EstadoToButtonEnabledConverter" />
            <conv:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter" />
            <conv:TipoDiscoToStringConverter x:Key="TipoDiscoToStringConverter" />
            <conv:MultiBooleanToVisibilityConverter x:Key="MultiBooleanToVisibilityConverter" />
            <conv:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
            <conv:EstadoToBoolConverter x:Key="EstadoToEnReparacionConverter" TargetEstado="EnReparacion" />
            <conv:EstadoToVisibilityConverter x:Key="EstadoToVisibilityConverter" TargetEstado="EnReparacion" />

            <Style x:Key="FastTooltipStyle" TargetType="ToolTip">
                <Setter Property="OverridesDefaultStyle" Value="True" />
                <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate x:Key="SlotRamTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="0,0,10,0">
                                <TextBlock Text="RAM" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                            </Border>
                            <TextBlock Text="Slot" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                            <TextBlock Text="{Binding NumeroSlot}" Margin="6,0,0,0" Style="{StaticResource ThemeCardTitleStyle}" FontSize="16" />
                        </StackPanel>

                        <Button Grid.Row="0" Grid.Column="1"
                                Command="{Binding DataContext.EliminarRamCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Content="Eliminar"
                                Style="{StaticResource ThemeDangerButtonStyle}"
                                Width="90"
                                Height="32"
                                FontSize="13"
                                Padding="10,0"
                                IsEnabled="{Binding DataContext.CanEliminarRam, RelativeSource={RelativeSource AncestorType=Window}}"
                                Opacity="{Binding DataContext.CanEliminarRam, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToOpacityConverter}}" />

                        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="120" />
                                <ColumnDefinition Width="1*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
                                <TextBlock Text="Tipo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding TipoMemoria}" Style="{StaticResource ThemeTextBoxStyle}" Height="38" ToolTip="{Binding DataContext.TipoMemoriaTooltip, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,10">
                                <TextBlock Text="Capacidad (GB)" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding CapacidadGB}" Style="{StaticResource ThemeTextBoxStyle}" Height="38" HorizontalContentAlignment="Right" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
                                <TextBlock Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Marca}" Style="{StaticResource ThemeTextBoxStyle}" Height="38" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                <TextBlock Text="Frecuencia" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Frecuencia}" Style="{StaticResource ThemeTextBoxStyle}" Height="38" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                            <TextBlock Text="Observaciones" Style="{StaticResource ThemeDetailLabelStyle}" />
                            <TextBox Text="{Binding Observaciones}" Style="{StaticResource ThemeTextBoxStyle}" Height="76" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Row="3" Grid.ColumnSpan="2"
                                   Text="No ocupado"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource DangerBrush}"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding Ocupado, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate DataType="{x:Type modelsEntities:DiscoEntity}">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="0,0,10,0">
                                <TextBlock Text="Disco" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                            </Border>
                            <TextBlock Text="{Binding NumeroDisco, StringFormat='#{0}'}" Style="{StaticResource ThemeCardTitleStyle}" FontSize="16" />
                        </StackPanel>

                        <Button Grid.Row="0" Grid.Column="1"
                                Content="Eliminar"
                                Command="{Binding DataContext.EliminarDiscoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ThemeDangerButtonStyle}"
                                Width="90"
                                Height="32"
                                FontSize="13"
                                Padding="10,0"
                                IsEnabled="{Binding DataContext.CanEliminarDisco, RelativeSource={RelativeSource AncestorType=Window}}"
                                Opacity="{Binding DataContext.CanEliminarDisco, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToOpacityConverter}}" />

                        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="120" />
                                <ColumnDefinition Width="1*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
                                <TextBlock Text="Tipo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <ComboBox ItemsSource="{Binding DataContext.TiposDisco, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding Tipo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Style="{StaticResource ThemeComboBoxStyle}"
                                          Height="36" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,10">
                                <TextBlock Text="Capacidad (GB)" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding CapacidadGB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" HorizontalContentAlignment="Right" />
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
                                <TextBlock Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Marca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                <TextBlock Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Modelo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="ConexionTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="0,0,10,0">
                                <TextBlock Text="Red" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                            </Border>
                            <TextBlock Text="{Binding Adaptador, TargetNullValue=Conexión}" Style="{StaticResource ThemeCardTitleStyle}" FontSize="16" TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Row="0" Grid.Column="1"
                                Content="Eliminar"
                                Command="{Binding DataContext.EliminarConexionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ThemeDangerButtonStyle}"
                                Width="90"
                                Height="32"
                                FontSize="13"
                                Padding="10,0" />

                        <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" MinWidth="120" />
                                <ColumnDefinition Width="1*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
                                <TextBlock Text="Adaptador" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Adaptador, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,10">
                                <TextBlock Text="MAC" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding DireccionMAC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
                                <TextBlock Text="IPv4" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding DireccionIPv4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,0">
                                <TextBlock Text="Máscara / Gateway" Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding MascaraSubred, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ThemeTextBoxStyle}" Height="36" ToolTip="Máscara de subred" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="PerifericoAsignadoTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Codigo}" Style="{StaticResource ThemeCardTitleStyle}" FontSize="16" />
                                    <TextBlock Text="{Binding Dispositivo}" Style="{StaticResource ThemeSectionSubtitleStyle}" Margin="0,3,0,0" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource ThemeDetailChipStyle}" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding EstadoDescripcion}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                </Border>
                            </Grid>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Marca, StringFormat=Marca: {0}}" Style="{StaticResource ThemeSectionSubtitleStyle}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Modelo, StringFormat=Modelo: {0}}" Style="{StaticResource ThemeSectionSubtitleStyle}" TextWrapping="Wrap" />
                            </UniformGrid>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Desasignar"
                                Command="{Binding DataContext.DesasignarPerifericoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ThemeDangerButtonStyle}"
                                Width="110"
                                Height="34"
                                FontSize="13"
                                Padding="10,0"
                            Margin="16,0,0,0"
                                VerticalAlignment="Top"
                                IsEnabled="{Binding DataContext.CanDesasignarPeriferico, RelativeSource={RelativeSource AncestorType=Window}}"
                                Opacity="{Binding DataContext.CanDesasignarPeriferico, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToOpacityConverter}}" />
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="PerifericoDisponibleTemplate">
                <Border Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Codigo}" Style="{StaticResource ThemeCardTitleStyle}" FontSize="16" />
                                    <TextBlock Text="{Binding Dispositivo}" Style="{StaticResource ThemeSectionSubtitleStyle}" Margin="0,3,0,0" TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1" Style="{StaticResource ThemeDetailChipStyle}" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding EstadoDescripcion}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                </Border>
                            </Grid>

                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <TextBlock Text="{Binding Marca, StringFormat=Marca: {0}}" Style="{StaticResource ThemeSectionSubtitleStyle}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Modelo, StringFormat=Modelo: {0}}" Style="{StaticResource ThemeSectionSubtitleStyle}" TextWrapping="Wrap" />
                            </UniformGrid>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Asignar"
                                Command="{Binding DataContext.AsignarPerifericoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource ThemePrimaryButtonStyle}"
                                Width="110"
                                Height="34"
                                FontSize="13"
                                Padding="10,0"
                            Margin="16,0,0,0"
                                VerticalAlignment="Top"
                                IsEnabled="{Binding DataContext.CanGuardarEquipo, RelativeSource={RelativeSource AncestorType=Window}}"
                                Opacity="{Binding DataContext.CanGuardarEquipo, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToOpacityConverter}}" />
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource ModalOverlayBrush}" MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border x:Name="Card"
                Width="1340"
                MaxHeight="900"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="24"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="24,24,0,0"
                        Padding="20,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}" Width="52" Height="52" Margin="0,0,14,0">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Style="{StaticResource ThemeCardIconTextStyle}" FontSize="20" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Agregar equipo informático"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                <TextBlock Text="Editar equipo informático"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock Text="Completa identificación, datos técnicos y componentes."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12"
                                           Margin="0,4,0,0" />
                                <Border Style="{StaticResource ThemeDetailChipStyle}"
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding IsLoadingRam, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ProgressBar IsIndeterminate="True" Width="72" Height="6" Margin="0,0,10,0" />
                                        <TextBlock Text="Obteniendo campos automáticos..."
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Button x:Name="BtnCerrarHeader"
                                Grid.Column="1"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="38"
                                Height="38"
                                ToolTip="Cerrar (Esc)"
                                Click="BtnCerrar_Click"
                                VerticalAlignment="Center">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Datos de identificación" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                    <TextBlock Text="Código interno, usuario asignado, estado y fechas de compra." Style="{StaticResource ThemeSectionSubtitleStyle}" Margin="0,6,0,14" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
                                            <TextBlock Text="Código *" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBox Text="{Binding Codigo}" CharacterCasing="Upper" Style="{StaticResource ThemeTextBoxStyle}" Height="40" ToolTip="Código interno del equipo" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,10">
                                            <TextBlock Text="Conexión remota" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBox Text="{Binding CodigoAnydesk}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,10">
                                            <TextBlock Text="Usuario asignado *" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <ComboBox IsEditable="True"
                                                      ItemsSource="{Binding PersonasFiltradas}"
                                                      SelectedItem="{Binding PersonaAsignada}"
                                                      Text="{Binding FiltroPersonaAsignada, Mode=TwoWay}"
                                                      DisplayMemberPath="NombreCompleto"
                                                      Style="{StaticResource ThemeComboBoxStyle}"
                                                      Height="40"
                                                      ToolTip="Buscar y seleccionar usuario" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,10">
                                            <TextBlock Text="Estado" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <ComboBox SelectedValue="{Binding Estado, Mode=TwoWay}"
                                                      SelectedValuePath="Content"
                                                      Style="{StaticResource ThemeComboBoxStyle}"
                                                      Height="40">
                                                <ComboBoxItem Content="Activo" />
                                                <ComboBoxItem Content="Dado de baja" />
                                                <ComboBoxItem Content="En reparación" />
                                                <ComboBoxItem Content="En mantenimiento" />
                                                <ComboBoxItem Content="Inactivo" />
                                            </ComboBox>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,10,0">
                                            <TextBlock Text="Costo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBox Text="{Binding Costo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:C0}, ConverterCulture=es-CO}"
                                                     Style="{StaticResource ThemeTextBoxStyle}"
                                                     Height="40"
                                                     HorizontalContentAlignment="Right" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Grid.Row="2" Margin="10,0,0,0">
                                            <TextBlock Text="Fecha de compra" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="48" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding FechaCompra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DateTimeToStringConverter}}"
                                                         Style="{StaticResource ThemeTextBoxStyle}"
                                                         Height="40"
                                                         local:DateMaskBehavior.EnableMask="True"
                                                         HorizontalContentAlignment="Center"
                                                         ToolTip="dd/MM/yyyy" />
                                                <DatePicker Grid.Column="2"
                                                            SelectedDate="{Binding FechaCompra, Mode=TwoWay, StringFormat=dd/MM/yyyy}"
                                                            Style="{StaticResource ThemeDatePickerStyle}"
                                                            Height="40"
                                                            Width="48"
                                                            Language="es-ES">
                                                    <DatePicker.Resources>
                                                        <Style TargetType="DatePickerTextBox">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </Style>
                                                    </DatePicker.Resources>
                                                </DatePicker>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource ThemeDetailSectionCardStyle}" Margin="16,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Acciones rápidas" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                    <TextBlock Text="Detecta datos, valida permisos y ejecuta acciones sin salir del formulario." Style="{StaticResource ThemeSectionSubtitleStyle}" Margin="0,6,0,14" TextWrapping="Wrap" />

                                    <Button Content="Obtener campos automáticos"
                                            Command="{Binding ObtenerCamposAutomaticosCommand}"
                                            IsEnabled="{Binding CanObtenerCamposAutomaticos}"
                                            Opacity="{Binding CanObtenerCamposAutomaticos, Converter={StaticResource BooleanToOpacityConverter}}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Height="40"
                                            Margin="0,0,0,10"
                                            ToolTip="Detectar marca, RAM, discos, conexiones y otros campos automáticamente" />

                                    <Border Style="{StaticResource ThemeDetailItemCardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Estado actual" Style="{StaticResource ThemeDetailLabelStyle}" />
                                            <TextBlock Text="{Binding Estado, TargetNullValue=Activo}" Style="{StaticResource ThemeCardTitleStyle}" FontSize="18" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding DarDeBajaButtonTooltip, TargetNullValue=El equipo puede darse de baja desde esta pantalla.}"
                                                       Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,8,0,0" />

                                            <Button Content="Dar de baja"
                                                    Command="{Binding DarDeBajaCommand}"
                                                    Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    IsEnabled="{Binding Estado, Converter={StaticResource EstadoToButtonEnabledConverter}}"
                                                    ToolTip="{Binding DarDeBajaButtonTooltip}"
                                                    Style="{StaticResource ThemeDangerButtonStyle}"
                                                    Height="38"
                                                    Margin="0,14,0,0" />

                                            <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="0,14,0,0">
                                                <TextBlock Text="Guardado y baja mantienen la lógica existente" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" TextWrapping="Wrap" />
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Datos técnicos" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                <TextBlock Text="Especificaciones generales del equipo, sin interferir con el flujo de captura." Style="{StaticResource ThemeSectionSubtitleStyle}" Margin="0,6,0,14" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
                                        <TextBlock Text="Nombre del equipo *" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding NombreEquipo}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" ToolTip="Nombre visible en red" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0,0,10">
                                        <TextBlock Text="Sede" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <ComboBox SelectedValue="{Binding Sede, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Content"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  Height="40"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Administrativa - Barranquilla" />
                                            <ComboBoxItem Content="Taller - Barranquilla" />
                                            <ComboBoxItem Content="Bodega - Bayunca" />
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,10,10">
                                        <TextBlock Text="Marca" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding Marca}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="10,0,0,10">
                                        <TextBlock Text="Modelo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding Modelo}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,10,10">
                                        <TextBlock Text="Sistema operativo" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding So}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="2" Margin="10,0,0,10">
                                        <TextBlock Text="Serial" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding SerialNumber}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,10,0">
                                        <TextBlock Text="Procesador" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding Procesador}" Style="{StaticResource ThemeTextBoxStyle}" Height="40" IsReadOnly="{Binding IsLoadingRam}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="3" Margin="10,0,0,0">
                                        <TextBlock Text="Observaciones" Style="{StaticResource ThemeDetailLabelStyle}" />
                                        <TextBox Text="{Binding Observaciones}" Style="{StaticResource ThemeTextBoxStyle}" Height="92" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1.1*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource ThemeDetailSectionCardStyle}" Margin="0,0,12,0" IsEnabled="{Binding IsLoadingRam, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="Memoria RAM" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                        <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ListaRam.Count, StringFormat={}{0} módulos}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                        </Border>
                                    </StackPanel>
                                    <Button Content="Agregar RAM"
                                            Command="{Binding AgregarRamCommand}"
                                            IsEnabled="{Binding CanGuardarEquipo}"
                                            Opacity="{Binding CanGuardarEquipo, Converter={StaticResource BooleanToOpacityConverter}}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,12" />
                                    <ItemsControl ItemsSource="{Binding ListaRam}" ItemTemplate="{StaticResource SlotRamTemplate}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource ThemeDetailSectionCardStyle}" Margin="0,0,12,0" IsEnabled="{Binding IsLoadingRam, Converter={StaticResource InverseBooleanConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="Discos" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                        <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ListaDiscos.Count, StringFormat={}{0} discos}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                        </Border>
                                    </StackPanel>
                                    <Button Content="Agregar disco"
                                            Command="{Binding AgregarDiscoManualCommand}"
                                            IsEnabled="{Binding CanAgregarDiscoManual}"
                                            Opacity="{Binding CanAgregarDiscoManual, Converter={StaticResource BooleanToOpacityConverter}}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,12" />
                                    <ItemsControl ItemsSource="{Binding ListaDiscos}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource ThemeDetailSectionCardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="Conexiones de red" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                        <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ListaConexiones.Count, StringFormat={}{0} conexiones}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                        </Border>
                                    </StackPanel>
                                    <Button Content="Agregar conexión manual"
                                            Command="{Binding AgregarConexionManualCommand}"
                                            IsEnabled="{Binding CanAgregarConexionManualFormulario}"
                                            Opacity="{Binding CanAgregarConexionManualFormulario, Converter={StaticResource BooleanToOpacityConverter}}"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Height="36"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,12" />
                                    <ItemsControl ItemsSource="{Binding ListaConexiones}" ItemTemplate="{StaticResource ConexionTemplate}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Periféricos" Style="{StaticResource ThemeSectionTitleStyle}" FontSize="16" />
                                        <TextBlock Text="Asignados y disponibles en dos paneles paralelos para facilitar la revisión y la asignación."
                                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1" Style="{StaticResource ThemeDetailChipStyle}" VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PerifericosAsignados.Count, StringFormat={}{0} asignados}"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0" />
                                            <TextBlock Text=" / " Style="{StaticResource ThemeDetailLabelStyle}" Margin="6,0" />
                                            <TextBlock Text="{Binding PerifericosDisponibles.Count, StringFormat={}{0} disponibles}"
                                                       Style="{StaticResource ThemeDetailLabelStyle}"
                                                       Margin="0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource ThemeDetailItemCardStyle}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock Text="Asignados" Style="{StaticResource ThemeCardTitleStyle}" FontSize="18" />
                                                <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding PerifericosAsignados.Count, StringFormat={}{0} items}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="No hay periféricos asignados"
                                                       Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                       Margin="0,0,0,10"
                                                       Visibility="{Binding PerifericosAsignados.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                                            <ItemsControl ItemsSource="{Binding PerifericosAsignados}" ItemTemplate="{StaticResource PerifericoAsignadoTemplate}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource ThemeDetailItemCardStyle}" Margin="12,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock Text="Disponibles" Style="{StaticResource ThemeCardTitleStyle}" FontSize="18" />
                                                <Border Style="{StaticResource ThemeDetailChipStyle}" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding PerifericosDisponibles.Count, StringFormat={}{0} items}" Style="{StaticResource ThemeDetailLabelStyle}" Margin="0" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="Selecciona un periférico para asignarlo al equipo"
                                                       Style="{StaticResource ThemeSectionSubtitleStyle}"
                                                       Margin="0,0,0,10" />
                                            <ItemsControl ItemsSource="{Binding PerifericosDisponibles}" ItemTemplate="{StaticResource PerifericoDisponibleTemplate}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderStrongBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24"
                        Padding="22,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancelar"
                                Content="Cancelar"
                                Command="{Binding CancelarCommand}"
                                Click="BtnCancelar_Click"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                Height="38"
                                MinWidth="130"
                                Margin="0,0,12,0" />
                        <Button x:Name="BtnGuardar"
                                Content="Guardar"
                                Command="{Binding GuardarCommand}"
                                Click="BtnGuardar_Click"
                                Style="{StaticResource ThemePrimaryButtonStyle}"
                                Height="38"
                                MinWidth="130"
                            IsEnabled="{Binding CanGuardarFormulario}"
                            Opacity="{Binding CanGuardarFormulario, Converter={StaticResource BooleanToOpacityConverter}}" />
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>