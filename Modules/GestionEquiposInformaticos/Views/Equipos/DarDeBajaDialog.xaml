<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Equipos.DarDeBajaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Observación de baja"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Language="es-ES"
        Style="{StaticResource ModalWindowBase}">

    <Grid Background="{DynamicResource ModalOverlayBrush}">
        <Border Width="760"
                MaxWidth="860"
                Margin="24"
                Background="{DynamicResource BackgroundAppBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True"
                Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="18,14"
                        Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="46"
                                    Height="46"
                                    Margin="0,0,12,0">
                                <TextBlock Text=""
                                           FontFamily="Segoe MDL2 Assets"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center" MaxWidth="560">
                                <TextBlock Text="Dar de baja equipo"
                                           Style="{StaticResource ThemeCardTitleStyle}"
                                           FontSize="20"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Registra una observación clara para dejar trazabilidad de la baja del activo."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxWidth="540" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Click="Cancel_Click"
                                ToolTip="Cerrar"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <Grid Width="16" Height="16">
                                <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="16" Y1="0" X2="0" Y2="16" Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="24,20,24,24">
                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Observación de baja"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="16"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="Por favor indique la observación para la baja del equipo."
                                           Style="{StaticResource ThemeBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />

                                <TextBlock Text="Observación"
                                           Style="{StaticResource ThemeDetailLabelStyle}" />

                                <TextBox x:Name="ObservacionTextBox"
                                         Text="{Binding Observacion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         MinHeight="130"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Tag="Ej. Motivo de baja, estado del equipo, destino o condición final" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Padding="24"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Width="128"
                                Height="40"
                                Margin="0,0,12,0"
                                Click="Cancel_Click"
                                Content="Cancelar"
                                Style="{StaticResource ThemeSecondaryButtonStyle}" />
                        <Button Width="132"
                                Height="40"
                                Click="Ok_Click"
                                Content="Aceptar"
                                Style="{StaticResource ThemePrimaryButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
