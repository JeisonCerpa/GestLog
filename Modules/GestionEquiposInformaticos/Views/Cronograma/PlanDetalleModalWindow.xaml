<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Cronograma.PlanDetalleModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Detalle del Plan de Mantenimiento"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="PlanMetricCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailItemCardStyle}">
            <Setter Property="MinHeight" Value="98" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="PlanMetricLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource ThemeDetailLabelStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="PlanMetricValueStyle" TargetType="TextBlock" BasedOn="{StaticResource ThemeDetailValueStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="PlanStatusBadgeStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailChipStyle}">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DetalleEstadoTexto}" Value="Ejecutado">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetalleEstadoTexto}" Value="Atrasado">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetalleEstadoTexto}" Value="Pendiente">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DetalleEstadoTexto}" Value="En Progreso">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlanStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SummaryBlockStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailSectionCardStyle}">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="ChecklistStateBadgeStyle" TargetType="Border" BasedOn="{StaticResource ThemeDetailChipStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Estado}" Value="Ejecutado">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Atrasado">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Estado}" Value="En Progreso">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ModalOverlayBrush}"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown">
        <Border x:Name="Card"
                Width="860"
                MaxHeight="760"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                CornerRadius="18"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                Effect="{DynamicResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        CornerRadius="18,18,0,0"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                                    Width="48"
                                    Height="48"
                                    Margin="0,0,14,0">
                                <TextBlock Text=""
                                           FontFamily="Segoe MDL2 Assets"
                                           Style="{StaticResource ThemeCardIconTextStyle}"
                                           FontSize="18" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Detalle del Plan de Mantenimiento"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="19"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Resumen ejecutivo y trazabilidad del plan"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="✕"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Margin="0,0,0,0"
                                ToolTip="Cerrar"
                                Click="CloseButton_Click" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource PlanMetricCardStyle}"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Código"
                                           Style="{StaticResource PlanMetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPlanDetalle.Codigo}"
                                           Style="{StaticResource PlanMetricValueStyle}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource PlanMetricCardStyle}"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Equipo"
                                           Style="{StaticResource PlanMetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPlanDetalle.Nombre}"
                                           Style="{StaticResource PlanMetricValueStyle}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource PlanMetricCardStyle}"
                                Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Asignado a / Sede"
                                           Style="{StaticResource PlanMetricLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPlanDetalle.Sede}"
                                           Style="{StaticResource PlanMetricValueStyle}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3"
                                Style="{StaticResource PlanMetricCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Estado"
                                           Style="{StaticResource PlanMetricLabelStyle}" />
                                <Border Style="{StaticResource PlanStatusBadgeStyle}">
                                    <TextBlock Text="{Binding DetalleEstadoTexto}"
                                               Style="{StaticResource PlanStatusTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20"
                              Background="{DynamicResource BackgroundAppBrush}">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="0.9*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Style="{StaticResource SummaryBlockStyle}"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Border DockPanel.Dock="Left"
                                                Style="{StaticResource ThemeCardIconCircleStyle}"
                                                Width="36"
                                                Height="36"
                                                Margin="0,0,12,0">
                                            <TextBlock Text=""
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Style="{StaticResource ThemeCardIconTextStyle}"
                                                       FontSize="14" />
                                        </Border>
                                        <TextBlock Text="Fechas clave"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Fecha objetivo"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,12,10" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding DetalleFechaObjetivo, StringFormat=dd/MM/yyyy}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   Margin="0,0,0,10" />

                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="0"
                                                   Text="Fecha ejecución"
                                                   Style="{StaticResource ThemeDetailLabelStyle}"
                                                   Margin="0,0,12,0" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding DetalleFechaEjecucion, StringFormat=dd/MM/yyyy HH:mm}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   Margin="0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource SummaryBlockStyle}"
                                    Margin="8,0,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Border DockPanel.Dock="Left"
                                                Style="{StaticResource ThemeCardIconCircleStyle}"
                                                Width="36"
                                                Height="36"
                                                Margin="0,0,12,0">
                                            <TextBlock Text=""
                                                       FontFamily="Segoe MDL2 Assets"
                                                       Style="{StaticResource ThemeCardIconTextStyle}"
                                                       FontSize="14" />
                                        </Border>
                                        <TextBlock Text="Resumen del plan"
                                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>

                                    <Border Background="{DynamicResource BackgroundAppBrush}"
                                            BorderBrush="{DynamicResource BorderLightBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16">
                                        <TextBlock Text="{Binding DetalleResumen}"
                                                   Style="{StaticResource ThemeDetailValueStyle}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Padding="20"
                                Margin="0,0,0,0">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,16">
                                    <Border DockPanel.Dock="Left"
                                            Style="{StaticResource ThemeCardIconCircleStyle}"
                                            Width="36"
                                            Height="36"
                                            Margin="0,0,12,0">
                                        <TextBlock Text=""
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                                   FontSize="14" />
                                    </Border>
                                    <TextBlock Text="Lista de verificación"
                                               Style="{StaticResource ThemeSectionTitleStyle}"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <Border CornerRadius="12"
                                        BorderBrush="{DynamicResource BorderLightBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource BackgroundSurfaceBrush}">
                                    <DataGrid ItemsSource="{Binding DetalleChecklist}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserReorderColumns="False"
                                              CanUserResizeColumns="True"
                                              CanUserSortColumns="False"
                                              RowHeight="42"
                                              ColumnWidth="*"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.VirtualizationMode="Standard"
                                              ScrollViewer.CanContentScroll="True"
                                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="ChecklistGrid_PreviewMouseWheel"
                                              Style="{StaticResource ThemeDataGridStyle}"
                                              BorderThickness="0"
                                              SnapsToDevicePixels="True"
                                              UseLayoutRounding="True">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource ThemeDataGridColumnHeaderStyle}" />
                                            <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemeDataGridRowStyle}" />
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource ThemeDataGridCellStyle}" />
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                                            <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                                        </DataGrid.Resources>

                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"
                                                                Binding="{Binding Id}"
                                                                Width="70"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                                            <DataGridTextColumn Header="Descripción"
                                                                Binding="{Binding Descripcion}"
                                                                Width="*"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource ThemeDataGridTextStyle}" />

                                            <DataGridTemplateColumn Header="Estado"
                                                                    Width="130"
                                                                    IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border>
                                                            <Border.Style>
                                                                <Style TargetType="Border" BasedOn="{StaticResource ChecklistStateBadgeStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Pendiente">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Estado}"
                                                                       Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <DataGridTextColumn Header="Observaciones"
                                                                Binding="{Binding Observacion}"
                                                                Width="220"
                                                                IsReadOnly="True"
                                                                ElementStyle="{StaticResource ThemeDataGridTextStyle}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,18,18"
                        Padding="20,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cerrar"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                MinWidth="110"
                                Height="38"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
