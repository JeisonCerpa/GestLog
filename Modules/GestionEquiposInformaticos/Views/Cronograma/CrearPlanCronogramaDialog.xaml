<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Cronograma.CrearPlanCronogramaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:GestLog.Converters"
        Title="Crear Plan de Cronograma"
        Width="1160"
        Height="820"
        MinWidth="1060"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        KeyDown="CrearPlanCronogramaDialog_KeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.BitmapScalingMode="HighQuality"
        RenderOptions.ClearTypeHint="Enabled">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid"
        Background="#99000000"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="1080"
                MaxHeight="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource BackgroundAppBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="24"
                Padding="0"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        CornerRadius="24,24,0,0"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="52"
                                    Height="52"
                                    Margin="0,0,16,0"
                                    CornerRadius="16"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="📋"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Crear Plan de Cronograma"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           FontSize="21" />
                                <TextBlock Text="Diseña el plan semanal con equipo, día de ejecución y checklist desde una experiencia premium"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource ThemeCloseButtonStyle}"
                                Click="BtnCancelar_Click"
                                ToolTip="Cerrar (Esc)"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                            <TextBlock Text="✕"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="24"
                      UseLayoutRounding="True"
                      SnapsToDevicePixels="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                            Padding="16"
                            Margin="0,0,0,14">
                        <TextBlock x:Name="InfoSemanaTextBlock"
                                   Text="Semana actual"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,0,14,0">
                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,0,14"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Datos principales"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="Código del equipo *"
                                           Style="{StaticResource ThemeDetailLabelStyle}" />
                                <ComboBox Margin="0,6,0,12"
                                          Padding="10,8"
                                          ItemsSource="{Binding EquiposFiltrados}"
                                          SelectedItem="{Binding EquipoSeleccionado}"
                                          SelectedValuePath="Codigo"
                                          SelectedValue="{Binding SelectedEquipoCodigo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Text="{Binding FiltroEquipo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          Style="{StaticResource ThemeComboBoxStyle}"
                                          ToolTip="Escribe para filtrar por código, nombre o usuario y selecciona un equipo de la lista.">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="Día de ejecución"
                                           Style="{StaticResource ThemeDetailLabelStyle}" />
                                <ComboBox Margin="0,6,0,0"
                                          Padding="10,8"
                                          ItemsSource="{Binding DiasDisponibles}"
                                          SelectedValue="{Binding DiaEjecucion, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Valor"
                                          DisplayMemberPath="Nombre"
                                          Style="{StaticResource ThemeComboBoxStyle}"
                                          ToolTip="Día preferido para ejecutar el plan" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="Datos adicionales"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,12" />

                                <TextBlock Text="Descripción del plan"
                                           Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,12"
                                         Padding="12,10"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="72"
                                         ToolTip="Describe el alcance del plan" />

                                <TextBlock Text="Responsable"
                                           Style="{StaticResource ThemeDetailLabelStyle}" />
                                <TextBox Text="{Binding Responsable, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,0"
                                         Padding="12,10"
                                         Style="{StaticResource ThemeTextBoxStyle}"
                                         ToolTip="Responsable sugerido para la ejecución" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Checklist de tareas"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           FontSize="18"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="Añade o ajusta las tareas antes de guardar."
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                Style="{StaticResource ThemeElevatedCardStyle}"
                                Background="{DynamicResource BackgroundSurfaceBrush}"
                                    Margin="0,12,0,10"
                                    Padding="10,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Text="{Binding NuevaTareaTexto, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10,8"
                                             Margin="0,0,12,0"
                                             Style="{StaticResource ThemeTextBoxStyle}"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Escribe una nueva tarea" />
                                    <Button Grid.Column="1"
                                            Content="Agregar"
                                            Command="{Binding AgregarTareaCommand}"
                                            Padding="14,6"
                                            MinHeight="34"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            ToolTip="Agregar la tarea al checklist" />
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="360"
                                          Padding="0"
                                          Margin="0">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                                    <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                                </ScrollViewer.Resources>
                                <ItemsControl ItemsSource="{Binding TareasChecklist}">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                            <Setter Property="Margin" Value="0,0,0,6" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6"
                                                    Background="{DynamicResource BackgroundAppBrush}"
                                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    MinHeight="44">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Text="{Binding Descripcion, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,10,0"
                                                             Padding="8,4"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             Style="{StaticResource ThemeTextBoxStyle}"
                                                             VerticalContentAlignment="Center"
                                                             AcceptsReturn="False"
                                                             TextWrapping="NoWrap"
                                                             MinHeight="28"
                                                             ToolTip="Editar descripción de la tarea" />

                                                    <Button Grid.Column="1"
                                                            Content="✕"
                                                            Command="{Binding DataContext.EliminarTareaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            Style="{StaticResource ThemeDangerButtonStyle}"
                                                            ToolTip="Eliminar esta tarea" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource ThemeDetailSectionCardStyle}"
                            Padding="16"
                            Margin="0,14,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="Cancelar"
                                        Name="BtnCancelar"
                                        Padding="16,8"
                                        MinWidth="116"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        Click="BtnCancelar_Click" />
                                <Button Command="{Binding CrearPlanCommand}"
                                        Padding="16,8"
                                        MinWidth="132"
                                        Style="{StaticResource ThemePrimaryButtonStyle}"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📋"
                                                       Margin="0,0,8,0"
                                                       Visibility="{Binding IsSaving, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                            <TextBlock Text="⏳"
                                                       Margin="0,0,8,0"
                                                       Visibility="{Binding IsSaving, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Text="{Binding IsSaving, Converter={StaticResource BooleanToStringConverter}, ConverterParameter='Creando...|Crear Plan'}" />
                                        </StackPanel>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
