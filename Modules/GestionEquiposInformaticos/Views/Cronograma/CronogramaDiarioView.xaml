<UserControl x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Cronograma.CronogramaDiarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestLog.Converters"
             KeyDown="CronogramaDiarioView_KeyDown"
             Background="{DynamicResource BackgroundAppBrush}">
    <UserControl.Resources>
        <converters:CronogramaTipoToBackgroundConverter x:Key="CronogramaTipoToBackgroundConverter" />
        <converters:CronogramaTipoToBorderConverter x:Key="CronogramaTipoToBorderConverter" />
        <converters:CronogramaTipoToButtonTextConverter x:Key="CronogramaTipoToButtonTextConverter" />
        <converters:PlanEjecucionEstadoToBackgroundConverter x:Key="PlanEjecucionEstadoToBackgroundConverter" />
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
            Margin="16,16,16,10"
            Padding="18,12"
                CornerRadius="16"
                Style="{StaticResource ThemeHeaderContainerStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource ThemeCardIconCircleStyle}"
                            Width="40"
                            Height="40"
                            Margin="0,0,14,0">
                        <TextBlock Text="📅"
                                   FontFamily="Segoe UI Emoji"
                                   Style="{StaticResource ThemeCardIconTextStyle}"
                                   FontSize="20" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cronograma Diario"
                                   Style="{StaticResource ThemeSectionTitleStyle}"
                                   FontSize="19"
                                   Margin="0,0,0,2" />
                        <TextBlock Text="Gestión semanal de mantenimientos y ejecuciones"
                                   Style="{StaticResource ThemeSectionSubtitleStyle}"
                                   FontSize="11" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="CalendarButton"
                            Click="CalendarButton_Click"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            MinHeight="38"
                            Padding="12,8"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📅"
                                       FontFamily="Segoe UI Emoji"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="SelectedWeekText"
                                       Text="Semana 1, 2024"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="▾"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>

                    <Button Content="Gestionar Planes"
                            Command="{Binding GestionarPlanesCommand}"
                            Style="{StaticResource ThemeHeaderActionButtonStyle}"
                            MinHeight="38" />
                </StackPanel>

                <Popup x:Name="CalendarPopup"
                       PlacementTarget="{Binding ElementName=CalendarButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Width="320"
                            Padding="16"
                            CornerRadius="16"
                            Background="{DynamicResource BackgroundSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            Effect="{DynamicResource ThemeCardShadow}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="PrevMonthButton"
                                        Content="‹"
                                        Click="PrevMonthButton_Click"
                                        Width="34"
                                        Height="34"
                                        Padding="0"
                                        Style="{StaticResource ThemeHeaderActionButtonStyle}" />

                                <TextBlock x:Name="MonthYearText"
                                           Grid.Column="1"
                                           Text="Año 2024"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           FontSize="13"
                                           FontWeight="SemiBold" />

                                <Button x:Name="NextMonthButton"
                                        Grid.Column="2"
                                        Content="›"
                                        Click="NextMonthButton_Click"
                                        Width="34"
                                        Height="34"
                                        Padding="0"
                                        Style="{StaticResource ThemeHeaderActionButtonStyle}" />
                            </Grid>

                            <ListBox x:Name="WeekSelector"
                                     Height="220"
                                     SelectionMode="Single"
                                     SelectionChanged="WeekSelector_SelectionChanged"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Style="{StaticResource ThemeDetailItemCardStyle}"
                                                            Padding="12,10"
                                                            Margin="0"
                                                            Background="{DynamicResource BackgroundSurfaceBrush}">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource BackgroundHoverBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="BorderBrush"
                                                                    Value="{DynamicResource PrimaryBrush}" />
                                                            <Setter TargetName="ItemBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource PrimaryLightBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding WeekNumber, StringFormat=Semana {0}}"
                                                       Style="{StaticResource ThemeBodyTextStyle}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Margin="0,0,12,0" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DateRange}"
                                                       Style="{StaticResource ThemeBodyTextStyle}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="16,0,16,16"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Days}"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch"
                          SnapsToDevicePixels="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="5" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,12,0"
                                Padding="18,16"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource ThemeInteractiveCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />

                                    <Border Grid.Column="1"
                                            Style="{StaticResource ThemeDetailChipStyle}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Items.Count, StringFormat={}{0} mantenimientos}"
                                                   Style="{StaticResource ThemeBodyTextStyle}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Border>
                                </Grid>

                                <Separator Grid.Row="1"
                                           Margin="0,10,0,8"
                                           Opacity="0.6" />

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="No hay mantenimientos"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,8"
                                               Style="{StaticResource ThemeBodyTextStyle}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="10"
                                               Visibility="{Binding Items.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="0"
                                                  Margin="0">
                                        <ItemsControl ItemsSource="{Binding Items}"
                                                      HorizontalContentAlignment="Stretch">
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                    <Setter Property="Margin" Value="0,0,0,4" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="6"
                                                            HorizontalAlignment="Stretch"
                                                            Style="{StaticResource ThemeDetailItemCardStyle}"
                                                            Background="{DynamicResource BackgroundSurfaceBrush}"
                                                            BorderBrush="{Binding Converter={StaticResource PlanEjecucionEstadoToBackgroundConverter}}"
                                                            BorderThickness="1.5"
                                                            ToolTip="{Binding PlanEjecutadoSemana, Converter={StaticResource BooleanToStringConverter}, ConverterParameter=Ejecutado|Pendiente}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0"
                                                                        Margin="0,0,6,0"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Nombre}"
                                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Sede}"
                                                                           Style="{StaticResource ThemeBodyTextStyle}"
                                                                           FontSize="9"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>

                                                            <Button Grid.Column="1"
                                                                    Content="{Binding Converter={StaticResource CronogramaTipoToButtonTextConverter}}"
                                                                    Padding="6,2"
                                                                    MinHeight="24"
                                                                    FontSize="9"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right"
                                                                    Command="{Binding DataContext.OpenRegistrarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Cursor="Hand"
                                                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                                                    Visibility="{Binding MostrarBotonEjecutar, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                            <Button Grid.Column="1"
                                                                    Content="Ver"
                                                                    ToolTip="Ver detalle ejecución"
                                                                    Padding="6,2"
                                                                    MinHeight="24"
                                                                    FontSize="9"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Right"
                                                                    Command="{Binding DataContext.VerDetallePlanCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Cursor="Hand"
                                                                    Style="{StaticResource ThemeHeaderActionButtonStyle}"
                                                                    Visibility="{Binding PlanEjecutadoSemana, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
