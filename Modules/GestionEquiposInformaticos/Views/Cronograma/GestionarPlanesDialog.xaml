<Window x:Class="GestLog.Modules.GestionEquiposInformaticos.Views.Cronograma.GestionarPlanesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:GestLog.Converters"
    Title="Gestión de Planes de Cronograma"
    Width="1120"
    Height="760"
    MinWidth="980"
    MinHeight="680"
    WindowStartupLocation="CenterOwner"
    WindowState="Maximized"
    ResizeMode="NoResize"
    WindowStyle="None"
    AllowsTransparency="True"
    ShowInTaskbar="False"
    Background="Transparent"
    KeyDown="GestionarPlanesDialog_KeyDown">
    <Window.Resources>
        <converters:BooleanToStringConverter x:Key="BooleanToStringConverter" />
        <converters:DiaProgramadoToNombreDiaConverter x:Key="DiaProgramadoToNombreDiaConverter" />
        <converters:BooleanToColorConverter x:Key="BooleanToColorConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid"
        Background="#CC000000"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True">

        <Border x:Name="Card"
                Width="1080"
                MaxHeight="820"
                Background="{DynamicResource BackgroundAppBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource ThemeCardShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource ThemeHeaderContainerStyle}"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        CornerRadius="20,20,0,0"
                        Padding="24,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="50"
                                    Height="50"
                                    Margin="0,0,14,0"
                                    CornerRadius="14"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1">
                                <Image Source="/Assets/image001.ico"
                                       Width="28"
                                       Height="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Gestión de Planes de Cronograma"
                                           Style="{StaticResource ThemeSectionTitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           FontSize="20" />
                                <TextBlock Text="Modal premium para crear, editar, activar o eliminar planes"
                                           Style="{StaticResource ThemeSectionSubtitleStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Opacity="0.88" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="Nuevo plan"
                                    Click="NuevoPlanButton_Click"
                                    Style="{StaticResource ThemeHeaderPrimaryButtonStyle}"
                                    MinWidth="132"
                                    Margin="0,0,12,0" />
                            <Button Style="{StaticResource ThemeCloseButtonStyle}"
                                    Click="CerrarButton_Click"
                                    ToolTip="Cerrar (Esc)"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="✕"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Margin="24"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThemeScrollBarStyle}" />
                        <Style TargetType="Thumb" BasedOn="{StaticResource ThemeScrollBarThumbStyle}" />
                    </ScrollViewer.Resources>

                    <StackPanel>
                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,0,14">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Selecciona un plan para editarlo, activarlo/desactivarlo o eliminarlo."
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="12"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource ThemeElevatedCardStyle}"
                                Margin="0,0,0,14"
                                Padding="0">
                            <DataGrid x:Name="PlanesListView"
                                      ItemsSource="{Binding Planes}"
                                      SelectionMode="Single"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      Margin="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Style="{StaticResource ThemeDataGridStyle}"
                                      RowStyle="{StaticResource ThemeDataGridRowStyle}"
                                      CellStyle="{StaticResource ThemeDataGridCellStyle}"
                                      ColumnHeaderStyle="{StaticResource ThemeDataGridColumnHeaderStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoEquipo}" Width="120" />

                                    <DataGridTemplateColumn Header="Nombre equipo" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Equipo.NombreEquipo, FallbackValue=''}"
                                                           Style="{StaticResource ThemeDataGridTextStyle}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Usuario asignado" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Equipo.UsuarioAsignado, FallbackValue=''}"
                                                           Style="{StaticResource ThemeDataGridTextStyle}"
                                                           Foreground="{DynamicResource TextBodyBrush}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Día" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} ({1})">
                                                            <Binding Path="DiaProgramado" />
                                                            <Binding Path="DiaProgramado" Converter="{StaticResource DiaProgramadoToNombreDiaConverter}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Estado" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Activo, Converter={StaticResource BooleanToStringConverter}}"
                                                           Foreground="{Binding Activo, Converter={StaticResource BooleanToColorConverter}}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Creación" Binding="{Binding FechaCreacion, StringFormat='dd/MM/yyyy'}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Acciones del plan seleccionado"
                                               Style="{StaticResource ThemeSectionSubtitleStyle}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,14,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Content="Editar"
                                            x:Name="BtnEditar"
                                            Style="{StaticResource ThemeSecondaryButtonStyle}"
                                            Margin="0,0,10,0"
                                            Click="EditarButton_Click" />
                                    <Button Content="Activar/Desactivar"
                                            Style="{StaticResource ThemeSecondaryButtonStyle}"
                                            Margin="0,0,10,0"
                                            Click="ToggleActivoButton_Click" />
                                    <Button Content="Eliminar"
                                            Style="{StaticResource ThemeDangerButtonStyle}"
                                            Click="EliminarButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="EditPanel"
                                Style="{StaticResource ThemeDetailSectionCardStyle}"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,14,0">
                                    <TextBlock Text="Código equipo"
                                               Style="{StaticResource ThemeDetailLabelStyle}" />
                                    <TextBox x:Name="TxtCodigoEquipoEditar"
                                             Style="{StaticResource ThemeTextBoxStyle}"
                                             IsReadOnly="True"
                                             Background="{DynamicResource BackgroundElevatedBrush}"
                                             ToolTip="El equipo no se puede cambiar. Elimine el plan y cree uno nuevo si necesita asignar otro equipo." />
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="0,0,14,0">
                                    <TextBlock Text="Día programado"
                                               Style="{StaticResource ThemeDetailLabelStyle}" />
                                    <ComboBox x:Name="CmbDiaEditar"
                                              Style="{StaticResource ThemeComboBoxStyle}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Tag="1">1 - Lunes</ComboBoxItem>
                                        <ComboBoxItem Tag="2">2 - Martes</ComboBoxItem>
                                        <ComboBoxItem Tag="3">3 - Miércoles</ComboBoxItem>
                                        <ComboBoxItem Tag="4">4 - Jueves</ComboBoxItem>
                                        <ComboBoxItem Tag="5">5 - Viernes</ComboBoxItem>
                                        <ComboBoxItem Tag="6">6 - Sábado</ComboBoxItem>
                                        <ComboBoxItem Tag="7">7 - Domingo</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="Responsable"
                                               Style="{StaticResource ThemeDetailLabelStyle}" />
                                    <TextBox x:Name="TxtResponsableEditar"
                                             Style="{StaticResource ThemeTextBoxStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,18,0,0">
                                    <Button Content="Guardar"
                                            x:Name="BtnGuardarEdicion"
                                            Style="{StaticResource ThemePrimaryButtonStyle}"
                                            Width="120"
                                            Margin="0,0,10,0"
                                            Click="GuardarEdicionButton_Click" />
                                    <Button Content="Cancelar"
                                            x:Name="BtnCancelarEdicion"
                                            Style="{StaticResource ThemeSecondaryButtonStyle}"
                                            Width="120"
                                            Click="CancelarEdicionButton_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="Transparent"
                        Padding="24,0,24,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Listo"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" />

                        <Button Grid.Column="1"
                                Content="Cerrar"
                                Padding="14,8"
                                Style="{StaticResource ThemeSecondaryButtonStyle}"
                                Click="CerrarButton_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
