<UserControl x:Class="GestLog.Modules.DaaterProccesor.Views.DaaterProccesorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:GestLog.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <UserControl.Resources>
        <Style x:Key="HeroBadgeStyle" TargetType="Border" BasedOn="{StaticResource ThemeInfoNoticeStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>

        <Style x:Key="MiniMetricCardStyle" TargetType="Border" BasedOn="{StaticResource ThemeElevatedCardStyle}">
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="StepCircleStyle" TargetType="Border">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="17" />
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundAppBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="28,22,28,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource ThemeWelcomeCardStyle}" Padding="24,20" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <WrapPanel Margin="0,0,0,8">
                            <Border Style="{StaticResource HeroBadgeStyle}">
                                <TextBlock Text="Centro de operaciones"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Style="{StaticResource HeroBadgeStyle}">
                                <TextBlock Text="Excel Workflow"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="72" Height="72" CornerRadius="36" Margin="0,0,14,0">
                                <TextBlock Text="📊"
                                           Style="{DynamicResource ThemeCardIconTextStyle}"
                                           FontSize="34"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DaaterProccesor"
                                           Style="{DynamicResource ThemeSectionTitleStyle}"
                                           FontSize="27" />
                                <TextBlock Text="Operación premium para consolidación, análisis y filtrado de archivos Excel"
                                           Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           MaxWidth="560" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Ejecuta el procesamiento masivo desde una sola vista, conserva trazabilidad operativa y pasa al módulo de filtros sin salir del flujo principal."
                                   Style="{DynamicResource ThemeBodyTextStyle}"
                                   FontSize="14"
                                   Margin="0,0,0,14"
                                   TextWrapping="Wrap"
                                   MaxWidth="700" />

                        <Border Style="{DynamicResource ThemeInfoNoticeStyle}" MaxWidth="720" Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ℹ️"
                                           FontSize="16"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Salida operativa"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="Los consolidados y exportaciones se generan automáticamente en la carpeta Output del ejecutable."
                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                               FontSize="13"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource MiniMetricCardStyle}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Estado actual" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MiniMetricCardStyle}" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="Ruta de trabajo" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="{Binding ExecutablePath}" Foreground="{DynamicResource TextBodyBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MiniMetricCardStyle}" Padding="14,12" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Módulos disponibles" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Text="Procesamiento masivo y filtros avanzados" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="24,20">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,10">
                            <Border Style="{StaticResource HeroBadgeStyle}">
                                <TextBlock Text="Acción principal"
                                           Foreground="{DynamicResource PrimaryBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Procesamiento de archivos Excel" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="18" Margin="0,0,0,8" />
                        <TextBlock Text="Selecciona una carpeta y ejecuta el flujo completo de consolidación sobre todos los archivos Excel válidos detectados." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,14" />

                        <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Incluye" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="• Lectura de múltiples archivos y subcarpetas" Style="{DynamicResource ThemeBodyTextStyle}" FontSize="13" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Text="• Consolidación del contenido en una única salida" Style="{DynamicResource ThemeBodyTextStyle}" FontSize="13" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="2" Text="• Seguimiento visual del progreso en tiempo real" Style="{DynamicResource ThemeBodyTextStyle}" FontSize="13" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button Content="Seleccionar carpeta y procesar"
                                Style="{StaticResource ThemePrimaryButtonStyle}"
                                Command="{Binding ProcessExcelFilesCommand}"
                                IsEnabled="{Binding CanProcessFiles}"
                                HorizontalAlignment="Left"
                                Padding="18,11" />
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="22,18" Margin="0,0,0,18">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Border Style="{StaticResource HeroBadgeStyle}">
                                    <TextBlock Text="Acceso secundario"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Text="Filtros y exportación" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="17" Margin="0,0,0,8" />
                            <TextBlock Text="Abre la vista de consolidado para aplicar filtros especializados y exportar resultados finales." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,14" />

                            <Button Content="Abrir filtros avanzados"
                                    Style="{StaticResource ThemeSecondaryButtonStyle}"
                                    Click="OnOpenFilteredDataViewClick"
                                    HorizontalAlignment="Left"
                                    Padding="18,11" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20,16">
                        <StackPanel>
                            <TextBlock Text="Flujo operativo" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="17" Margin="0,0,0,10" />

                            <StackPanel Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource StepCircleStyle}">
                                        <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Selecciona origen" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="Elige la carpeta que contiene los archivos a consolidar." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource StepCircleStyle}">
                                        <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Consolida" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="Supervisa el avance y deja que el sistema genere la salida consolidada." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource StepCircleStyle}">
                                        <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Filtra y exporta" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" />
                                        <TextBlock Text="Accede al consolidado para obtener subconjuntos listos para entrega." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>

        <Grid Grid.RowSpan="2"
              Panel.ZIndex="20"
              Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="{DynamicResource ModalOverlayBrush}" />
            <Border x:Name="ProcessingCard"
                    Style="{DynamicResource ThemeWelcomeCardStyle}"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="520"
                    MaxWidth="700"
                    Effect="{DynamicResource WindowShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="12,12,0,0"
                            Padding="24,16"
                            Effect="{DynamicResource HeaderShadow}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                        CornerRadius="8"
                                        Padding="8"
                                        Margin="0,0,16,0"
                                        Width="44"
                                        Height="44"
                                        BorderThickness="0"
                                        BorderBrush="Transparent"
                                        Effect="{DynamicResource SectionShadow}">
                                    <TextBlock Text="⏳" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Procesando archivos Excel" Style="{DynamicResource HeaderTextStyle}" Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                    <TextBlock Text="La operación continúa en primer plano hasta completar el consolidado" Style="{DynamicResource SubHeaderTextStyle}" Foreground="{DynamicResource TextOnPrimaryBrush}" Margin="0,3,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource CloseButton}"
                                    Command="{Binding CancelProcessingCommand}"
                                    ToolTip="Cancelar procesamiento">
                                <Grid Width="14" Height="14">
                                    <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                            </Button>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{DynamicResource BackgroundSurfaceBrush}" Padding="24,20">
                        <StackPanel>
                            <TextBlock Text="Estado actual" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource ThemeBodyTextStyle}" FontSize="14" Margin="0,0,0,14" TextWrapping="Wrap" />

                            <controls:SimpleProgressBar ProgressValue="{Binding Progress}"
                                                        Title="Avance del procesamiento"
                                                        StatusMessage="{Binding StatusMessage}"
                                                        BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                                        TitleColor="{DynamicResource TextPrimaryBrush}"
                                                        PercentageColor="{DynamicResource PrimaryBrush}"
                                                        MessageColor="{DynamicResource TextSecondaryBrush}"
                                                        BarForeground="{DynamicResource PrimaryBrush}"
                                                        BarBackground="{DynamicResource BorderDefaultBrush}"
                                                        BarHeight="18"
                                                        CornerRadius="8"
                                                        Margin="0,0,0,14" />

                            <Border Background="{DynamicResource BackgroundElevatedBrush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="Ruta de salida" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ExecutablePath}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{DynamicResource BackgroundSurfaceBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="0,1,0,0"
                            CornerRadius="0,0,12,12"
                            Padding="24,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancelar"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CancelProcessingCommand}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
    </Grid>
</UserControl>

