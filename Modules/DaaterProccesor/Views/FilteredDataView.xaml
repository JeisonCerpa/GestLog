<Window x:Class="GestLog.Modules.DaaterProccesor.Views.FilteredDataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filtrar consolidado"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Style="{StaticResource ModalWindowBase}">

    <Grid x:Name="RootGrid"
          Background="Transparent"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

        <Rectangle Fill="{DynamicResource ModalOverlayBrush}" />

        <Border x:Name="Card"
                MinWidth="1040"
                MaxWidth="1340"
                MaxHeight="860"
                Style="{DynamicResource ThemeWelcomeCardStyle}"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{DynamicResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="12,12,0,0"
                        Padding="24,16"
                        Effect="{DynamicResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BackgroundSurfaceBrush}"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,0,16,0"
                                    Width="44"
                                    Height="44"
                                    BorderThickness="0"
                                    BorderBrush="Transparent"
                                    Effect="{DynamicResource SectionShadow}">
                                <TextBlock Text="🔍"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryBrush}" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Filtrar datos consolidados"
                                           Style="{DynamicResource HeaderTextStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}" />
                                <TextBlock Text="Filtros especializados para productos de acero y perfiles metálicos"
                                           Style="{DynamicResource SubHeaderTextStyle}"
                                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButton}"
                                Width="32"
                                Height="32"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CancelarButton_Click"
                                ToolTip="Cerrar (Esc)">
                            <Grid Width="12" Height="12">
                                <Line X1="0" Y1="0" X2="12" Y2="12" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                <Line X1="12" Y1="0" X2="0" Y2="12" Stroke="{DynamicResource TextOnPrimaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        Margin="18"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <DataGrid x:Name="FilteredDataGrid"
                                  AutoGenerateColumns="True"
                                  Margin="15"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  AlternatingRowBackground="{DynamicResource BackgroundElevatedBrush}"
                                  RowBackground="Transparent"
                                  FontFamily="Segoe UI"
                                  FontSize="12"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  AutoGeneratingColumn="FilteredDataGrid_AutoGeneratingColumn">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="10,8" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,1,0" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>

                        <Border x:Name="EmptyStatePanel"
                                Visibility="Visible"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource BackgroundElevatedBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="28,24"
                                MaxWidth="620">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="64"
                                        Height="64"
                                        CornerRadius="32"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        Margin="0,0,0,14"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="📂"
                                               FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}" />
                                </Border>

                                <TextBlock Text="Aún no hay datos consolidados cargados"
                                          Style="{DynamicResource ThemeSectionTitleStyle}"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          HorizontalAlignment="Center"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="Selecciona un archivo consolidado para visualizar registros y habilitar los filtros especializados de exportación."
                                          Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                          HorizontalAlignment="Center"
                                          TextAlignment="Center"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,16" />

                                <Button Content="Cargar consolidado"
                                        Style="{StaticResource ThemeSecondaryButtonStyle}"
                                        Click="LoadConsolidatedFile_Click"
                                        ToolTip="Seleccionar un archivo consolidado desde cualquier ubicación"
                                        HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource BackgroundSurfaceBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,12,12"
                        Padding="20,15">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="txtRecordCount"
                                  Text="Cargue datos consolidados para aplicar filtros especializados"
                                  Style="{DynamicResource ThemeSectionSubtitleStyle}"
                                  FontSize="14"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0"
                                  DockPanel.Dock="Left" />

                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="btnExportFiltros"
                                    Content="Filtros Productos Acero"
                                    Style="{StaticResource ThemePrimaryButtonStyle}"
                                    Click="ExportAcerosEspeciales_Click"
                                    Margin="0"
                                    IsEnabled="False"
                                    ToolTip="Generar 7 hojas Excel: CONSOLIDADO (todos los datos), ACEROS ESPECIALES (7225400000), LÁMINAS, ROLLOS, ÁNGULOS, CANALES y VIGAS con filtros específicos por categoría" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

